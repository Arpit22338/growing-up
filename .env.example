MONGODB_URI=mongodb+srv://your_user:your_password@cluster0.xxxxx.mongodb.net/growingup?retryWrites=true&w=majority
SESSION_SECRET=your_random_session_secret_here
PORT=3000
NODE_ENV=production

SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=YourSecurePassword123

FIN_SEC_EMAIL=finance@example.com
FIN_SEC_PASSWORD=YourFinPassword123

BASE_URL=https://yourdomain.com

# Required: random 32+ char string. Used to authorize Vercel Cron callbacks.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=replace_with_a_long_random_string

# Cloudinary (profile pictures + payment screenshots).
# Easiest: paste the full URL Cloudinary gives you in the dashboard.
# Format: cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name
# Or set the three values separately (used as a fallback if CLOUDINARY_URL is unset):
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
