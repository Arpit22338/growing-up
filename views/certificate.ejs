<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Certificate of Completion — Growing Up</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
  <style>
    @page { size: A4 landscape; margin: 0; }
    * { box-sizing: border-box; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    body {
      margin: 0;
      background: #0A1F44;
      font-family: 'Poppins', sans-serif;
      min-height: 100vh;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      padding: 16px;
    }
    .no-print {
      width: 100%; max-width: 1060px;
      display: flex; gap: 10px; justify-content: flex-end; margin-bottom: 14px;
      flex-wrap: wrap;
    }
    .no-print button, .no-print a {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 10px 18px; border: none; border-radius: 8px;
      font-family: 'Poppins', sans-serif; font-size: 14px; font-weight: 600;
      cursor: pointer; text-decoration: none;
      transition: transform 0.1s, box-shadow 0.15s, background 0.15s;
    }
    .no-print button:hover, .no-print a:hover { transform: translateY(-1px); box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
    .no-print .print-btn { background: #D4A017; color: #0A1F44; }
    .no-print .download-btn { background: #10B981; color: #fff; }
    .no-print .verify-btn { background: #fff; color: #10B981; border: 1.5px solid #10B981; }
    .no-print .back-btn { background: #fff; color: #0A1F44; border: 1.5px solid #0A1F44; }

    .cert-wrapper {
      width: 1060px; max-width: 100%;
    }
    .certificate {
      width: 100%;
      aspect-ratio: 1.414 / 1;
      background: #FFFEF7;
      position: relative;
      padding: 40px 60px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.3);
      border: 14px solid transparent;
      background-clip: padding-box;
      color: #0A1F44;
      display: flex; flex-direction: column;
    }
    .certificate::before {
      content: '';
      position: absolute; inset: 0;
      border: 2px solid #D4A017;
      pointer-events: none;
      margin: 8px;
    }
    .certificate::after {
      content: '';
      position: absolute; inset: 0;
      border: 1px solid #D4A017;
      pointer-events: none;
      margin: 16px;
    }
    .corner {
      position: absolute; width: 60px; height: 60px;
      border: 3px solid #D4A017;
    }
    .corner.tl { top: 24px; left: 24px; border-right: 0; border-bottom: 0; }
    .corner.tr { top: 24px; right: 24px; border-left: 0; border-bottom: 0; }
    .corner.bl { bottom: 24px; left: 24px; border-right: 0; border-top: 0; }
    .corner.br { bottom: 24px; right: 24px; border-left: 0; border-top: 0; }

    .cert-header { text-align: center; margin-top: 8px; }
    .cert-logo {
      display: inline-flex; align-items: center; gap: 10px;
      font-weight: 700; font-size: 18px; color: #0A1F44;
    }
    .cert-logo img { width: 38px; height: 38px; border-radius: 50%; }
    .cert-logo span { color: #D4A017; }

    .cert-body { text-align: center; margin-top: auto; flex: 1; display: flex; flex-direction: column; justify-content: center; }
    .cert-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 52px; font-weight: 700;
      color: #0A1F44; letter-spacing: 2px;
      margin: 0 0 6px;
    }
    .cert-subtitle { font-size: 17px; color: #475569; margin: 0 0 16px; }
    .cert-presented { font-size: 15px; color: #64748B; margin: 0 0 4px; font-style: italic; }
    .cert-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 42px; font-weight: 600;
      color: #0A1F44;
      margin: 4px 0 10px;
      border-bottom: 2px solid #D4A017;
      display: inline-block;
      padding: 0 30px 6px;
    }
    .cert-completion {
      font-size: 15px; color: #475569;
      max-width: 600px;
      margin: 0 auto 8px;
      line-height: 1.4;
    }
    .cert-course {
      font-family: 'Cormorant Garamond', serif;
      font-size: 28px; font-weight: 600;
      color: #D4A017;
      margin: 0 0 6px;
    }
    .cert-seal {
      width: 80px; height: 80px;
      background: linear-gradient(135deg, #D4A017, #B8860B);
      color: #0A1F44;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 32px;
      box-shadow: 0 4px 12px rgba(212,168,67,0.4);
      margin: 0 auto;
    }

    .cert-footer {
      display: flex; justify-content: space-between; align-items: flex-end;
      margin-top: auto;
      padding: 0 20px;
      gap: 30px;
    }
    .cert-sig {
      text-align: center; flex: 1; max-width: 240px;
      display: flex; flex-direction: column; align-items: center;
    }
    .cert-sig img.sig-img { width: 220px; height: auto; margin-bottom: 0; object-fit: contain; }
    .cert-sig img.stamp-img { height: 170px; width: auto; margin-bottom: 0; object-fit: contain; }
    .cert-sig .line {
      border-top: 2px solid #0A1F44;
      padding-top: 4px;
      font-weight: 700; color: #0A1F44; font-size: 14px;
      width: 100%;
    }
    .cert-sig .role { font-size: 12px; color: #64748B; margin-top: 1px; }

    .cert-id {
      text-align: center; flex: 1;
      font-size: 11px; color: #94A3B8;
      font-family: monospace;
      display: flex; flex-direction: column; align-items: center; gap: 6px;
    }
    .cert-id strong { color: #475569; display: block; font-size: 12px; font-weight: 700; }
    .cert-id-row { display: inline-flex; align-items: center; gap: 6px; }
    .cert-id-copy {
      background: #F1F5F9; border: 1px solid #CBD5E1;
      color: #0A1F44;
      padding: 4px 10px; border-radius: 6px;
      font-size: 13px; font-weight: 700;
      cursor: pointer; font-family: monospace;
      display: inline-flex; align-items: center; gap: 6px;
      transition: background 0.15s;
    }
    .cert-id-copy:hover { background: #E2E8F0; }
    .cert-id-copy i { color: #0A1F44; }
    .cert-id-hint { font-size: 10px; color: #94A3B8; }

    /* MOBILE: scale the whole cert down to fit screen, no scroll */
    @media (max-width: 760px) {
      body { padding: 10px 0; background: #0A1F44; }
      .no-print { padding: 0 12px; justify-content: center; }
      .no-print button, .no-print a { padding: 8px 10px; font-size: 11px; gap: 4px; }
      .cert-wrapper {
        width: 100vw;
        max-width: 100vw;
        overflow: hidden;
        padding: 0 6px;
      }
      .certificate {
        width: 700px;
        transform-origin: top left;
        padding: 28px 40px;
      }
      .cert-title { font-size: 38px; }
      .cert-name { font-size: 30px; padding: 0 20px 5px; }
      .cert-course { font-size: 22px; }
      .cert-seal { width: 60px; height: 60px; font-size: 24px; }
      .cert-sig img.sig-img { width: 170px; }
      .cert-sig img.stamp-img { height: 130px; }
      .corner { width: 40px; height: 40px; }
      .corner.tl, .corner.tr { top: 16px; }
      .corner.bl, .corner.br { bottom: 16px; }
      .corner.tl, .corner.bl { left: 16px; }
      .corner.tr, .corner.br { right: 16px; }
    }

    @media print {
      body { background: #fff; padding: 0; }
      .no-print { display: none !important; }
      .cert-wrapper { width: 100%; max-width: none; }
      .certificate {
        box-shadow: none;
        width: 100%;
        height: 100vh;
        aspect-ratio: auto;
      }
    }
  </style>
</head>
<body>

  <div class="no-print">
    <a href="/profile" class="back-btn"><i class='bx bx-arrow-back'></i> Back to Profile</a>
    <a href="/certificates" class="back-btn" style="background:#0A1F44;color:#D4A017;border-color:#0A1F44;"><i class='bx bx-collection'></i> All Certificates</a>
    <a href="/verify/GU-<%= certId %>" class="verify-btn" target="_blank" rel="noopener"><i class='bx bx-shield-check'></i> Verify</a>
    <button type="button" class="download-btn" data-action="download"><i class='bx bx-download'></i> Download</button>
    <button type="button" class="print-btn" data-action="print"><i class='bx bx-printer'></i> Print / Save as PDF</button>
  </div>

  <div class="cert-wrapper">
    <div class="certificate">
      <div class="corner tl"></div>
      <div class="corner tr"></div>
      <div class="corner bl"></div>
      <div class="corner br"></div>

      <div class="cert-header">
        <div class="cert-logo">
          <img src="/images/logo-web.png" alt="Growing Up">
          Growing <span>Up</span>
        </div>
      </div>

      <div class="cert-body">
        <h1 class="cert-title">Certificate of Completion</h1>
        <p class="cert-subtitle">Knowledge-Building Program</p>
        <p class="cert-presented">This certificate is proudly presented to</p>
        <div class="cert-name">
          <%= user.firstName %><% if (user.middleName) { %> <%= user.middleName %><% } %> <%= user.lastName %>
        </div>
        <p class="cert-completion">
          for successfully completing every module of
        </p>
        <div class="cert-course"><%= course.name %></div>
        <div class="cert-seal"><i class='bx bxs-medal'></i></div>
      </div>

      <div class="cert-footer">
        <div class="cert-sig">
          <img src="/images/signature.png" alt="Signature" class="sig-img">
          <div class="line">Arpit Kafle</div>
          <div class="role">Founder, Growing Up</div>
        </div>
        <div class="cert-id">
          <strong>Certificate ID</strong>
          <div class="cert-id-row">
            <button type="button" class="cert-id-copy" data-copy-text="GU-<%= certId %>" aria-label="Copy certificate ID">
              <span>GU-<%= certId %></span>
              <i class='bx bx-copy'></i>
            </button>
          </div>
          <div class="cert-id-hint">Issued <%= issuedAt %></div>
          <div class="cert-id-hint">Verify at growingup.tech/verify/GU-<%= certId %></div>
        </div>
        <div class="cert-sig">
          <img src="/images/stamp.png" alt="Growing Up Stamp" class="stamp-img">
          <div class="role">Knowledge-Building Program</div>
        </div>
      </div>
    </div>
  </div>

  <div class="toast-container" id="toastContainer" style="position:fixed;top:80px;right:20px;z-index:99999;display:flex;flex-direction:column;gap:10px;"></div>

  <script>
    function copyToClipboard(text, onSuccess, onError) {
      function done() { if (onSuccess) onSuccess(); }
      function fail() { if (onError) onError(); }
      function fallback(t) {
        var ta = document.createElement('textarea');
        ta.value = t; ta.setAttribute('readonly', '');
        ta.style.position = 'fixed'; ta.style.top = '0'; ta.style.left = '0';
        ta.style.width = '1px'; ta.style.height = '1px'; ta.style.opacity = '0';
        document.body.appendChild(ta); ta.focus(); ta.select();
        var ok = false;
        try { ok = document.execCommand('copy'); } catch (e) { ok = false; }
        document.body.removeChild(ta);
        if (ok && onSuccess) onSuccess(); else if (!ok && onError) onError();
      }
      if (navigator.clipboard && window.isSecureContext) {
        navigator.clipboard.writeText(text).then(done, function() { fallback(text); });
      } else {
        fallback(text);
      }
    }
    function showToast(message, type) {
      type = type || 'success';
      var c = document.getElementById('toastContainer');
      if (!c) return;
      var t = document.createElement('div');
      t.style.cssText = 'background:#fff;color:#0A1F44;padding:12px 20px;border-radius:8px;box-shadow:0 4px 16px rgba(0,0,0,0.15);font-family:Poppins,sans-serif;font-size:14px;font-weight:600;border-left:4px solid ' + (type==='success'?'#10B981':'#EF4444') + ';';
      t.innerHTML = '<i class="bx ' + (type === 'success' ? 'bx-check-circle' : 'bx-error-circle') + '"></i> ' + message;
      c.appendChild(t);
      setTimeout(function() { t.remove(); }, 2500);
    }
    document.addEventListener('click', function(e) {
      var btn = e.target.closest('[data-copy-text]');
      if (btn) {
        e.preventDefault();
        var text = btn.getAttribute('data-copy-text') || '';
        if (!text) return;
        copyToClipboard(text,
          function() {
            showToast('Certificate ID copied!', 'success');
            var orig = btn.getAttribute('data-copy-orig') || btn.innerHTML;
            btn.setAttribute('data-copy-orig', orig);
            btn.innerHTML = "<i class='bx bx-check'></i> Copied";
            setTimeout(function() { btn.innerHTML = orig; }, 1500);
          },
          function() { showToast('Copy failed', 'error'); }
        );
        return;
      }
      var act = e.target.closest('[data-action]');
      if (act) {
        var action = act.getAttribute('data-action');
        if (action === 'print' || action === 'download') {
          window.print();
        }
      }
    });

    // Scale certificate on mobile so it fits the screen without scrolling
    (function() {
      var cert = document.querySelector('.certificate');
      var wrapper = document.querySelector('.cert-wrapper');
      if (!cert || !wrapper) return;
      function scaleCert() {
        if (window.innerWidth <= 760) {
          var scale = (window.innerWidth - 12) / 700;
          if (scale > 1) scale = 1;
          cert.style.transform = 'scale(' + scale + ')';
          wrapper.style.height = (cert.scrollHeight * scale) + 'px';
        } else {
          cert.style.transform = '';
          wrapper.style.height = '';
        }
      }
      scaleCert();
      window.addEventListener('resize', scaleCert);
    })();
  </script>

  <% if (typeof downloadMode !== 'undefined' && downloadMode) { %>
  <script>
    setTimeout(function() { window.print(); }, 600);
  </script>
  <% } %>
</body>
</html>
