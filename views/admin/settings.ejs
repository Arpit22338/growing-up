<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="csrf-token" content="<%= csrfToken %>">
  <title>Settings — Admin — Growing Up</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
  <style>
    .settings-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 28px; margin-bottom: 24px; }
    .qr-upload-card {
      background: var(--gray-50); border: 2px dashed var(--gray-200); border-radius: 12px;
      padding: 24px; text-align: center; transition: var(--transition);
    }
    .qr-upload-card:hover { border-color: var(--gold); background: #faf8f2; }
    .qr-upload-card h4 { font-size: 16px; font-weight: 700; color: var(--navy); margin-bottom: 16px; }
    .qr-upload-card h4 i { color: var(--gold); margin-right: 6px; }
    .qr-preview {
      width: 180px; height: 180px; margin: 0 auto 16px; border-radius: 10px;
      overflow: hidden; border: 2px solid var(--gray-200); background: var(--white);
      display: flex; align-items: center; justify-content: center;
    }
    .qr-preview img { width: 100%; height: 100%; object-fit: contain; }
    .qr-preview .qr-empty { color: var(--gray-400); font-size: 14px; text-align: center; }
    .qr-preview .qr-empty i { font-size: 40px; display: block; margin-bottom: 8px; }
    .qr-file-label {
      display: inline-flex; align-items: center; gap: 8px; cursor: pointer;
      background: var(--navy); color: var(--white); padding: 10px 20px; border-radius: 8px;
      font-size: 13px; font-weight: 600; transition: var(--transition);
    }
    .qr-file-label:hover { background: var(--gold); color: var(--navy); }
    .qr-file-label input { display: none; }
    .qr-file-name { font-size: 12px; color: var(--gray-500); margin-top: 8px; min-height: 18px; }
    .info-table td { padding: 10px 0; border-bottom: 1px solid var(--gray-100); }
    .info-table td:first-child { color: var(--gray-500); width: 160px; }
    .info-table td:last-child { font-weight: 600; }
    @media (max-width: 640px) { .settings-grid { grid-template-columns: 1fr; } }
  </style>
</head>
<body>
  <div class="admin-layout">
    <%- include('sidebar', { role, active: 'settings' }) %>

    <div class="admin-content">
      <h1 style="margin-bottom: 8px;"><i class='bx bx-cog' style="color: var(--gold);"></i> Settings</h1>
      <p style="color: var(--gray-500); margin-bottom: 28px;">Manage payment QR codes and platform configuration.</p>

      <!-- QR Code Upload -->
      <div class="card" style="margin-bottom: 28px;">
        <h3 style="margin-bottom: 6px;"><i class='bx bx-qr' style="color: var(--gold);"></i> Payment QR Codes</h3>
        <p style="color: var(--gray-500); margin-bottom: 24px; font-size: 13px;">
          Upload eSewa & Khalti QR images. Shown to users during registration payment.
        </p>

        <form id="qrForm" enctype="multipart/form-data">
          <div class="settings-grid">
            <!-- eSewa -->
            <div class="qr-upload-card">
              <h4><i class='bx bx-wallet'></i> eSewa QR</h4>
              <div class="qr-preview" id="esewaPreview">
                <% if (settings.esewaQR) { %>
                  <img src="<%= settings.esewaQR %>" alt="eSewa QR">
                <% } else { %>
                  <div class="qr-empty"><i class='bx bx-image-add'></i>No QR uploaded</div>
                <% } %>
              </div>
              <label class="qr-file-label">
                <i class='bx bx-upload'></i> Choose Image
                <input type="file" name="esewaQR" accept="image/*" onchange="previewQR(this, 'esewaPreview', 'esewaName')">
              </label>
              <div class="qr-file-name" id="esewaName"></div>
            </div>

            <!-- Khalti -->
            <div class="qr-upload-card">
              <h4><i class='bx bx-wallet-alt'></i> Khalti QR</h4>
              <div class="qr-preview" id="khaltiPreview">
                <% if (settings.khaltiQR) { %>
                  <img src="<%= settings.khaltiQR %>" alt="Khalti QR">
                <% } else { %>
                  <div class="qr-empty"><i class='bx bx-image-add'></i>No QR uploaded</div>
                <% } %>
              </div>
              <label class="qr-file-label">
                <i class='bx bx-upload'></i> Choose Image
                <input type="file" name="khaltiQR" accept="image/*" onchange="previewQR(this, 'khaltiPreview', 'khaltiName')">
              </label>
              <div class="qr-file-name" id="khaltiName"></div>
            </div>
          </div>

          <div style="text-align: center; margin-top: 8px;">
            <button type="submit" class="btn btn-gold btn-lg" id="uploadBtn" style="min-width: 220px;">
              <i class='bx bx-cloud-upload'></i> Save QR Codes
            </button>
          </div>
        </form>
      </div>

      <!-- System Info -->
      <div class="card">
        <h3 style="margin-bottom: 16px;"><i class='bx bx-info-circle' style="color: var(--gold);"></i> System Info</h3>
        <table class="info-table" style="width: 100%;">
          <tr>
            <td>Last QR Update</td>
            <td><%= settings.updatedAt ? new Date(settings.updatedAt).toLocaleString() : 'Never' %></td>
          </tr>
          <tr>
            <td>Platform</td>
            <td>Growing Up v1.0</td>
          </tr>
        </table>
      </div>
    </div>
  </div>

  <div class="toast-container" id="toastContainer"></div>
  <script>
    function showToast(msg, type) {
      type = type || 'success';
      var c = document.getElementById('toastContainer');
      var t = document.createElement('div');
      t.className = 'toast toast-' + type;
      t.innerHTML = '<i class="bx ' + (type === 'success' ? 'bx-check-circle' : 'bx-error-circle') + '"></i> ' + msg;
      c.appendChild(t);
      setTimeout(function() { t.remove(); }, 4000);
    }

    function previewQR(input, previewId, nameId) {
      var preview = document.getElementById(previewId);
      var nameEl = document.getElementById(nameId);
      if (input.files && input.files[0]) {
        var file = input.files[0];
        nameEl.textContent = file.name;
        var reader = new FileReader();
        reader.onload = function(e) {
          preview.innerHTML = '<img src="' + e.target.result + '" alt="QR Preview">';
        };
        reader.readAsDataURL(file);
      }
    }

    var csrfMeta = document.querySelector('meta[name="csrf-token"]');
    var CSRF = csrfMeta ? csrfMeta.content : '';

    document.getElementById('qrForm').addEventListener('submit', function(e) {
      e.preventDefault();
      var btn = document.getElementById('uploadBtn');
      btn.disabled = true;
      btn.innerHTML = '<i class="bx bx-loader-alt bx-spin"></i> Uploading...';

      var fd = new FormData(e.target);
      fetch('/admin/settings/qr', {
        method: 'POST',
        headers: { 'X-CSRF-Token': CSRF },
        body: fd
      })
      .then(function(res) { return res.json(); })
      .then(function(data) {
        if (data.success) {
          showToast('QR codes updated successfully!');
          setTimeout(function() { location.reload(); }, 1500);
        } else {
          showToast(data.error || 'Upload failed', 'error');
          btn.disabled = false;
          btn.innerHTML = '<i class="bx bx-cloud-upload"></i> Save QR Codes';
        }
      })
      .catch(function(err) {
        showToast('Network error. Try again.', 'error');
        btn.disabled = false;
        btn.innerHTML = '<i class="bx bx-cloud-upload"></i> Save QR Codes';
      });
    });
  </script>
</body>
</html>
