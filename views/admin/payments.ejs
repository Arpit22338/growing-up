<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
  <title>Payments — Admin — Growing Up</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
</head>
<body>
  <div class="admin-layout">
    <%- include('sidebar', { role, active: 'payments' }) %>

    <div class="admin-content">
      <div class="admin-topbar">
        <button class="hamburger" id="hamBtn"><i class='bx bx-menu'></i></button>
        <div>
          <h1 style="margin-bottom: 2px;"><i class='bx bx-credit-card'></i> Payment Requests</h1>
          <p style="color: var(--gray-500); font-size: 13px; margin: 0;">Review and manage user payments</p>
        </div>
      </div>

      <!-- Status Filter -->
      <div style="display: flex; gap: 8px; margin-bottom: 24px; flex-wrap: wrap;">
        <a href="/admin/payments?status=pending" class="btn btn-sm <%= status === 'pending' ? 'btn-primary' : 'btn-outline' %>">
          Pending
        </a>
        <a href="/admin/payments?status=approved" class="btn btn-sm <%= status === 'approved' ? 'btn-success' : 'btn-outline' %>">
          Approved
        </a>
        <a href="/admin/payments?status=rejected" class="btn btn-sm <%= status === 'rejected' ? 'btn-danger' : 'btn-outline' %>">
          Rejected
        </a>
      </div>

      <div class="card">
        <% if (payments.length === 0) { %>
          <p style="text-align: center; color: var(--gray-500); padding: 40px;">
            No <%= status %> payments found.
          </p>
        <% } else { %>
          <div class="table-container">
            <table>
              <thead>
                <tr>
                  <th>User</th>
                  <th>Course</th>
                  <th>Amount</th>
                  <th>Screenshot</th>
                  <th>Txn ID</th>
                  <th>Date</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% payments.forEach(p => { %>
                  <tr id="payment-<%= p._id %>">
                    <td>
                      <strong><%= p.user ? p.user.firstName + ' ' + p.user.lastName : 'Unknown' %></strong>
                      <br><small style="color: var(--gray-500);"><%= p.user ? p.user.whatsapp : '' %></small>
                    </td>
                    <td><%= p.courseName %></td>
                    <td><strong>₹<%= p.price %></strong></td>
                    <td>
                      <img src="<%= p.screenshot %>" class="screenshot-thumb"
                        data-full="<%= p.screenshot %>">
                    </td>
                    <td><%= p.transactionId || '-' %></td>
                    <td><%= new Date(p.createdAt).toLocaleDateString() %></td>
                    <td>
                      <% if (status === 'pending') { %>
                        <button class="btn btn-success btn-sm approve-btn" data-id="<%= p._id %>">
                          <i class='bx bx-check'></i> Approve
                        </button>
                        <% if (role === 'superadmin') { %>
                          <button class="btn btn-danger btn-sm reject-btn" data-id="<%= p._id %>" style="margin-top: 4px;">
                            <i class='bx bx-x'></i> Reject
                          </button>
                        <% } %>
                      <% } else { %>
                        <span class="badge badge-<%= status %>"><%= status %></span>
                      <% } %>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Screenshot Modal -->
  <div class="modal-overlay" id="screenshotModal">
    <div class="modal" style="max-width: 600px; text-align: center;">
      <h3>Payment Screenshot</h3>
      <img id="screenshotFull" style="max-width: 100%; border-radius: 8px;">
      <div class="modal-actions" style="justify-content: center;">
        <button class="btn btn-outline" id="closeScreenshotModal">Close</button>
      </div>
    </div>
  </div>

  <div class="toast-container" id="toastContainer"></div>
  <script>
    function showToast(msg, type) {
      type = type || 'success';
      var c = document.getElementById('toastContainer');
      if (!c) return;
      var t = document.createElement('div');
      t.className = 'toast toast-' + type;
      t.innerHTML = '<i class="bx ' + (type === 'success' ? 'bx-check-circle' : 'bx-error-circle') + '"></i> ' + msg;
      c.appendChild(t);
      setTimeout(function() { t.remove(); }, 4000);
    }

    var csrfMeta = document.querySelector('meta[name="csrf-token"]');
    var CSRF = csrfMeta ? csrfMeta.content : '';

    // Close screenshot modal
    var closeModalBtn = document.getElementById('closeScreenshotModal');
    if (closeModalBtn) {
      closeModalBtn.addEventListener('click', function() {
        document.getElementById('screenshotModal').classList.remove('show');
      });
    }

    // Screenshot viewer — event delegation
    document.addEventListener('click', function(e) {
      var thumb = e.target.closest('.screenshot-thumb');
      if (thumb) {
        var src = thumb.getAttribute('data-full');
        if (src) {
          document.getElementById('screenshotFull').src = src;
          document.getElementById('screenshotModal').classList.add('show');
        }
        return;
      }

      // Approve button — event delegation
      var approveBtn = e.target.closest('.approve-btn');
      if (approveBtn) {
        e.preventDefault();
        e.stopPropagation();
        var id = approveBtn.getAttribute('data-id');
        if (!id) return;
        if (!confirm('Approve this payment?')) return;
        approveBtn.disabled = true;
        approveBtn.innerHTML = '<span class="spinner"></span> Approving...';
        fetch('/admin/payments/' + id + '/approve', {
          method: 'POST',
          headers: { 'X-CSRF-Token': CSRF },
          credentials: 'same-origin'
        }).then(function(res) {
          if (res.redirected || res.status === 401 || res.status === 302) {
            showToast('Session expired. Please login again.', 'error');
            setTimeout(function() { window.location.href = '/admin/login'; }, 1500);
            return null;
          }
          return res.json();
        }).then(function(data) {
          if (!data) return;
          if (data.success) {
            showToast('Payment approved successfully!');
            var row = document.getElementById('payment-' + id);
            if (row) row.remove();
          } else {
            showToast(data.error || 'Failed to approve', 'error');
            approveBtn.disabled = false;
            approveBtn.innerHTML = '<i class="bx bx-check"></i> Approve';
          }
        }).catch(function(err) {
          showToast('Error: ' + (err.message || 'Connection failed'), 'error');
          approveBtn.disabled = false;
          approveBtn.innerHTML = '<i class="bx bx-check"></i> Approve';
        });
        return;
      }

      // Reject button — event delegation
      var rejectBtn = e.target.closest('.reject-btn');
      if (rejectBtn) {
        e.preventDefault();
        e.stopPropagation();
        var rid = rejectBtn.getAttribute('data-id');
        if (!rid) return;
        var reason = prompt('Rejection reason (optional):');
        if (reason === null) return;
        rejectBtn.disabled = true;
        rejectBtn.innerHTML = '<span class="spinner"></span> Rejecting...';
        fetch('/admin/payments/' + rid + '/reject', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF },
          credentials: 'same-origin',
          body: JSON.stringify({ reason: reason })
        }).then(function(res) {
          if (res.redirected || res.status === 401 || res.status === 302) {
            showToast('Session expired. Please login again.', 'error');
            setTimeout(function() { window.location.href = '/admin/login'; }, 1500);
            return null;
          }
          return res.json();
        }).then(function(data) {
          if (!data) return;
          if (data.success) {
            showToast('Payment rejected');
            var row = document.getElementById('payment-' + rid);
            if (row) row.remove();
          } else {
            showToast(data.error || 'Failed to reject', 'error');
            rejectBtn.disabled = false;
            rejectBtn.innerHTML = '<i class="bx bx-x"></i> Reject';
          }
        }).catch(function(err) {
          showToast('Error: ' + (err.message || 'Connection failed'), 'error');
          rejectBtn.disabled = false;
          rejectBtn.innerHTML = '<i class="bx bx-x"></i> Reject';
        });
        return;
      }
    });

    // Hamburger
    var hamBtn = document.getElementById('hamBtn');
    if (hamBtn) {
      hamBtn.addEventListener('click', function() {
        var sb = document.getElementById('adminSidebar');
        if (sb) sb.classList.toggle('open');
      });
    }
  </script>
</body>
</html>
