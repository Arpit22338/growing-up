<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
  <title>User Detail — Admin — Growing Up</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
</head>
<body>
  <div class="admin-layout">
    <%- include('sidebar', { role, active: 'users' }) %>

    <div class="admin-content">
      <style>
        @media (max-width: 768px) {
          .ud-grid { grid-template-columns: 1fr !important; }
        }
      </style>
      <div class="admin-topbar">
        <button class="hamburger" id="hamBtn"><i class='bx bx-menu'></i></button>
        <a href="/admin/users" style="color: var(--gray-500); font-size: 13px; display: inline-flex; align-items: center; gap: 4px;">
          <i class='bx bx-arrow-back'></i> Back to Users
        </a>
      </div>

      <h1><i class='bx bx-user'></i> <%= user.firstName %> <%= user.middleName || '' %> <%= user.lastName %></h1>

      <!-- User Info -->
      <div class="ud-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 24px;">
        <div class="card">
          <h3 style="margin-bottom: 16px;"><i class='bx bx-info-circle' style="color: var(--gold);"></i> Information</h3>
          <div class="table-container">
            <table style="width: 100%;">
            <tr><td style="padding: 8px 0; color: var(--gray-500);">Email</td><td style="font-weight: 600;"><%= user.email %></td></tr>
            <tr><td style="padding: 8px 0; color: var(--gray-500);">WhatsApp</td><td style="font-weight: 600;"><%= user.whatsapp %></td></tr>
            <tr><td style="padding: 8px 0; color: var(--gray-500);">Gender</td><td><%= user.gender === 'M' ? 'Male' : 'Female' %></td></tr>
            <tr><td style="padding: 8px 0; color: var(--gray-500);">Referral Code</td><td><code style="background: var(--gray-100); padding: 2px 8px; border-radius: 4px;"><%= user.referralCode %></code></td></tr>
            <tr>
              <td style="padding: 8px 0; color: var(--gray-500);">Referral Link</td>
              <td>
                <div style="display: flex; gap: 8px; align-items: center; flex-wrap: wrap;">
                  <input type="text" readonly value="<%= typeof baseUrl !== 'undefined' ? baseUrl : 'https://growingup.tech' %>/register?ref=<%= user.referralCode %>" id="userRefLink" style="font-size: 12px; padding: 4px 8px; border: 1px solid var(--gray-200); border-radius: 4px; background: var(--gray-50); flex: 1; min-width: 200px;">
                </div>
              </td>
            </tr>
            <tr>
              <td style="padding: 8px 0; color: var(--gray-500);">Status</td>
              <td><span class="badge <%= user.isActive ? 'badge-active' : 'badge-inactive' %>"><%= user.isActive ? 'Active' : 'Inactive' %></span></td>
            </tr>
            <tr><td style="padding: 8px 0; color: var(--gray-500);">Joined</td><td><%= new Date(user.createdAt).toLocaleDateString() %></td></tr>
            </table>
          </div>
        </div>
        <div class="card">
          <h3 style="margin-bottom: 16px;"><i class='bx bx-money' style="color: var(--gold);"></i> Earnings & Referrals</h3>
          <div style="background:#fff!important;border-radius:12px!important;padding:20px!important;box-shadow:0 2px 8px rgba(0,0,0,0.08)!important;display:flex!important;flex-direction:column!important;align-items:center!important;text-align:center!important;width:auto!important;height:auto!important;">
            <i class='bx bx-money' style="font-size:28px;color:#D4A017;margin-bottom:8px;"></i>
            <div style="font-size:24px;font-weight:700;color:#0A1F44;">₹<%= user.totalEarnings %></div>
            <div style="font-size:13px;color:#888;margin-top:4px;">Total Earnings (Commissions)</div>
          </div>
          <div style="margin-top: 12px;">
            <p style="color: var(--gray-500); font-size: 13px;">Referred By:</p>
            <p style="font-weight: 600;">
              <%= user.referredBy ? user.referredBy.firstName + ' ' + user.referredBy.lastName + ' (' + user.referredBy.referralCode + ')' : 'None (Direct)' %>
            </p>
          </div>
          <% if (role === 'superadmin') { %>
            <div style="margin-top: 16px;">
              <label style="font-size: 13px; color: var(--gray-500); display: block; margin-bottom: 4px;">Change Role:</label>
              <select class="form-control" id="roleSelect" style="width: auto; display: inline-block;">
                <option value="user" <%= user.role === 'user' ? 'selected' : '' %>>User</option>
                <option value="financial_secretary" <%= user.role === 'financial_secretary' ? 'selected' : '' %>>Financial Secretary</option>
              </select>
              <button class="btn btn-primary btn-sm" onclick="changeRole()">Update</button>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Referral Tree -->
      <div class="card" style="margin-bottom: 24px;">
        <h3 style="margin-bottom: 16px; display: flex; align-items: center; gap: 8px; flex-wrap: wrap;">
          <i class='bx bx-git-branch' style="color: var(--gold);"></i> Referral Tree (<%= user.referredUsers ? user.referredUsers.length : 0 %> direct)
          <button class="btn btn-primary btn-sm" onclick="loadFullTree()" id="treeBtn" style="margin-left: auto;">
            <i class='bx bx-expand'></i> View Full Downline
          </button>
        </h3>
        <% if (user.referredUsers && user.referredUsers.length > 0) { %>
          <div class="table-container">
            <table>
              <thead>
                <tr><th>Name</th><th>Email</th><th>WhatsApp</th><th>Status</th><th>Joined</th></tr>
              </thead>
              <tbody>
                <% user.referredUsers.forEach(r => { %>
                  <tr>
                    <td><a href="/admin/users/<%= r._id %>" style="color: var(--navy); font-weight: 600;"><%= r.firstName %> <%= r.lastName %></a></td>
                    <td><%= r.email %></td>
                    <td><%= r.whatsapp %></td>
                    <td><span class="badge <%= r.isActive ? 'badge-active' : 'badge-inactive' %>"><%= r.isActive ? 'Active' : 'Pending' %></span></td>
                    <td><%= new Date(r.createdAt).toLocaleDateString() %></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <p style="color: var(--gray-500); text-align: center; padding: 20px;">No referrals yet.</p>
        <% } %>

        <!-- Full Downline Tree Container -->
        <div id="fullTreeContainer" style="display: none; margin-top: 20px; border-top: 1px solid var(--gray-200); padding-top: 20px;">
          <h4 style="color: var(--navy); margin-bottom: 12px;"><i class='bx bx-sitemap' style="color: var(--gold);"></i> Full Downline Tree</h4>
          <div id="treeContent" style="font-size: 14px;"></div>
        </div>
      </div>

      <!-- Courses (incl. admin-granted) -->
      <% if (user.purchasedCourses && user.purchasedCourses.length > 0) { %>
        <div class="card" style="margin-bottom: 24px;">
          <h3 style="margin-bottom: 16px;"><i class='bx bx-book-open' style="color: var(--gold);"></i> Courses (<%= user.purchasedCourses.length %>)</h3>
          <div class="table-container">
            <table>
              <thead>
                <tr><th>Course</th><th>Price</th><th>Status</th><th>Progress</th><th>Source</th><th>Date</th></tr>
              </thead>
              <tbody>
                <% user.purchasedCourses.forEach(function(c) {
                  const done = (c.completedModules && c.completedModules.length) || 0;
                %>
                  <tr>
                    <td><%= c.courseName || c.courseKey %></td>
                    <td>₹<%= c.price || 0 %></td>
                    <td><span class="badge badge-<%= c.status %>"><%= c.status %></span></td>
                    <td style="font-size:12px;color:#64748B;">
                      <% if (c.status === 'approved') { %><%= done %> module<%= done === 1 ? '' : 's' %><% } else { %>—<% } %>
                    </td>
                    <td>
                      <% if (c.grantedBy) { %>
                        <span style="display:inline-flex;align-items:center;gap:4px;background:#D4A017;color:#0A1F44;padding:2px 8px;border-radius:10px;font-size:11px;font-weight:700;">
                          <i class='bx bx-gift'></i> Granted
                        </span>
                      <% } else { %>
                        <span style="color:#64748B;font-size:12px;">Self-purchased</span>
                      <% } %>
                    </td>
                    <td><%= new Date(c.purchasedAt).toLocaleDateString() %></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>
      <% } %>

      <!-- Payment History -->
      <div class="card">
        <h3 style="margin-bottom: 16px;"><i class='bx bx-receipt' style="color: var(--gold);"></i> Payment History</h3>
        <% if (payments.length > 0) { %>
          <div class="table-container">
            <table>
              <thead>
                <tr><th>Course</th><th>Amount</th><th>Status</th><th>Txn ID</th><th>Date</th></tr>
              </thead>
              <tbody>
                <% payments.forEach(p => { %>
                  <tr>
                    <td><%= p.courseName %></td>
                    <td>₹<%= p.price %></td>
                    <td><span class="badge badge-<%= p.status %>"><%= p.status %></span></td>
                    <td><%= p.transactionId || '-' %></td>
                    <td><%= new Date(p.createdAt).toLocaleDateString() %></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <p style="color: var(--gray-500); text-align: center; padding: 20px;">No payment records.</p>
        <% } %>
      </div>

      <!-- Grant Course (Super Admin only) -->
      <% if (role === 'superadmin' && user.role === 'user') { %>
        <div class="card" style="margin-top: 24px; border: 2px dashed #D4A017;">
          <h3 style="margin-bottom: 6px;"><i class='bx bx-gift' style="color: var(--gold);"></i> Grant Course to User</h3>
          <p style="color: var(--gray-500); font-size: 13px; margin-bottom: 16px;">
            Give <strong><%= user.firstName %></strong> a course for free. No payment record is created. The user gets full access immediately.
          </p>
          <div style="display: flex; gap: 12px; align-items: flex-end; flex-wrap: wrap;">
            <div style="flex: 1; min-width: 200px;">
              <label style="font-size: 12px; color: var(--gray-500); display: block; margin-bottom: 4px; font-weight: 600;">Select Course</label>
              <select id="grantCourseKey" class="form-control" onchange="updateGrantBtn()">
                <option value="">— Choose a course —</option>
                <% Object.keys({
                  starter: 'Starter Package',
                  prime: 'Prime Package',
                  master: 'Master Package',
                  everything: 'Everything Bundle'
                }).forEach(function(k) { %>
                  <option value="<%= k %>"><%= {
                    starter: 'Starter Package',
                    prime: 'Prime Package',
                    master: 'Master Package',
                    everything: 'Everything Bundle'
                  }[k] %></option>
                <% }); %>
              </select>
            </div>
            <div style="flex: 2; min-width: 240px;">
              <label style="font-size: 12px; color: var(--gray-500); display: block; margin-bottom: 4px; font-weight: 600;">Reason (optional, internal note)</label>
              <input type="text" id="grantReason" class="form-control" placeholder="e.g. Promo, beta tester, support escalation..." maxlength="200">
            </div>
            <div>
              <button type="button" class="btn btn-primary" id="grantCourseBtn" disabled style="background: #CBD5E1; color: #64748B; border: none; padding: 10px 18px; cursor: not-allowed; font-weight: 700; transition: background 0.2s, color 0.2s;">
                <i class='bx bx-gift'></i> Grant Course
              </button>
            </div>
          </div>
          <div id="grantCourseMsg" style="margin-top: 12px; font-size: 13px;"></div>
        </div>

        <!-- Grant Course confirmation modal -->
        <div id="grantConfirmModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.6); z-index:99999; align-items:center; justify-content:center; padding:16px;">
          <div style="background:#fff; border-radius:14px; padding:28px; max-width:440px; width:100%; box-shadow:0 20px 60px rgba(0,0,0,0.3);">
            <h3 style="margin:0 0 8px; color:#0A1F44; font-size:1.25rem; display:flex; align-items:center; gap:8px;">
              <i class='bx bx-gift' style="color:#D4A017;"></i> Confirm Course Grant
            </h3>
            <p style="color:#475569; font-size:14px; margin:0 0 18px; line-height:1.5;">
              Are you sure you want to grant
              <strong id="grantConfirmCourse" style="color:#0A1F44;"></strong>
              to <strong id="grantConfirmUser" style="color:#0A1F44;"><%= user.firstName %></strong>?
              They will get immediate access and no payment record will be created.
            </p>
            <div id="grantConfirmReason" style="background:#F1F5F9; border-radius:8px; padding:10px 14px; font-size:13px; color:#475569; margin-bottom:18px; display:none;"></div>
            <div style="display:flex; gap:10px; justify-content:flex-end;">
              <button type="button" id="grantConfirmCancel" style="background:#fff; color:#0A1F44; border:1.5px solid #CBD5E1; padding:10px 18px; border-radius:8px; font-weight:700; cursor:pointer;">
                Cancel
              </button>
              <button type="button" id="grantConfirmYes" style="background:#D4A017; color:#0A1F44; border:none; padding:10px 18px; border-radius:8px; font-weight:700; cursor:pointer;">
                <i class='bx bx-check'></i> Yes, Grant It
              </button>
            </div>
          </div>
        </div>
      <% } %>
    </div>
  </div>

  <div class="toast-container" id="toastContainer"></div>
  <script>
    function showToast(msg, type='success') {
      const c = document.getElementById('toastContainer');
      const t = document.createElement('div');
      t.className = 'toast toast-' + type;
      t.innerHTML = '<i class="bx ' + (type === 'success' ? 'bx-check-circle' : 'bx-error-circle') + '"></i> ' + msg;
      c.appendChild(t);
      setTimeout(() => t.remove(), 4000);
    }

    var csrfMeta = document.querySelector('meta[name="csrf-token"]');
    var CSRF = csrfMeta ? csrfMeta.content : '';

    async function changeRole() {
      const role = document.getElementById('roleSelect').value;
      try {
        const res = await fetch('/admin/users/<%= user._id %>/role', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF },
          credentials: 'same-origin',
          body: JSON.stringify({ role })
        });
        if (res.redirected) {
          showToast('Session expired. Please login again.', 'error');
          setTimeout(function(){ window.location.href = '/admin/login'; }, 1500);
          return;
        }
        var data;
        try { data = await res.json(); } catch (e) {
          showToast('Server error (status ' + res.status + ')', 'error');
          return;
        }
        if (data.success) {
          showToast('Role updated!');
        } else {
          showToast(data.error || 'Failed', 'error');
        }
      } catch (err) {
        showToast('Error: ' + (err.message || 'Connection failed'), 'error');
      }
    }

    // Enable/disable the Grant Course button based on the select.
    // Disabled = gray + cursor not-allowed. Enabled = gold (#D4A017).
    function updateGrantBtn() {
      try {
        var keyEl = document.getElementById('grantCourseKey');
        var btn = document.getElementById('grantCourseBtn');
        if (!keyEl || !btn) return;
        if (keyEl.value) {
          btn.disabled = false;
          btn.style.background = '#D4A017';
          btn.style.color = '#0A1F44';
          btn.style.cursor = 'pointer';
        } else {
          btn.disabled = true;
          btn.style.background = '#CBD5E1';
          btn.style.color = '#64748B';
          btn.style.cursor = 'not-allowed';
        }
      } catch (e) {
        console.error('updateGrantBtn error:', e);
      }
    }

    // Belt-and-suspenders: also wire the change event programmatically
    // so the button toggles even if the inline onchange attribute is
    // stripped by an extension / CSP / browser quirk.
    (function(){
      var keyEl = document.getElementById('grantCourseKey');
      if (keyEl) {
        keyEl.addEventListener('change', updateGrantBtn);
        keyEl.addEventListener('input', updateGrantBtn);
      }
    })();

    // Show the confirmation modal before actually submitting the grant.
    function grantCourse() {
      var keyEl = document.getElementById('grantCourseKey');
      var reasonEl = document.getElementById('grantReason');
      var msg = document.getElementById('grantCourseMsg');
      var key = keyEl.value;
      if (!key) {
        msg.innerHTML = "<span style='color:#991B1B;'>Please choose a course.</span>";
        return;
      }
      var courseName = keyEl.options[keyEl.selectedIndex].text;
      document.getElementById('grantConfirmCourse').textContent = courseName;
      var reasonBox = document.getElementById('grantConfirmReason');
      if (reasonEl.value.trim()) {
        reasonBox.textContent = 'Reason: ' + reasonEl.value.trim();
        reasonBox.style.display = 'block';
      } else {
        reasonBox.style.display = 'none';
      }
      document.getElementById('grantConfirmModal').style.display = 'flex';
    }

    // Wire up the modal buttons AND the grant course button.
    (function(){
      var grantBtn = document.getElementById('grantCourseBtn');
      if (grantBtn) {
        grantBtn.addEventListener('click', function() {
          grantCourse();
        });
      }
      var modal = document.getElementById('grantConfirmModal');
      if (!modal) return;
      document.getElementById('grantConfirmCancel').addEventListener('click', function() {
        modal.style.display = 'none';
      });
      document.getElementById('grantConfirmYes').addEventListener('click', function() {
        modal.style.display = 'none';
        submitGrantCourse();
      });
      // Click on the backdrop closes the modal
      modal.addEventListener('click', function(e) {
        if (e.target === modal) modal.style.display = 'none';
      });
      // Esc closes the modal
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && modal.style.display === 'flex') modal.style.display = 'none';
      });
    })();

    // Actually call the server endpoint. Invoked only after the user confirms.
    async function submitGrantCourse() {
      var keyEl = document.getElementById('grantCourseKey');
      var reasonEl = document.getElementById('grantReason');
      var btn = document.getElementById('grantCourseBtn');
      var msg = document.getElementById('grantCourseMsg');
      var key = keyEl.value;
      if (!key) {
        msg.innerHTML = "<span style='color:#991B1B;'>Please choose a course.</span>";
        showToast('Please choose a course', 'error');
        return;
      }
      btn.disabled = true;
      btn.innerHTML = '<i class="bx bx-loader-alt bx-spin"></i> Granting...';
      msg.innerHTML = '';
      try {
        var res = await fetch('/admin/users/<%= user._id %>/grant-course', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF },
          credentials: 'same-origin',
          body: JSON.stringify({ courseKey: key, reason: reasonEl.value })
        });
        if (res.redirected || res.status === 401) {
          showToast('Session expired. Please login again.', 'error');
          setTimeout(function(){ window.location.href = '/admin/login'; }, 1500);
          btn.disabled = false;
          updateGrantBtn();
          btn.innerHTML = '<i class="bx bx-gift"></i> Grant Course';
          return;
        }
        var data;
        try {
          data = await res.json();
        } catch (parseErr) {
          console.error('Grant course: failed to parse response', parseErr);
          msg.innerHTML = "<span style='color:#991B1B;'>Server returned an invalid response (status " + res.status + ").</span>";
          showToast('Server error — check console', 'error');
          btn.disabled = false;
          updateGrantBtn();
          btn.innerHTML = '<i class="bx bx-gift"></i> Grant Course';
          return;
        }
        if (data.success) {
          showToast(data.message || 'Course granted!');
          msg.innerHTML = "<span style='color:#065F46;'>Course granted. Reloading...</span>";
          setTimeout(function(){ window.location.reload(); }, 900);
        } else {
          var errMsg = data.error || 'Failed (status ' + res.status + ')';
          console.error('Grant course error:', errMsg);
          msg.innerHTML = "<span style='color:#991B1B;'>" + errMsg + "</span>";
          showToast(errMsg, 'error');
          btn.disabled = false;
          updateGrantBtn();
          btn.innerHTML = '<i class="bx bx-gift"></i> Grant Course';
        }
      } catch (err) {
        console.error('Grant course fetch error:', err);
        msg.innerHTML = "<span style='color:#991B1B;'>Connection failed: " + (err.message || 'Unknown error') + "</span>";
        showToast('Connection failed: ' + (err.message || ''), 'error');
        btn.disabled = false;
        updateGrantBtn();
        btn.innerHTML = '<i class="bx bx-gift"></i> Grant Course';
      }
    }

    // Init: ensure the button starts disabled (in case browser autofills the select)
    updateGrantBtn();

    async function loadFullTree() {
      var btn = document.getElementById('treeBtn');
      btn.disabled = true;
      btn.innerHTML = '<i class="bx bx-loader-alt bx-spin"></i> Loading...';
      try {
        var res = await fetch('/admin/users/<%= user._id %>/tree');
        if (res.status === 401) {
          showToast('Session expired. Please login again.', 'error');
          setTimeout(function(){ window.location.href = '/admin/login'; }, 1500);
          return;
        }
        var data = await res.json();
        if (data.tree) {
          var container = document.getElementById('fullTreeContainer');
          var content = document.getElementById('treeContent');
          content.innerHTML = renderTree(data.tree, 0);
          container.style.display = 'block';
          btn.innerHTML = '<i class="bx bx-collapse"></i> Tree Loaded';
        }
      } catch (err) {
        showToast('Failed to load tree', 'error');
        btn.disabled = false;
        btn.innerHTML = '<i class="bx bx-expand"></i> View Full Downline';
      }
    }

    function renderTree(nodes, depth) {
      if (!nodes || nodes.length === 0) return '';
      var html = '<ul style="list-style:none;padding-left:' + (depth > 0 ? '24' : '0') + 'px;margin:0;">';
      nodes.forEach(function(node) {
        var statusBadge = node.isActive ? '<span class="badge badge-active" style="font-size:11px;">Active</span>' : '<span class="badge badge-inactive" style="font-size:11px;">Pending</span>';
        html += '<li style="padding:6px 0;border-left:' + (depth > 0 ? '2px solid var(--gray-200)' : 'none') + ';padding-left:' + (depth > 0 ? '12' : '0') + 'px;margin-left:' + (depth > 0 ? '8' : '0') + 'px;">';
        html += '<div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">';
        html += '<i class="bx bx-user" style="color:var(--gold);"></i>';
        html += '<a href="/admin/users/' + node._id + '" style="color:var(--navy);font-weight:600;">' + node.name + '</a>';
        html += '<span style="color:var(--gray-500);font-size:12px;">' + node.email + '</span>';
        html += statusBadge;
        if (node.children && node.children.length > 0) {
          html += '<span style="font-size:11px;color:var(--info);font-weight:600;">(' + node.children.length + ' referrals)</span>';
        }
        html += '</div>';
        if (node.children && node.children.length > 0) {
          html += renderTree(node.children, depth + 1);
        }
        html += '</li>';
      });
      html += '</ul>';
      return html;
    }

    document.getElementById('hamBtn').addEventListener('click', function() {
      document.getElementById('adminSidebar').classList.toggle('open');
    });
  </script>
</body>
</html>
