<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
  <title>User Detail — Admin — Growing Up</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
</head>
<body>
  <div class="admin-layout">
    <%- include('sidebar', { role, active: 'users' }) %>

    <div class="admin-content">
      <div class="admin-topbar">
        <button class="hamburger" id="hamBtn"><i class='bx bx-menu'></i></button>
        <a href="/admin/users" style="color: var(--gray-500); font-size: 13px; display: inline-flex; align-items: center; gap: 4px;">
          <i class='bx bx-arrow-back'></i> Back to Users
        </a>
      </div>

      <h1><i class='bx bx-user'></i> <%= user.firstName %> <%= user.middleName || '' %> <%= user.lastName %></h1>

      <!-- User Info -->
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 24px;">
        <div class="card">
          <h3 style="margin-bottom: 16px;"><i class='bx bx-info-circle' style="color: var(--gold);"></i> Information</h3>
          <table style="width: 100%;">
            <tr><td style="padding: 8px 0; color: var(--gray-500);">Email</td><td style="font-weight: 600;"><%= user.email %></td></tr>
            <tr><td style="padding: 8px 0; color: var(--gray-500);">WhatsApp</td><td style="font-weight: 600;"><%= user.whatsapp %></td></tr>
            <tr><td style="padding: 8px 0; color: var(--gray-500);">Gender</td><td><%= user.gender === 'M' ? 'Male' : 'Female' %></td></tr>
            <tr><td style="padding: 8px 0; color: var(--gray-500);">Referral Code</td><td><code style="background: var(--gray-100); padding: 2px 8px; border-radius: 4px;"><%= user.referralCode %></code></td></tr>
            <tr>
              <td style="padding: 8px 0; color: var(--gray-500);">Referral Link</td>
              <td>
                <div style="display: flex; gap: 8px; align-items: center; flex-wrap: wrap;">
                  <input type="text" readonly value="<%= typeof baseUrl !== 'undefined' ? baseUrl : 'https://growingup.tech' %>/register?ref=<%= user.referralCode %>" id="userRefLink" style="font-size: 12px; padding: 4px 8px; border: 1px solid var(--gray-200); border-radius: 4px; background: var(--gray-50); flex: 1; min-width: 200px;">
                  <button type="button" style="padding:10px 18px;background:#D4A017;color:#fff;border:none;border-radius:8px;font-weight:700;cursor:pointer;font-size:14px;" onclick="(function(btn){var text=btn.previousElementSibling.value||btn.previousElementSibling.textContent;var el=document.createElement('textarea');el.value=text;el.style.position='fixed';el.style.opacity='0';document.body.appendChild(el);el.focus();el.select();document.execCommand('copy');document.body.removeChild(el);btn.textContent='✓ Copied!';setTimeout(function(){btn.textContent='Copy';},2000);})(this)">Copy</button>
                </div>
              </td>
            </tr>
            <tr>
              <td style="padding: 8px 0; color: var(--gray-500);">Status</td>
              <td><span class="badge <%= user.isActive ? 'badge-active' : 'badge-inactive' %>"><%= user.isActive ? 'Active' : 'Inactive' %></span></td>
            </tr>
            <tr><td style="padding: 8px 0; color: var(--gray-500);">Joined</td><td><%= new Date(user.createdAt).toLocaleDateString() %></td></tr>
          </table>
        </div>
        <div class="card">
          <h3 style="margin-bottom: 16px;"><i class='bx bx-money' style="color: var(--gold);"></i> Earnings & Referrals</h3>
          <div style="background:#fff!important;border-radius:12px!important;padding:20px!important;box-shadow:0 2px 8px rgba(0,0,0,0.08)!important;display:flex!important;flex-direction:column!important;align-items:center!important;text-align:center!important;width:auto!important;height:auto!important;">
            <i class='bx bx-money' style="font-size:28px;color:#D4A017;margin-bottom:8px;"></i>
            <div style="font-size:24px;font-weight:700;color:#0A1F44;">₹<%= user.totalEarnings %></div>
            <div style="font-size:13px;color:#888;margin-top:4px;">Total Earnings (Commissions)</div>
          </div>
          <div style="margin-top: 12px;">
            <p style="color: var(--gray-500); font-size: 13px;">Referred By:</p>
            <p style="font-weight: 600;">
              <%= user.referredBy ? user.referredBy.firstName + ' ' + user.referredBy.lastName + ' (' + user.referredBy.referralCode + ')' : 'None (Direct)' %>
            </p>
          </div>
          <% if (role === 'superadmin') { %>
            <div style="margin-top: 16px;">
              <label style="font-size: 13px; color: var(--gray-500); display: block; margin-bottom: 4px;">Change Role:</label>
              <select class="form-control" id="roleSelect" style="width: auto; display: inline-block;">
                <option value="user" <%= user.role === 'user' ? 'selected' : '' %>>User</option>
                <option value="financial_secretary" <%= user.role === 'financial_secretary' ? 'selected' : '' %>>Financial Secretary</option>
              </select>
              <button class="btn btn-primary btn-sm" onclick="changeRole()">Update</button>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Referral Tree -->
      <div class="card" style="margin-bottom: 24px;">
        <h3 style="margin-bottom: 16px; display: flex; align-items: center; gap: 8px; flex-wrap: wrap;">
          <i class='bx bx-git-branch' style="color: var(--gold);"></i> Referral Tree (<%= user.referredUsers ? user.referredUsers.length : 0 %> direct)
          <button class="btn btn-primary btn-sm" onclick="loadFullTree()" id="treeBtn" style="margin-left: auto;">
            <i class='bx bx-expand'></i> View Full Downline
          </button>
        </h3>
        <% if (user.referredUsers && user.referredUsers.length > 0) { %>
          <div class="table-container">
            <table>
              <thead>
                <tr><th>Name</th><th>Email</th><th>WhatsApp</th><th>Status</th><th>Joined</th></tr>
              </thead>
              <tbody>
                <% user.referredUsers.forEach(r => { %>
                  <tr>
                    <td><a href="/admin/users/<%= r._id %>" style="color: var(--navy); font-weight: 600;"><%= r.firstName %> <%= r.lastName %></a></td>
                    <td><%= r.email %></td>
                    <td><%= r.whatsapp %></td>
                    <td><span class="badge <%= r.isActive ? 'badge-active' : 'badge-inactive' %>"><%= r.isActive ? 'Active' : 'Pending' %></span></td>
                    <td><%= new Date(r.createdAt).toLocaleDateString() %></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <p style="color: var(--gray-500); text-align: center; padding: 20px;">No referrals yet.</p>
        <% } %>

        <!-- Full Downline Tree Container -->
        <div id="fullTreeContainer" style="display: none; margin-top: 20px; border-top: 1px solid var(--gray-200); padding-top: 20px;">
          <h4 style="color: var(--navy); margin-bottom: 12px;"><i class='bx bx-sitemap' style="color: var(--gold);"></i> Full Downline Tree</h4>
          <div id="treeContent" style="font-size: 14px;"></div>
        </div>
      </div>

      <!-- Payment History -->
      <div class="card">
        <h3 style="margin-bottom: 16px;"><i class='bx bx-receipt' style="color: var(--gold);"></i> Payment History</h3>
        <% if (payments.length > 0) { %>
          <div class="table-container">
            <table>
              <thead>
                <tr><th>Course</th><th>Amount</th><th>Status</th><th>Txn ID</th><th>Date</th></tr>
              </thead>
              <tbody>
                <% payments.forEach(p => { %>
                  <tr>
                    <td><%= p.courseName %></td>
                    <td>₹<%= p.price %></td>
                    <td><span class="badge badge-<%= p.status %>"><%= p.status %></span></td>
                    <td><%= p.transactionId || '-' %></td>
                    <td><%= new Date(p.createdAt).toLocaleDateString() %></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <p style="color: var(--gray-500); text-align: center; padding: 20px;">No payment records.</p>
        <% } %>
      </div>
    </div>
  </div>

  <div class="toast-container" id="toastContainer"></div>
  <script>
    function showToast(msg, type='success') {
      const c = document.getElementById('toastContainer');
      const t = document.createElement('div');
      t.className = 'toast toast-' + type;
      t.innerHTML = '<i class="bx ' + (type === 'success' ? 'bx-check-circle' : 'bx-error-circle') + '"></i> ' + msg;
      c.appendChild(t);
      setTimeout(() => t.remove(), 4000);
    }

    function doCopy(btn, text) {
      var inp = document.createElement('input');
      inp.setAttribute('value', text);
      inp.setAttribute('readonly', '');
      inp.style.cssText = 'position:absolute;left:-9999px;top:0;';
      document.body.appendChild(inp);
      inp.select();
      inp.setSelectionRange(0, 99999);
      var success = false;
      try { success = document.execCommand('copy'); } catch(e) { success = false; }
      document.body.removeChild(inp);
      if (success) {
        var orig = btn.innerHTML;
        btn.innerHTML = '✓ Copied!';
        btn.style.background = '#27AE60';
        btn.style.color = '#fff';
        setTimeout(function(){ btn.innerHTML = orig; btn.style.background = ''; btn.style.color = ''; }, 2000);
      } else {
        alert('Copy failed. Please copy manually:\n'+text);
      }
    }
    function copyLink(text, btn) { doCopy(btn, text); }

    var csrfMeta = document.querySelector('meta[name="csrf-token"]');
    var CSRF = csrfMeta ? csrfMeta.content : '';

    async function changeRole() {
      const role = document.getElementById('roleSelect').value;
      try {
        const res = await fetch('/admin/users/<%= user._id %>/role', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF },
          credentials: 'same-origin',
          body: JSON.stringify({ role })
        });
        if (res.redirected || res.status === 401) {
          showToast('Session expired. Please login again.', 'error');
          setTimeout(function(){ window.location.href = '/admin/login'; }, 1500);
          return;
        }
        const data = await res.json();
        if (data.success) {
          showToast('Role updated!');
        } else {
          showToast(data.error || 'Failed', 'error');
        }
      } catch (err) {
        showToast('Error: ' + (err.message || 'Connection failed'), 'error');
      }
    }

    async function loadFullTree() {
      var btn = document.getElementById('treeBtn');
      btn.disabled = true;
      btn.innerHTML = '<i class="bx bx-loader-alt bx-spin"></i> Loading...';
      try {
        var res = await fetch('/admin/users/<%= user._id %>/tree');
        if (res.status === 401) {
          showToast('Session expired. Please login again.', 'error');
          setTimeout(function(){ window.location.href = '/admin/login'; }, 1500);
          return;
        }
        var data = await res.json();
        if (data.tree) {
          var container = document.getElementById('fullTreeContainer');
          var content = document.getElementById('treeContent');
          content.innerHTML = renderTree(data.tree, 0);
          container.style.display = 'block';
          btn.innerHTML = '<i class="bx bx-collapse"></i> Tree Loaded';
        }
      } catch (err) {
        showToast('Failed to load tree', 'error');
        btn.disabled = false;
        btn.innerHTML = '<i class="bx bx-expand"></i> View Full Downline';
      }
    }

    function renderTree(nodes, depth) {
      if (!nodes || nodes.length === 0) return '';
      var html = '<ul style="list-style:none;padding-left:' + (depth > 0 ? '24' : '0') + 'px;margin:0;">';
      nodes.forEach(function(node) {
        var statusBadge = node.isActive ? '<span class="badge badge-active" style="font-size:11px;">Active</span>' : '<span class="badge badge-inactive" style="font-size:11px;">Pending</span>';
        html += '<li style="padding:6px 0;border-left:' + (depth > 0 ? '2px solid var(--gray-200)' : 'none') + ';padding-left:' + (depth > 0 ? '12' : '0') + 'px;margin-left:' + (depth > 0 ? '8' : '0') + 'px;">';
        html += '<div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">';
        html += '<i class="bx bx-user" style="color:var(--gold);"></i>';
        html += '<a href="/admin/users/' + node._id + '" style="color:var(--navy);font-weight:600;">' + node.name + '</a>';
        html += '<span style="color:var(--gray-500);font-size:12px;">' + node.email + '</span>';
        html += statusBadge;
        if (node.children && node.children.length > 0) {
          html += '<span style="font-size:11px;color:var(--info);font-weight:600;">(' + node.children.length + ' referrals)</span>';
        }
        html += '</div>';
        if (node.children && node.children.length > 0) {
          html += renderTree(node.children, depth + 1);
        }
        html += '</li>';
      });
      html += '</ul>';
      return html;
    }

    document.getElementById('hamBtn').addEventListener('click', function() {
      document.getElementById('adminSidebar').classList.toggle('open');
    });
  </script>
</body>
</html>
