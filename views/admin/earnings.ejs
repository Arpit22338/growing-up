<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
  <title>Earnings — Admin — Growing Up</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
</head>
<body>
  <div class="admin-layout">
    <%- include('sidebar', { role, active: 'earnings' }) %>

    <div class="admin-content">
      <div class="admin-topbar">
        <button class="hamburger" id="hamBtn"><i class='bx bx-menu'></i></button>
        <h1 style="margin-bottom: 0;"><i class='bx bx-bar-chart-alt-2'></i> Earnings Overview</h1>
      </div>

      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:16px;margin-bottom:24px;">
        <div style="background:#fff!important;border-radius:12px!important;padding:20px!important;box-shadow:0 2px 8px rgba(0,0,0,0.08)!important;display:flex!important;flex-direction:column!important;align-items:center!important;text-align:center!important;width:auto!important;height:auto!important;">
          <i class='bx bx-money' style="font-size:28px;color:#D4A017;margin-bottom:8px;"></i>
          <div style="font-size:24px;font-weight:700;color:#0A1F44;">₹<%= totalRevenue %></div>
          <div style="font-size:13px;color:#888;margin-top:4px;">Total Revenue</div>
        </div>
        <div style="background:#fff!important;border-radius:12px!important;padding:20px!important;box-shadow:0 2px 8px rgba(0,0,0,0.08)!important;display:flex!important;flex-direction:column!important;align-items:center!important;text-align:center!important;width:auto!important;height:auto!important;">
          <i class='bx bx-wallet' style="font-size:28px;color:#D4A017;margin-bottom:8px;"></i>
          <div style="font-size:24px;font-weight:700;color:#0A1F44;">₹<%= totalPlatform %></div>
          <div style="font-size:13px;color:#888;margin-top:4px;">Platform Earnings (35%)</div>
        </div>
        <div style="background:#fff!important;border-radius:12px!important;padding:20px!important;box-shadow:0 2px 8px rgba(0,0,0,0.08)!important;display:flex!important;flex-direction:column!important;align-items:center!important;text-align:center!important;width:auto!important;height:auto!important;">
          <i class='bx bx-group' style="font-size:28px;color:#D4A017;margin-bottom:8px;"></i>
          <div style="font-size:24px;font-weight:700;color:#0A1F44;">₹<%= totalReferrer %></div>
          <div style="font-size:13px;color:#888;margin-top:4px;">Referrer Commissions (65%)</div>
        </div>
      </div>

      <div class="card">
        <h3 style="margin-bottom: 16px;">Transaction History</h3>
        <% if (payments.length === 0) { %>
          <p style="text-align: center; color: var(--gray-500); padding: 40px;">No approved payments yet.</p>
        <% } else { %>
          <div class="table-container">
            <table>
              <thead>
                <tr>
                  <th>Buyer</th>
                  <th>Course</th>
                  <th>Total</th>
                  <th>Platform (35%)</th>
                  <th>Referrer (65%)</th>
                  <th>Referrer Name</th>
                  <th>Date</th>
                </tr>
              </thead>
              <tbody>
                <% payments.forEach(p => { %>
                  <tr>
                    <td><%= p.user ? p.user.firstName + ' ' + p.user.lastName : 'Unknown' %></td>
                    <td><%= p.courseName %></td>
                    <td><strong>₹<%= p.price %></strong></td>
                    <td>₹<%= p.platformCommission %></td>
                    <td>₹<%= p.referrerCommission %></td>
                    <td><%= p.referrer ? p.referrer.firstName + ' ' + p.referrer.lastName : '-' %></td>
                    <td><%= p.reviewedAt ? new Date(p.reviewedAt).toLocaleDateString() : '-' %></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
  <script>
    document.getElementById('hamBtn').addEventListener('click', function() {
      document.getElementById('adminSidebar').classList.toggle('open');
    });
  </script>
</body>
</html>
