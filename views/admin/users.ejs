<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Users — Admin — Growing Up</title>
  <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
</head>
<body>
  <div class="admin-layout">
    <%- include('sidebar', { role, active: 'users' }) %>

    <div class="admin-content">
      <div class="admin-topbar">
        <button class="hamburger" id="hamBtn"><i class='bx bx-menu'></i></button>
        <div style="flex: 1; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px;">
          <div>
            <h1 style="margin-bottom: 2px;"><i class='bx bx-group'></i> Users (<%= users.length %>)</h1>
            <p style="color: var(--gray-500); font-size: 13px; margin: 0;">Manage all platform users</p>
          </div>
          <% if (role === 'superadmin') { %>
            <a href="/admin/add-user" class="btn btn-gold">
              <i class='bx bx-user-plus'></i> Add User
            </a>
          <% } %>
        </div>
      </div>

      <!-- Search -->
      <div class="card" style="margin-bottom: 24px; padding: 16px;">
        <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
          <input type="text" class="form-control" id="userSearch" placeholder="Search by name, email, referral code, or phone..."
            oninput="filterUsers(this.value)" style="flex:1; min-width:200px;">
          <button type="button" class="btn btn-sm" onclick="document.getElementById('userSearch').value=''; filterUsers('');"
            style="background:#fff; border:1.5px solid #CBD5E1; color:#0A1F44; padding:6px 12px; border-radius:6px; cursor:pointer; font-weight:600; font-size:13px;">
            <i class='bx bx-x'></i> Clear
          </button>
          <span id="userSearchCount" style="color: var(--gray-500); font-size: 13px; font-weight: 600;"></span>
        </div>
      </div>

      <div class="card">
        <% if (users.length === 0) { %>
          <p style="text-align: center; color: var(--gray-500); padding: 40px;">No users found.</p>
        <% } else { %>
          <div class="table-container">
            <table id="usersTable">
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Email</th>
                  <th>WhatsApp</th>
                  <th>Referral Code</th>
                  <th>Referred By</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% users.forEach(u => { %>
                  <tr class="user-row" data-search="<%= (u.firstName + ' ' + u.lastName + ' ' + u.email + ' ' + (u.referralCode || '') + ' ' + (u.whatsapp || '')).toLowerCase() %>">
                    <td>
                      <a href="/admin/users/<%= u._id %>" style="color: var(--navy); font-weight: 600;">
                        <%= u.firstName %> <%= u.lastName %>
                      </a>
                    </td>
                    <td><%= u.email %></td>
                    <td><%= u.whatsapp %></td>
                    <td><code style="background: var(--gray-100); padding: 2px 8px; border-radius: 4px;"><%= u.referralCode %></code></td>
                    <td><%= u.referredBy ? u.referredBy.firstName + ' ' + u.referredBy.lastName : '-' %></td>
                    <td>
                      <span class="badge <%= u.isActive ? 'badge-active' : 'badge-inactive' %>">
                        <%= u.isActive ? 'Active' : 'Inactive' %>
                      </span>
                    </td>
                    <td>
                      <a href="/admin/users/<%= u._id %>" class="btn btn-primary btn-sm">
                        <i class='bx bx-show'></i>
                      </a>
                      <% if (role === 'superadmin') { %>
                        <button class="btn btn-danger btn-sm delete-user-btn" data-id="<%= u._id %>" data-name="<%= u.firstName %>">
                          <i class='bx bx-trash'></i>
                        </button>
                      <% } %>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <div class="toast-container" id="toastContainer"></div>
  <script>
    function showToast(msg, type) {
      type = type || 'success';
      var c = document.getElementById('toastContainer');
      if (!c) return;
      var t = document.createElement('div');
      t.className = 'toast toast-' + type;
      t.innerHTML = '<i class="bx ' + (type === 'success' ? 'bx-check-circle' : 'bx-error-circle') + '"></i> ' + msg;
      c.appendChild(t);
      setTimeout(function() { t.remove(); }, 4000);
    }

    function filterUsers(q) {
      var query = String(q || '').toLowerCase().trim();
      var rows = document.querySelectorAll('.user-row');
      var visible = 0;
      rows.forEach(function(row) {
        var hay = row.dataset.search || '';
        // For empty query, show all. Otherwise require the query to
        // appear as a contiguous substring (case-insensitive).
        var match = !query || hay.indexOf(query) !== -1;
        row.style.display = match ? '' : 'none';
        if (match) visible++;
      });
      var counter = document.getElementById('userSearchCount');
      if (counter) {
        counter.textContent = query ? (visible + ' of ' + rows.length) : (rows.length + ' total');
      }
      // Show "no results" message if every row is hidden
      var tableContainer = document.querySelector('.table-container');
      var noRes = document.getElementById('noResultsMsg');
      if (tableContainer) {
        if (query && visible === 0) {
          if (!noRes) {
            noRes = document.createElement('p');
            noRes.id = 'noResultsMsg';
            noRes.style.cssText = 'text-align:center; color: var(--gray-500); padding: 30px; font-size: 14px;';
            noRes.innerHTML = '<i class="bx bx-search-alt-2" style="font-size:32px;display:block;margin-bottom:8px;color:#CBD5E1;"></i>No users match &ldquo;' + query.replace(/[<>&"']/g, function(c){return {'<':'&lt;','>':'&gt;','&':'&amp;','"':'&quot;',"'":'&#39;'}[c];}) + '&rdquo;';
            tableContainer.parentNode.insertBefore(noRes, tableContainer.nextSibling);
          }
        } else if (noRes) {
          noRes.remove();
        }
      }
    }
    // Init: show initial count
    (function(){
      var rows = document.querySelectorAll('.user-row');
      var counter = document.getElementById('userSearchCount');
      if (counter) counter.textContent = rows.length + ' total';
    })();

    var csrfMeta = document.querySelector('meta[name="csrf-token"]');
    var CSRF = csrfMeta ? csrfMeta.content : '';

    // Event delegation for delete user button
    document.addEventListener('click', function(e) {
      var deleteBtn = e.target.closest('.delete-user-btn');
      if (!deleteBtn) return;
      e.preventDefault();
      e.stopPropagation();
      var id = deleteBtn.getAttribute('data-id');
      var name = deleteBtn.getAttribute('data-name');
      if (!id) return;
      if (!confirm('Delete user "' + name + '"? This cannot be undone.')) return;
      deleteBtn.disabled = true;
      fetch('/admin/users/' + id + '/delete', {
        method: 'POST',
        headers: { 'X-CSRF-Token': CSRF },
        credentials: 'same-origin'
      }).then(function(res) {
        if (res.redirected || res.status === 401) {
          showToast('Session expired. Please login again.', 'error');
          setTimeout(function(){ window.location.href = '/admin/login'; }, 1500);
          return null;
        }
        return res.json();
      }).then(function(data) {
        if (!data) return;
        if (data.success) {
          showToast('User deleted');
          location.reload();
        } else {
          showToast(data.error || 'Failed', 'error');
          deleteBtn.disabled = false;
        }
      }).catch(function(err) {
        showToast('Error: ' + (err.message || 'Connection failed'), 'error');
        deleteBtn.disabled = false;
      });
    });

    // Hamburger
    var hamBtn = document.getElementById('hamBtn');
    if (hamBtn) {
      hamBtn.addEventListener('click', function() {
        var sb = document.getElementById('adminSidebar');
        if (sb) sb.classList.toggle('open');
      });
    }
  </script>
</body>
</html>
