<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
  <title>Withdrawals — Admin — Growing Up</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
</head>
<body>
  <div class="admin-layout">
    <%- include('sidebar', { role, active: 'withdrawals' }) %>

    <div class="admin-content">
      <div class="admin-topbar">
        <button class="hamburger" id="hamBtn"><i class='bx bx-menu'></i></button>
        <div style="flex: 1;">
          <h1 style="margin-bottom: 2px;"><i class='bx bx-money-withdraw'></i> Withdrawal Requests</h1>
          <p style="color: var(--gray-500); font-size: 13px; margin: 0;">Review and manage withdrawal requests</p>
        </div>
      </div>

      <!-- Status Tabs -->
      <div class="status-tabs" style="display: flex; gap: 8px; margin-bottom: 24px; flex-wrap: wrap;">
        <a href="/admin/withdrawals?status=pending" class="btn <%= status === 'pending' ? 'btn-primary' : 'btn-outline' %> btn-sm">
          <i class='bx bx-time-five'></i> Pending
        </a>
        <a href="/admin/withdrawals?status=approved" class="btn <%= status === 'approved' ? 'btn-primary' : 'btn-outline' %> btn-sm">
          <i class='bx bx-check-circle'></i> Approved
        </a>
        <a href="/admin/withdrawals?status=rejected" class="btn <%= status === 'rejected' ? 'btn-primary' : 'btn-outline' %> btn-sm">
          <i class='bx bx-x-circle'></i> Rejected
        </a>
      </div>

      <% if (withdrawals.length === 0) { %>
        <div class="card" style="text-align: center; padding: 40px;">
          <i class='bx bx-check-circle' style="font-size: 48px; color: var(--gray-300);"></i>
          <p style="margin-top: 12px; color: var(--gray-500);">No <%= status %> withdrawal requests.</p>
        </div>
      <% } else { %>
        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>User</th>
                <th>Amount</th>
                <th>Method</th>
                <th>Details</th>
                <th>Fee</th>
                <th>Net</th>
                <th>Date</th>
                <% if (status === 'pending') { %><th>Actions</th><% } %>
                <% if (status === 'rejected') { %><th>Reason</th><% } %>
              </tr>
            </thead>
            <tbody>
              <% withdrawals.forEach(w => { %>
                <tr>
                  <td>
                    <strong><%= w.user ? w.user.firstName + ' ' + w.user.lastName : 'Unknown' %></strong>
                    <br><span style="font-size: 12px; color: var(--gray-500);"><%= w.user ? w.user.email : '' %></span>
                    <br><span style="font-size: 12px; color: var(--gray-500);"><%= w.user ? w.user.whatsapp : '' %></span>
                  </td>
                  <td style="font-weight: 700;">₹<%= w.amount %></td>
                  <td>
                    <span class="badge" style="background: var(--gray-100); color: var(--navy);">
                      <%= w.method === 'esewa' ? 'eSewa' : w.method === 'khalti' ? 'Khalti' : 'Bank' %>
                    </span>
                  </td>
                  <td style="font-size: 13px;">
                    <% if (w.method === 'bank') { %>
                      <strong><%= w.bankName %></strong><br>
                      <%= w.accountName %><br>
                      A/C: <%= w.accountNumber %>
                    <% } else { %>
                      <%= w.walletId %>
                    <% } %>
                  </td>
                  <td>₹<%= w.fee %></td>
                  <td style="font-weight: 600; color: var(--success);">₹<%= w.netAmount %></td>
                  <td><%= new Date(w.createdAt).toLocaleDateString() %></td>
                  <% if (status === 'pending') { %>
                    <td>
                      <div style="display: flex; gap: 6px; flex-wrap: wrap;">
                        <button class="btn btn-sm approve-withdrawal-btn" style="background: var(--success); color: white;" data-id="<%= w._id %>">
                          <i class='bx bx-check'></i> Mark as Paid
                        </button>
                        <button class="btn btn-sm reject-withdrawal-btn" style="background: var(--danger); color: white;" data-id="<%= w._id %>">
                          <i class='bx bx-x'></i> Reject
                        </button>
                      </div>
                    </td>
                  <% } %>
                  <% if (status === 'rejected') { %>
                    <td style="font-size: 13px; color: var(--danger);"><%= w.rejectionReason || '-' %></td>
                  <% } %>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>

  <div class="toast-container" id="toastContainer"></div>
  <script>
    function showToast(msg, type) {
      type = type || 'success';
      var c = document.getElementById('toastContainer');
      if (!c) return;
      var t = document.createElement('div');
      t.className = 'toast toast-' + type;
      t.innerHTML = '<i class="bx ' + (type === 'success' ? 'bx-check-circle' : 'bx-error-circle') + '"></i> ' + msg;
      c.appendChild(t);
      setTimeout(function(){ t.remove(); }, 4000);
    }

    var csrfMeta = document.querySelector('meta[name="csrf-token"]');
    var CSRF = csrfMeta ? csrfMeta.content : '';

    // Event delegation for all button clicks
    document.addEventListener('click', function(e) {
      // Approve withdrawal
      var approveBtn = e.target.closest('.approve-withdrawal-btn');
      if (approveBtn) {
        e.preventDefault();
        e.stopPropagation();
        var id = approveBtn.getAttribute('data-id');
        if (!id) return;
        if (!confirm('Mark as Paid? Make sure you have already sent the money to the user.')) return;
        approveBtn.disabled = true;
        approveBtn.innerHTML = '<span class="spinner"></span> Processing...';
        fetch('/admin/withdrawals/' + id + '/approve', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF },
          credentials: 'same-origin'
        }).then(function(res) {
          if (res.status === 401) {
            showToast('Session expired. Please login again.', 'error');
            setTimeout(function(){ window.location.href = '/admin/login'; }, 1500);
            return null;
          }
          return res.json();
        }).then(function(data) {
          if (!data) return;
          if (data.success) {
            showToast('Withdrawal approved!');
            setTimeout(function(){ location.reload(); }, 1200);
          } else {
            showToast(data.error || 'Failed', 'error');
            approveBtn.disabled = false;
            approveBtn.innerHTML = '<i class="bx bx-check"></i> Mark as Paid';
          }
        }).catch(function(err) {
          showToast('Error: ' + (err.message || 'Connection failed'), 'error');
          approveBtn.disabled = false;
          approveBtn.innerHTML = '<i class="bx bx-check"></i> Mark as Paid';
        });
        return;
      }

      // Reject withdrawal
      var rejectBtn = e.target.closest('.reject-withdrawal-btn');
      if (rejectBtn) {
        e.preventDefault();
        e.stopPropagation();
        var rid = rejectBtn.getAttribute('data-id');
        if (!rid) return;
        var reason = prompt('Rejection reason (optional):');
        if (reason === null) return;
        rejectBtn.disabled = true;
        rejectBtn.innerHTML = '<span class="spinner"></span> Processing...';
        fetch('/admin/withdrawals/' + rid + '/reject', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF },
          credentials: 'same-origin',
          body: JSON.stringify({ reason: reason })
        }).then(function(res) {
          if (res.status === 401) {
            showToast('Session expired. Please login again.', 'error');
            setTimeout(function(){ window.location.href = '/admin/login'; }, 1500);
            return null;
          }
          return res.json();
        }).then(function(data) {
          if (!data) return;
          if (data.success) {
            showToast('Withdrawal rejected.');
            setTimeout(function(){ location.reload(); }, 1200);
          } else {
            showToast(data.error || 'Failed', 'error');
            rejectBtn.disabled = false;
            rejectBtn.innerHTML = '<i class="bx bx-x"></i> Reject';
          }
        }).catch(function(err) {
          showToast('Error: ' + (err.message || 'Connection failed'), 'error');
          rejectBtn.disabled = false;
          rejectBtn.innerHTML = '<i class="bx bx-x"></i> Reject';
        });
        return;
      }
    });

    // Hamburger
    var hamBtn = document.getElementById('hamBtn');
    if (hamBtn) {
      hamBtn.addEventListener('click', function() {
        var sb = document.getElementById('adminSidebar');
        if (sb) sb.classList.toggle('open');
      });
    }
  </script>
</body>
</html>
