<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="csrf-token" content="<%= csrfToken %>">
  <title>Admin Dashboard — Growing Up</title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
</head>
<body>
  <div class="admin-layout">
    <%- include('sidebar', { role, active: 'dashboard' }) %>

    <div class="admin-content">
      <div class="admin-topbar">
        <button class="hamburger" id="hamBtn"><i class='bx bx-menu'></i></button>
        <div>
          <h1 style="margin-bottom: 2px;"><i class='bx bx-grid-alt'></i> Dashboard</h1>
          <p style="color: var(--gray-500); font-size: 13px; margin: 0;">Welcome back, Admin</p>
        </div>
      </div>

      <!-- Stats Grid -->
      <div class="admin-stats-grid">
        <div class="admin-stat-card admin-stat-blue">
          <div class="admin-stat-left">
            <div class="admin-stat-value">₹<%= totalBalance %></div>
            <div class="admin-stat-label">Platform Balance (35%)</div>
          </div>
          <div class="admin-stat-icon-bg"><i class='bx bx-wallet'></i></div>
        </div>
        <div class="admin-stat-card admin-stat-gold">
          <div class="admin-stat-left">
            <div class="admin-stat-value">₹<%= totalRevenue %></div>
            <div class="admin-stat-label">Total Revenue</div>
          </div>
          <div class="admin-stat-icon-bg"><i class='bx bx-trending-up'></i></div>
        </div>
        <div class="admin-stat-card admin-stat-green">
          <div class="admin-stat-left">
            <div class="admin-stat-value"><%= totalUsers %></div>
            <div class="admin-stat-label">Total Users</div>
          </div>
          <div class="admin-stat-icon-bg"><i class='bx bx-group'></i></div>
        </div>
        <div class="admin-stat-card admin-stat-teal">
          <div class="admin-stat-left">
            <div class="admin-stat-value"><%= activeUsers %></div>
            <div class="admin-stat-label">Active Users</div>
          </div>
          <div class="admin-stat-icon-bg"><i class='bx bx-user-check'></i></div>
        </div>
        <div class="admin-stat-card admin-stat-orange">
          <div class="admin-stat-left">
            <div class="admin-stat-value"><%= pendingPayments %></div>
            <div class="admin-stat-label">Pending Payments</div>
          </div>
          <div class="admin-stat-icon-bg"><i class='bx bx-time-five'></i></div>
        </div>
      </div>

      <!-- Quick Actions -->
      <div class="card" style="margin-top: 4px;">
        <h3 style="margin-bottom: 16px; display: flex; align-items: center; gap: 8px;">
          <i class='bx bx-zap' style="color: var(--gold);"></i> Quick Actions
        </h3>
        <div class="admin-actions-grid">
          <a href="/admin/payments?status=pending" class="admin-action-card">
            <i class='bx bx-credit-card'></i>
            <span>Review Payments</span>
            <% if (pendingPayments > 0) { %><span class="admin-action-badge"><%= pendingPayments %></span><% } %>
          </a>
          <a href="/admin/users" class="admin-action-card">
            <i class='bx bx-group'></i>
            <span>Manage Users</span>
          </a>
          <% if (role === 'superadmin') { %>
            <a href="/admin/add-user" class="admin-action-card">
              <i class='bx bx-user-plus'></i>
              <span>Add User</span>
            </a>
            <a href="/admin/settings" class="admin-action-card">
              <i class='bx bx-qr'></i>
              <span>QR Codes</span>
            </a>
            <a href="/admin/earnings" class="admin-action-card">
              <i class='bx bx-bar-chart-alt-2'></i>
              <span>Earnings</span>
            </a>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <div class="toast-container" id="toastContainer"></div>
  <script>
    document.getElementById('hamBtn').addEventListener('click', function() {
      document.getElementById('adminSidebar').classList.toggle('open');
    });
  </script>
</body>
</html>
