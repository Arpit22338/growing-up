<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
  <title>Admin Dashboard — Growing Up</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
</head>
<body>
  <div class="admin-layout">
    <%- include('sidebar', { role, active: 'dashboard' }) %>

    <div class="admin-content">
      <div class="admin-topbar">
        <button class="hamburger" id="hamBtn"><i class='bx bx-menu'></i></button>
        <div style="flex: 1;">
          <h1 style="margin-bottom: 2px;"><i class='bx bx-grid-alt'></i> Dashboard</h1>
          <p style="color: var(--gray-500); font-size: 13px; margin: 0;">Welcome back, Admin</p>
        </div>
      </div>

      <!-- Stats Grid -->
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:16px;padding:16px 0;">
        <div style="background:#fff!important;border-radius:12px!important;padding:20px!important;box-shadow:0 2px 8px rgba(0,0,0,0.08)!important;display:flex!important;flex-direction:column!important;align-items:center!important;text-align:center!important;width:auto!important;height:auto!important;">
          <i class='bx bx-wallet' style="font-size:28px;color:#D4A017;margin-bottom:8px;"></i>
          <div style="font-size:24px;font-weight:700;color:#0A1F44;">₹<%= totalBalance %></div>
          <div style="font-size:13px;color:#888;margin-top:4px;">Platform Balance (35%)</div>
        </div>
        <div style="background:#fff!important;border-radius:12px!important;padding:20px!important;box-shadow:0 2px 8px rgba(0,0,0,0.08)!important;display:flex!important;flex-direction:column!important;align-items:center!important;text-align:center!important;width:auto!important;height:auto!important;">
          <i class='bx bx-trending-up' style="font-size:28px;color:#D4A017;margin-bottom:8px;"></i>
          <div style="font-size:24px;font-weight:700;color:#0A1F44;">₹<%= totalRevenue %></div>
          <div style="font-size:13px;color:#888;margin-top:4px;">Total Revenue</div>
        </div>
        <div style="background:#fff!important;border-radius:12px!important;padding:20px!important;box-shadow:0 2px 8px rgba(0,0,0,0.08)!important;display:flex!important;flex-direction:column!important;align-items:center!important;text-align:center!important;width:auto!important;height:auto!important;">
          <i class='bx bx-group' style="font-size:28px;color:#10B981;margin-bottom:8px;"></i>
          <div style="font-size:24px;font-weight:700;color:#0A1F44;"><%= totalUsers %></div>
          <div style="font-size:13px;color:#888;margin-top:4px;">Total Users</div>
        </div>
        <div style="background:#fff!important;border-radius:12px!important;padding:20px!important;box-shadow:0 2px 8px rgba(0,0,0,0.08)!important;display:flex!important;flex-direction:column!important;align-items:center!important;text-align:center!important;width:auto!important;height:auto!important;">
          <i class='bx bx-user-check' style="font-size:28px;color:#14B8A6;margin-bottom:8px;"></i>
          <div style="font-size:24px;font-weight:700;color:#0A1F44;"><%= activeUsers %></div>
          <div style="font-size:13px;color:#888;margin-top:4px;">Active Users</div>
        </div>
        <div style="background:#fff!important;border-radius:12px!important;padding:20px!important;box-shadow:0 2px 8px rgba(0,0,0,0.08)!important;display:flex!important;flex-direction:column!important;align-items:center!important;text-align:center!important;width:auto!important;height:auto!important;">
          <i class='bx bx-time-five' style="font-size:28px;color:#F59E0B;margin-bottom:8px;"></i>
          <div style="font-size:24px;font-weight:700;color:#0A1F44;"><%= pendingPayments %></div>
          <div style="font-size:13px;color:#888;margin-top:4px;">Pending Payments</div>
        </div>
        <div style="background:#fff!important;border-radius:12px!important;padding:20px!important;box-shadow:0 2px 8px rgba(0,0,0,0.08)!important;display:flex!important;flex-direction:column!important;align-items:center!important;text-align:center!important;width:auto!important;height:auto!important;">
          <i class='bx bx-money-withdraw' style="font-size:28px;color:#8B5CF6;margin-bottom:8px;"></i>
          <div style="font-size:24px;font-weight:700;color:#0A1F44;"><%= typeof pendingWithdrawals !== 'undefined' ? pendingWithdrawals : 0 %></div>
          <div style="font-size:13px;color:#888;margin-top:4px;">Pending Withdrawals</div>
        </div>
      </div>

      <!-- Quick Actions -->
      <div class="card" style="margin-top: 4px;">
        <h3 style="margin-bottom: 16px; display: flex; align-items: center; gap: 8px;">
          <i class='bx bx-zap' style="color: var(--gold);"></i> Quick Actions
        </h3>
        <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin-top:16px;">
          <a href="/admin/payments?status=pending" style="display:flex;align-items:center;gap:8px;padding:14px;background:#fff;border-radius:10px;box-shadow:0 2px 6px rgba(0,0,0,0.08);text-decoration:none;color:#0A1F44;font-weight:600;font-size:14px;">
            <i class='bx bx-credit-card' style="color:#D4A017;font-size:20px;"></i>
            Review Payments
            <% if (pendingPayments > 0) { %><span style="background:#F59E0B;color:#fff;font-size:11px;padding:2px 8px;border-radius:12px;margin-left:auto;"><%= pendingPayments %></span><% } %>
          </a>
          <a href="/admin/users" style="display:flex;align-items:center;gap:8px;padding:14px;background:#fff;border-radius:10px;box-shadow:0 2px 6px rgba(0,0,0,0.08);text-decoration:none;color:#0A1F44;font-weight:600;font-size:14px;">
            <i class='bx bx-group' style="color:#D4A017;font-size:20px;"></i>
            Manage Users
          </a>
          <a href="/admin/withdrawals?status=pending" style="display:flex;align-items:center;gap:8px;padding:14px;background:#fff;border-radius:10px;box-shadow:0 2px 6px rgba(0,0,0,0.08);text-decoration:none;color:#0A1F44;font-weight:600;font-size:14px;">
            <i class='bx bx-money-withdraw' style="color:#D4A017;font-size:20px;"></i>
            Withdrawals
            <% if (typeof pendingWithdrawals !== 'undefined' && pendingWithdrawals > 0) { %><span style="background:#F59E0B;color:#fff;font-size:11px;padding:2px 8px;border-radius:12px;margin-left:auto;"><%= pendingWithdrawals %></span><% } %>
          </a>
          <a href="/admin/add-user" style="display:flex;align-items:center;gap:8px;padding:14px;background:#fff;border-radius:10px;box-shadow:0 2px 6px rgba(0,0,0,0.08);text-decoration:none;color:#0A1F44;font-weight:600;font-size:14px;">
            <i class='bx bx-user-plus' style="color:#D4A017;font-size:20px;"></i>
            Add User
          </a>
          <a href="/admin/earnings" style="display:flex;align-items:center;gap:8px;padding:14px;background:#fff;border-radius:10px;box-shadow:0 2px 6px rgba(0,0,0,0.08);text-decoration:none;color:#0A1F44;font-weight:600;font-size:14px;">
            <i class='bx bx-bar-chart-alt-2' style="color:#D4A017;font-size:20px;"></i>
            Earnings
          </a>
          <a href="/admin/referral-tree" style="display:flex;align-items:center;gap:8px;padding:14px;background:#fff;border-radius:10px;box-shadow:0 2px 6px rgba(0,0,0,0.08);text-decoration:none;color:#0A1F44;font-weight:600;font-size:14px;">
            <i class='bx bx-git-branch' style="color:#D4A017;font-size:20px;"></i>
            Referral Tree
          </a>
        </div>
      </div>

      <% if (role === 'superadmin') { %>
      <!-- Danger Zone -->
      <div class="card" style="margin-top: 20px; border: 2px solid var(--danger); border-radius: 12px;">
        <h3 style="margin-bottom: 8px; display: flex; align-items: center; gap: 8px; color: var(--danger);">
          <i class='bx bx-error-circle'></i> Danger Zone
        </h3>
        <p style="color: var(--gray-500); font-size: 13px; margin-bottom: 16px;">
          This will permanently delete <strong>all payments</strong>, reset <strong>all user earnings to ₹0</strong>, deactivate all users, and clear purchased courses. This action <strong>cannot be undone</strong>.
        </p>
        <button class="btn btn-danger" id="resetBtn">
          <i class='bx bx-reset'></i> Reset Everything to Zero
        </button>
      </div>
      <% } %>
    </div>
  </div>

  <div class="toast-container" id="toastContainer"></div>
  <script>
    function showToast(msg, type) {
      type = type || 'success';
      var c = document.getElementById('toastContainer');
      var t = document.createElement('div');
      t.className = 'toast toast-' + type;
      t.innerHTML = '<i class="bx ' + (type === 'success' ? 'bx-check-circle' : 'bx-error-circle') + '"></i> ' + msg;
      c.appendChild(t);
      setTimeout(function(){ t.remove(); }, 4000);
    }

    var csrfMeta = document.querySelector('meta[name="csrf-token"]');
    var CSRF = csrfMeta ? csrfMeta.content : '';

    // Reset button — event listener
    var resetBtn = document.getElementById('resetBtn');
    if (resetBtn) {
      resetBtn.addEventListener('click', function() {
        var c1 = confirm('⚠️ WARNING: This will delete ALL payments, reset all earnings to ₹0, deactivate all users, and clear purchased courses.\n\nAre you absolutely sure?');
        if (!c1) return;
        var c2 = prompt('Type "RESET" to confirm:');
        if (c2 !== 'RESET') {
          showToast('Reset cancelled — you must type RESET exactly.', 'error');
          return;
        }
        resetBtn.disabled = true;
        resetBtn.innerHTML = '<i class="bx bx-loader-alt bx-spin"></i> Resetting...';
        fetch('/admin/reset-everything', {
          method: 'POST',
          headers: { 'X-CSRF-Token': CSRF },
          credentials: 'same-origin'
        }).then(function(res) {
          if (res.status === 401) {
            showToast('Session expired. Please login again.', 'error');
            setTimeout(function(){ window.location.href = '/admin/login'; }, 1500);
            return null;
          }
          return res.json();
        }).then(function(data) {
          if (!data) return;
          if (data.success) {
            showToast('Everything has been reset to zero!');
            setTimeout(function(){ location.reload(); }, 1500);
          } else {
            showToast(data.error || 'Reset failed', 'error');
            resetBtn.disabled = false;
            resetBtn.innerHTML = '<i class="bx bx-reset"></i> Reset Everything to Zero';
          }
        }).catch(function(err) {
          showToast('Error: ' + (err.message || 'Connection failed'), 'error');
          resetBtn.disabled = false;
          resetBtn.innerHTML = '<i class="bx bx-reset"></i> Reset Everything to Zero';
        });
      });
    }

    // Hamburger
    var hamBtn = document.getElementById('hamBtn');
    if (hamBtn) {
      hamBtn.addEventListener('click', function() {
        var sb = document.getElementById('adminSidebar');
        if (sb) sb.classList.toggle('open');
      });
    }
  </script>
</body>
</html>
