<%- include('partials/header') %>

<style>
  .profile-wrap { max-width: 800px; margin: 0 auto; padding: 24px 16px 48px; }
  .profile-card {
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 2px 12px rgba(10,31,68,0.08);
    overflow: hidden;
    margin-bottom: 20px;
  }
  .profile-cover {
    height: 120px;
    background: linear-gradient(135deg, #0A1F44 0%, #3B82F6 100%);
    position: relative;
  }
  .profile-avatar-wrap {
    display: flex;
    align-items: flex-end;
    gap: 20px;
    padding: 0 24px;
    margin-top: -50px;
    flex-wrap: wrap;
  }
  .profile-avatar {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: linear-gradient(135deg, #D4A017, #B8860B);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 38px;
    font-weight: 700;
    border: 4px solid #fff;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
    overflow: hidden;
    flex-shrink: 0;
  }
  .profile-avatar img { width: 100%; height: 100%; object-fit: cover; }
  .profile-id { padding-bottom: 16px; flex: 1; min-width: 200px; }
  .profile-id h1 { margin: 0; font-size: 24px; color: #0A1F44; font-weight: 700; }
  .profile-id .role-badge {
    display: inline-block;
    margin-top: 4px;
    padding: 3px 12px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .role-badge.superadmin { background: #0A1F44; color: #D4A017; }
  .role-badge.financial_secretary { background: #0E7C66; color: #fff; }
  .role-badge.user { background: #E0E7FF; color: #3730A3; }
  .profile-id .status {
    display: inline-block;
    margin-left: 8px;
    padding: 3px 10px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 600;
  }
  .status.active { background: #D4EDDA; color: #155724; }
  .status.inactive { background: #FFF3CD; color: #856404; }
  .info-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: #f0f0f0;
    border-top: 1px solid #f0f0f0;
  }
  @media (max-width: 600px) { .info-grid { grid-template-columns: 1fr; } }
  .info-cell {
    background: #fff;
    padding: 16px 24px;
  }
  .info-cell .label {
    font-size: 11px;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: 600;
    margin-bottom: 4px;
  }
  .info-cell .value {
    font-size: 15px;
    color: #0A1F44;
    font-weight: 500;
    word-break: break-word;
  }
  .info-cell .value.muted { color: #888; font-style: italic; font-family: monospace; font-size: 12px; }
  .actions { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 8px; }
  .btn-row {
    flex: 1;
    min-width: 180px;
    padding: 14px 20px;
    border-radius: 10px;
    text-decoration: none;
    text-align: center;
    font-weight: 600;
    font-size: 14px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }
  .btn-primary { background: #0A1F44; color: #fff; }
  .btn-outline { background: #fff; color: #0A1F44; border: 2px solid #0A1F44; }
  .btn-gold { background: #D4A017; color: #0A1F44; }
  .hint-banner {
    background: #FFF8E1;
    border-left: 4px solid #D4A017;
    border-radius: 8px;
    padding: 14px 18px;
    margin-bottom: 20px;
    color: #5C4813;
    font-size: 14px;
    line-height: 1.5;
  }
  .hint-banner i { color: #D4A017; margin-right: 6px; }
  .hint-banner a { color: #0A1F44; font-weight: 700; text-decoration: underline; }
</style>

<div class="profile-wrap">
  <a href="/dashboard" style="display:inline-flex;align-items:center;gap:6px;color:#888;font-size:14px;text-decoration:none;margin-bottom:16px;">
    <i class='bx bx-arrow-back'></i> Back to Dashboard
  </a>

  <% if (user.role === 'user') { %>
    <div class="hint-banner">
      <i class='bx bx-info-circle'></i>
      Want to update your WhatsApp number or change your password?
      <a href="/settings">Go to Settings →</a>
    </div>
  <% } %>

  <!-- Profile Card -->
  <div class="profile-card">
    <div class="profile-cover"></div>
    <div class="profile-avatar-wrap">
      <div class="profile-avatar">
        <% if (user.profilePicture) { %>
          <img src="<%= user.profilePicture %>" alt="<%= user.firstName %>">
        <% } else { %>
          <%= user.firstName.charAt(0).toUpperCase() %>
        <% } %>
      </div>
      <div class="profile-id">
        <h1><%= user.fullName %></h1>
        <div style="margin-top:6px;">
          <% if (user.role === 'superadmin') { %>
            <span class="role-badge superadmin">Super Admin</span>
          <% } else if (user.role === 'financial_secretary') { %>
            <span class="role-badge financial_secretary">Financial Secretary</span>
          <% } else { %>
            <span class="role-badge user">User</span>
          <% } %>
          <% if (user.role === 'user') { %>
            <span class="status <%= user.isActive ? 'active' : 'inactive' %>">
              <%= user.isActive ? '✓ Active' : '⏳ Pending Approval' %>
            </span>
          <% } %>
        </div>
      </div>
    </div>

    <div class="info-grid">
      <div class="info-cell">
        <div class="label">Email</div>
        <div class="value"><%= user.email %></div>
      </div>
      <div class="info-cell">
        <div class="label">WhatsApp Number</div>
        <div class="value">+977 <%= user.whatsapp %></div>
      </div>
      <div class="info-cell">
        <div class="label">Gender</div>
        <div class="value"><%= user.gender === 'M' ? 'Male' : user.gender === 'F' ? 'Female' : 'Not specified' %></div>
      </div>
      <div class="info-cell">
        <div class="label">Member Since</div>
        <div class="value"><%= new Date(user.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></div>
      </div>
      <% if (user.middleName) { %>
      <div class="info-cell">
        <div class="label">Middle Name</div>
        <div class="value"><%= user.middleName %></div>
      </div>
      <% } %>
      <div class="info-cell">
        <div class="label">Account ID</div>
        <div class="value muted"><%= user._id %></div>
      </div>
    </div>
  </div>

  <!-- Actions -->
  <div class="actions">
    <% if (user.role === 'user') { %>
      <a href="/dashboard" class="btn-row btn-primary"><i class='bx bx-grid-alt'></i> Dashboard</a>
      <a href="/settings" class="btn-row btn-outline"><i class='bx bx-cog'></i> Settings</a>
    <% } else { %>
      <a href="/admin" class="btn-row btn-primary"><i class='bx bx-shield'></i> Admin Panel</a>
      <a href="/dashboard" class="btn-row btn-outline"><i class='bx bx-grid-alt'></i> Dashboard</a>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>
