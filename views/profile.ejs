<%- include('partials/header') %>

<style>
  /* ── Layout ── */
  .profile-wrap {
    max-width: 880px;
    margin: 0 auto;
    padding: 16px 16px 64px;
    font-family: 'Poppins', sans-serif;
  }
  .back-link {
    display: inline-flex; align-items: center; gap: 6px;
    color: #64748B; font-size: 14px; text-decoration: none;
    margin-bottom: 16px; font-weight: 500;
  }
  .back-link:hover { color: #0A1F44; }

  /* ── Hero ── */
  .pfp-hero {
    background: linear-gradient(135deg, #0A1F44 0%, #1E3A8A 60%, #3B82F6 100%);
    border-radius: 18px;
    padding: 28px 20px 20px;
    color: #fff;
    box-shadow: 0 4px 20px rgba(10,31,68,0.18);
    margin-bottom: 20px;
  }
  .pfp-hero-row {
    display: flex; align-items: center; gap: 20px; flex-wrap: wrap;
  }
  .pfp-avatar {
    width: 110px; height: 110px;
    border-radius: 50%;
    background: linear-gradient(135deg, #D4A017, #B8860B);
    color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-size: 44px; font-weight: 800;
    border: 5px solid #fff;
    box-shadow: 0 4px 14px rgba(0,0,0,0.25);
    overflow: hidden;
    flex-shrink: 0;
    position: relative;
  }
  .pfp-avatar img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }
  .pfp-name { font-size: 26px; font-weight: 700; margin: 0 0 8px; line-height: 1.1; }
  .pfp-badges { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 10px; }
  .pfp-badge {
    display: inline-block; padding: 4px 12px; border-radius: 20px;
    font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;
  }
  .pfp-badge.superadmin { background: #D4A017; color: #0A1F44; }
  .pfp-badge.financial_secretary { background: #10B981; color: #fff; }
  .pfp-badge.user { background: rgba(255,255,255,0.2); color: #fff; border: 1px solid rgba(255,255,255,0.3); }
  .pfp-badge.status-active { background: #10B981; color: #fff; }
  .pfp-badge.status-inactive { background: #F59E0B; color: #0A1F44; }
  .pfp-actions { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 4px; }
  .pfp-btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 8px 14px; border-radius: 8px;
    font-size: 13px; font-weight: 600;
    text-decoration: none; cursor: pointer;
    border: none; font-family: 'Poppins', sans-serif;
    transition: transform 0.05s, opacity 0.15s;
  }
  .pfp-btn:active { transform: scale(0.97); }
  .pfp-btn.gold { background: #D4A017; color: #0A1F44; }
  .pfp-btn.gold:hover { background: #E5B22A; }
  .pfp-btn.outline { background: rgba(255,255,255,0.15); color: #fff; border: 1px solid rgba(255,255,255,0.3); }
  .pfp-btn.outline:hover { background: rgba(255,255,255,0.25); }

  /* ── Cards ── */
  .card {
    background: #fff;
    border-radius: 14px;
    box-shadow: 0 2px 10px rgba(10,31,68,0.06);
    border: 1px solid #EEF2F7;
    padding: 22px;
    margin-bottom: 16px;
  }
  .card-title {
    color: #0A1F44;
    font-size: 17px;
    font-weight: 700;
    margin: 0 0 14px;
    display: flex; align-items: center; gap: 8px;
  }
  .card-title i { color: #D4A017; font-size: 20px; }

  /* ── Info grid (personal info) ── */
  .info-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: #F1F5F9;
    border-radius: 10px;
    overflow: hidden;
  }
  .info-cell { background: #fff; padding: 14px 18px; }
  .info-cell .lbl {
    font-size: 11px; color: #94A3B8;
    text-transform: uppercase; letter-spacing: 0.5px;
    font-weight: 600; margin-bottom: 4px;
  }
  .info-cell .val { font-size: 15px; color: #0A1F44; font-weight: 500; word-break: break-word; }
  .info-cell .val.mono { font-family: monospace; font-size: 12px; color: #64748B; }

  /* ── Referral card ── */
  .ref-code-row {
    display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
    background: #FFF8E1;
    border: 2px dashed #D4A017;
    border-radius: 12px;
    padding: 14px 18px;
    margin-bottom: 12px;
  }
  .ref-code-text {
    font-size: 22px; font-weight: 800; color: #0A1F44;
    letter-spacing: 1.5px; flex: 1; min-width: 140px;
    font-family: 'Poppins', monospace;
  }
  .ref-link-row {
    display: flex; gap: 8px; align-items: center;
    background: #F8FAFC; border: 1px solid #E2E8F0;
    border-radius: 10px; padding: 8px 10px;
  }
  .ref-link-input {
    flex: 1; background: transparent; border: none;
    font-family: monospace; font-size: 13px; color: #475569;
    outline: none; min-width: 0;
  }
  .ref-stats {
    display: grid; grid-template-columns: repeat(2, 1fr);
    gap: 12px; margin-top: 14px;
  }
  .ref-stat {
    background: #F8FAFC; border-radius: 10px; padding: 12px 14px;
    text-align: center;
  }
  .ref-stat .n { font-size: 22px; font-weight: 800; color: #0A1F44; }
  .ref-stat .l { font-size: 12px; color: #64748B; margin-top: 2px; }
  .copy-btn {
    background: #0A1F44; color: #fff; border: none;
    padding: 8px 14px; border-radius: 8px;
    font-size: 12px; font-weight: 700; cursor: pointer;
    font-family: 'Poppins', sans-serif;
    display: inline-flex; align-items: center; gap: 4px;
  }
  .copy-btn:hover { background: #1A3360; }

  /* ── Course list ── */
  .course-row {
    display: flex; align-items: center; gap: 14px;
    padding: 14px 16px;
    background: #F8FAFC; border-radius: 10px;
    margin-bottom: 10px;
    flex-wrap: wrap;
  }
  .course-row:last-child { margin-bottom: 0; }
  .course-row .ico {
    width: 42px; height: 42px; border-radius: 10px;
    background: linear-gradient(135deg, #0A1F44, #3B82F6);
    color: #fff; display: flex; align-items: center; justify-content: center;
    font-size: 20px; flex-shrink: 0;
  }
  .course-row .body { flex: 1; min-width: 160px; }
  .course-row .name { font-weight: 700; color: #0A1F44; font-size: 15px; }
  .course-row .meta { color: #64748B; font-size: 13px; margin-top: 4px; }
  .course-row .progress { display: flex; align-items: center; gap: 8px; margin-top: 6px; }
  .course-row .progress-bar { flex: 1; min-width: 80px; height: 6px; background: #E2E8F0; border-radius: 999px; overflow: hidden; }
  .course-row .progress-fill { height: 100%; background: linear-gradient(90deg, #D4A017, #10B981); border-radius: 999px; transition: width 0.4s ease; }
  .course-row .progress-label { font-size: 11px; color: #64748B; font-weight: 600; min-width: 56px; text-align: right; }
  .course-row .progress-label.complete { color: #065F46; }
  .course-row .actions { display: flex; gap: 8px; flex-wrap: wrap; }
  .row-btn {
    padding: 8px 14px; border-radius: 8px;
    font-size: 13px; font-weight: 600;
    text-decoration: none; cursor: pointer;
    display: inline-flex; align-items: center; gap: 4px;
    border: none; font-family: 'Poppins', sans-serif;
  }
  .row-btn.primary { background: #0A1F44; color: #fff; }
  .row-btn.primary:hover { background: #1A3360; }
  .row-btn.gold { background: #D4A017; color: #0A1F44; }
  .row-btn.gold:hover { background: #E5B22A; }
  .row-btn.outline { background: #fff; color: #0A1F44; border: 1.5px solid #CBD5E1; }
  .row-btn.outline:hover { border-color: #0A1F44; }
  .badge {
    padding: 3px 10px; border-radius: 20px;
    font-size: 11px; font-weight: 700; text-transform: uppercase;
  }
  .badge-pending { background: #FEF3C7; color: #92400E; }
  .badge-approved { background: #D1FAE5; color: #065F46; }
  .badge-rejected { background: #FEE2E2; color: #991B1B; }
  .empty-msg { text-align: center; color: #94A3B8; padding: 20px; font-size: 14px; }

  /* ── Toast ── */
  #toast {
    position: fixed; top: 80px; left: 50%;
    transform: translateX(-50%) translateY(-20px);
    background: #0A1F44; color: #fff;
    padding: 12px 24px; border-radius: 10px;
    font-size: 14px; font-weight: 600;
    z-index: 9999; opacity: 0; pointer-events: none;
    transition: opacity 0.2s, transform 0.2s;
    box-shadow: 0 4px 16px rgba(0,0,0,0.2);
    max-width: 90%; text-align: center;
  }
  #toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
  #toast.success { background: #10B981; }
  #toast.error { background: #DC2626; }

  /* ── Responsive ── */
  @media (max-width: 600px) {
    .pfp-hero { padding: 22px 16px 18px; }
    .pfp-hero-row { gap: 14px; }
    .pfp-avatar { width: 90px; height: 90px; font-size: 36px; border-width: 4px; }
    .pfp-name { font-size: 22px; }
    .info-grid { grid-template-columns: 1fr; }
    .ref-code-text { font-size: 18px; letter-spacing: 1px; }
    .ref-stats { grid-template-columns: 1fr; }
    .card { padding: 18px 16px; }
    .course-row { padding: 12px; }
    .course-row .actions { width: 100%; }
    .row-btn { flex: 1; justify-content: center; min-width: 0; }
  }
</style>

<div class="profile-wrap">
  <a href="/dashboard" class="back-link"><i class='bx bx-arrow-back'></i> Back to Dashboard</a>

  <!-- Hero -->
  <div class="pfp-hero">
    <div class="pfp-hero-row">
      <div class="pfp-avatar" id="profileAvatar">
        <% if (user.profilePicture) { %>
          <img src="<%= user.profilePicture %>" alt="<%= user.fullName %>" onerror="this.style.display='none'; this.parentElement.insertAdjacentHTML('beforeend', '<span><%= user.firstName.charAt(0).toUpperCase() %></span>');">
        <% } else { %>
          <span><%= user.firstName.charAt(0).toUpperCase() %></span>
        <% } %>
      </div>
      <div style="flex:1; min-width: 180px;">
        <h1 class="pfp-name"><%= user.fullName %></h1>
        <div class="pfp-badges">
          <% if (user.role === 'superadmin') { %>
            <span class="pfp-badge superadmin"><i class='bx bx-shield'></i> Super Admin</span>
          <% } else if (user.role === 'financial_secretary') { %>
            <span class="pfp-badge financial_secretary"><i class='bx bx-wallet'></i> Financial Secretary</span>
          <% } else { %>
            <span class="pfp-badge user"><i class='bx bx-user'></i> Member</span>
          <% } %>
          <% if (user.role === 'user') { %>
            <span class="pfp-badge status-<%= user.isActive ? 'active' : 'inactive' %>">
              <%= user.isActive ? '✓ Active' : '⏳ Pending' %>
            </span>
          <% } %>
        </div>
        <div class="pfp-actions">
          <a href="/settings" class="pfp-btn gold"><i class='bx bx-camera'></i> Change Photo</a>
          <a href="/settings" class="pfp-btn outline"><i class='bx bx-cog'></i> Settings</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Personal Info -->
  <div class="card">
    <h2 class="card-title"><i class='bx bx-id-card'></i> Personal Information</h2>
    <div class="info-grid">
      <div class="info-cell">
        <div class="lbl">Email</div>
        <div class="val"><%= user.email %></div>
      </div>
      <div class="info-cell">
        <div class="lbl">WhatsApp</div>
        <div class="val">+977 <%= user.whatsapp %></div>
      </div>
      <div class="info-cell">
        <div class="lbl">Gender</div>
        <div class="val"><%= user.gender === 'M' ? 'Male' : 'Female' %></div>
      </div>
      <div class="info-cell">
        <div class="lbl">Member Since</div>
        <div class="val"><%= new Date(user.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %></div>
      </div>
      <% if (user.middleName) { %>
      <div class="info-cell">
        <div class="lbl">Middle Name</div>
        <div class="val"><%= user.middleName %></div>
      </div>
      <% } %>
      <div class="info-cell">
        <div class="lbl">Account ID</div>
        <div class="val mono"><%= user._id %></div>
      </div>
    </div>
    <% if (user.referredBy) { %>
      <div style="margin-top:14px;padding-top:14px;border-top:1px solid #F1F5F9;font-size:13px;color:#64748B;">
        <i class='bx bx-user-plus' style="color:#D4A017;"></i>
        Referred by <strong style="color:#0A1F44;"><%= user.referredBy.firstName %> <%= user.referredBy.lastName %></strong>
        <span style="color:#94A3B8;">(<%= user.referredBy.referralCode %>)</span>
      </div>
    <% } %>
  </div>

    <!-- Referral -->
    <div class="card">
      <h2 class="card-title"><i class='bx bx-link'></i> Your Referral</h2>

      <div class="ref-code-row">
        <div class="ref-code-text" id="refCodeText"><%= user.referralCode %></div>
        <button type="button" class="copy-btn" data-copy-text="<%= user.referralCode %>">
          <i class='bx bx-copy'></i> Copy Code
        </button>
      </div>

      <div class="ref-link-row">
        <input type="text" class="ref-link-input" id="refLinkInput" readonly value="<%= baseUrl %>/register?ref=<%= user.referralCode %>" onclick="this.select()">
        <button type="button" class="copy-btn" data-copy-text="<%= baseUrl %>/register?ref=<%= user.referralCode %>">
          <i class='bx bx-copy'></i> Copy Link
        </button>
      </div>

    <div class="ref-stats">
      <div class="ref-stat">
        <div class="n"><%= (user.referredUsers && user.referredUsers.length) || 0 %></div>
        <div class="l">People Referred</div>
      </div>
      <div class="ref-stat">
        <div class="n" style="color:#10B981;">₹<%= user.totalEarnings || 0 %></div>
        <div class="l">Total Earned</div>
      </div>
    </div>
  </div>

  <!-- Courses + Certificates -->
  <div class="card">
    <h2 class="card-title"><i class='bx bx-book-open'></i> My Courses &amp; Certificates</h2>
    <% if (user.purchasedCourses && user.purchasedCourses.length > 0) { %>
      <% user.purchasedCourses.forEach(function(course) {
           const progress = (typeof courseProgress !== 'undefined' && courseProgress[course.courseKey]) || { moduleCount: 0, completedCount: 0, allComplete: false };
           const pct = progress.moduleCount > 0 ? (progress.completedCount / progress.moduleCount * 100) : 0;
      %>
        <div class="course-row">
          <div class="ico"><i class='bx bx-book'></i></div>
          <div class="body">
            <div class="name"><%= course.courseName || course.courseKey %></div>
            <div class="meta">
              ₹<%= course.price %> &middot;
              <%= new Date(course.purchasedAt).toLocaleDateString() %>
              &middot;
              <span class="badge badge-<%= course.status %>"><%= course.status %></span>
              <% if (course.status === 'approved' && progress.moduleCount > 0) { %>
                &middot; <%= progress.completedCount %> / <%= progress.moduleCount %> modules
              <% } %>
            </div>
            <% if (course.status === 'approved' && progress.moduleCount > 0) { %>
              <div class="progress">
                <div class="progress-bar"><div class="progress-fill" style="width: <%= pct %>%"></div></div>
                <div class="progress-label <%= progress.allComplete ? 'complete' : '' %>">
                  <% if (progress.allComplete) { %><i class='bx bx-check-circle'></i> Complete<% } else { %><%= Math.round(pct) %>%<% } %>
                </div>
              </div>
            <% } %>
          </div>
          <div class="actions">
            <% if (course.status === 'approved') { %>
              <a href="/course/<%= course.courseKey %>/read" class="row-btn primary"><i class='bx bx-book-open'></i> <%= progress.allComplete ? 'Review' : (progress.completedCount > 0 ? 'Continue' : 'Open') %></a>
              <% if (progress.allComplete) { %>
                <a href="/certificate/<%= course.courseKey %>" class="row-btn gold" target="_blank"><i class='bx bx-certification'></i> Certificate</a>
              <% } else { %>
                <span class="row-btn outline" style="opacity:0.55;cursor:not-allowed;" title="Finish all <%= progress.moduleCount %> modules to unlock"><i class='bx bx-lock-alt'></i> Certificate</span>
              <% } %>
            <% } else if (course.status === 'pending') { %>
              <span class="row-btn outline" style="opacity:0.6;cursor:default;">Awaiting Approval</span>
            <% } else if (course.status === 'rejected') { %>
              <span class="row-btn outline" style="opacity:0.6;cursor:default;color:#991B1B;">Rejected</span>
            <% } %>
          </div>
        </div>
      <% }); %>
    <% } else { %>
      <div class="empty-msg">
        <i class='bx bx-cart' style="font-size:32px;display:block;margin-bottom:8px;"></i>
        No courses yet. <a href="/#courses" style="color:#D4A017;font-weight:700;">Browse courses →</a>
      </div>
    <% } %>
  </div>

  <!-- Action buttons -->
  <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:8px;">
    <% if (user.role === 'user') { %>
      <a href="/dashboard" class="row-btn primary" style="flex:1;min-width:140px;padding:14px;justify-content:center;"><i class='bx bx-grid-alt'></i> Dashboard</a>
      <a href="/settings" class="row-btn outline" style="flex:1;min-width:140px;padding:14px;justify-content:center;"><i class='bx bx-cog'></i> Settings</a>
    <% } else { %>
      <a href="/admin" class="row-btn primary" style="flex:1;min-width:140px;padding:14px;justify-content:center;"><i class='bx bx-shield'></i> Admin Panel</a>
      <a href="/dashboard" class="row-btn outline" style="flex:1;min-width:140px;padding:14px;justify-content:center;"><i class='bx bx-grid-alt'></i> Dashboard</a>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>
