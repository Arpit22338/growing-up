<%- include('partials/header') %>

<div class="container" style="max-width: 640px; padding-top: 32px; padding-bottom: 48px;">
  <!-- Back to Dashboard -->
  <a href="/dashboard" style="display: inline-flex; align-items: center; gap: 6px; color: var(--gray-500); font-size: 14px; text-decoration: none; margin-bottom: 20px;">
    <i class='bx bx-arrow-back'></i> Back to Dashboard
  </a>

  <h2 style="color: var(--navy); margin-bottom: 24px; display: flex; align-items: center; gap: 10px;">
    <i class='bx bx-wallet' style="color: var(--gold);"></i> My Wallet
  </h2>

  <!-- Wallet Balance Card -->
  <div class="card" style="text-align: center; padding: 40px 24px; margin-bottom: 24px; background: linear-gradient(135deg, #0A1F44, #163265); color: var(--white); border: none;">
    <i class='bx bx-wallet' style="font-size: 48px; color: var(--gold); margin-bottom: 12px;"></i>
    <div style="font-size: 42px; font-weight: 800; color: var(--white); margin-bottom: 4px;">₹<%= availableBalance %></div>
    <div style="font-size: 14px; color: rgba(255,255,255,0.7);">Available Balance</div>
  </div>

  <!-- Withdraw Button -->
  <% if (availableBalance >= 400) { %>
    <button type="button" onclick="document.getElementById('wModal').style.display='flex'" style="width:100%;padding:16px;background:#27AE60;color:#fff;border:none;border-radius:10px;font-size:16px;font-weight:700;cursor:pointer;margin:16px 0;">
      Request Withdrawal
    </button>
  <% } else { %>
    <button disabled style="width:100%;padding:16px;background:#ccc;color:#888;border:none;border-radius:10px;font-size:16px;font-weight:700;cursor:not-allowed;margin:16px 0;">
      Minimum ₹400 required to withdraw
    </button>
  <% } %>

  <!-- Withdrawal History -->
  <div class="card" style="padding: 24px;">
    <h3 style="color: var(--navy); margin-bottom: 16px; display: flex; align-items: center; gap: 8px;">
      <i class='bx bx-history' style="color: var(--gold);"></i> Withdrawal History
    </h3>

    <% if (withdrawals.length > 0) { %>
      <!-- Mobile-friendly table -->
      <div class="table-container">
        <table>
          <thead>
            <tr>
              <th>Amount</th>
              <th>Platform</th>
              <th>Phone/Account</th>
              <th>Status</th>
              <th>Date</th>
            </tr>
          </thead>
          <tbody>
            <% withdrawals.forEach(w => { %>
              <tr>
                <td style="font-weight: 700;">₹<%= w.amount %><% if (w.fee > 0) { %><br><span style="font-size:11px;color:var(--gray-500);">Fee: ₹<%= w.fee %></span><% } %></td>
                <td><%= w.method === 'esewa' ? 'eSewa' : w.method === 'khalti' ? 'Khalti' : 'Bank' %></td>
                <td style="font-size: 13px;">
                  <% if (w.method === 'bank') { %>
                    <%= w.accountName %><br>
                    <span style="color:var(--gray-500);"><%= w.bankName %> · <%= w.accountNumber %></span>
                  <% } else { %>
                    <%= w.walletId %>
                  <% } %>
                </td>
                <td>
                  <span class="badge badge-<%= w.status %>"><%= w.status.charAt(0).toUpperCase() + w.status.slice(1) %></span>
                  <% if (w.status === 'rejected' && w.rejectionReason) { %>
                    <br><span style="font-size:11px;color:var(--danger);"><%= w.rejectionReason %></span>
                  <% } %>
                </td>
                <td style="font-size: 13px; color: var(--gray-500);"><%= new Date(w.createdAt).toLocaleDateString() %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div style="text-align: center; padding: 32px 16px; color: var(--gray-400);">
        <i class='bx bx-receipt' style="font-size: 40px; margin-bottom: 8px;"></i>
        <p>No withdrawal history yet.</p>
      </div>
    <% } %>
  </div>
</div>

<!-- Withdrawal Modal -->
<div id="wModal" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.6);z-index:99999;align-items:center;justify-content:center;">
  <div style="background:#fff;border-radius:16px;padding:28px;width:90%;max-width:420px;position:relative;max-height:90vh;overflow-y:auto;">
    <button type="button" onclick="document.getElementById('wModal').style.display='none'" style="position:absolute;top:14px;right:18px;background:none;border:none;font-size:24px;cursor:pointer;color:#333;">✕</button>
    <h3 style="margin:0 0 20px;color:#0A1F44;">Request Withdrawal</h3>
    <div style="display:flex;gap:10px;margin-bottom:16px;">
      <button type="button" id="eBtn" onclick="selP('esewa')" style="flex:1;padding:12px;border:2px solid #ddd;border-radius:8px;cursor:pointer;font-weight:700;background:#fff;">eSewa</button>
      <button type="button" id="kBtn" onclick="selP('khalti')" style="flex:1;padding:12px;border:2px solid #ddd;border-radius:8px;cursor:pointer;font-weight:700;background:#fff;">Khalti</button>
    </div>
    <input type="hidden" id="wP"/>
    <input type="text" id="wN" placeholder="Account Holder Name" style="width:100%;padding:13px;border:1.5px solid #ddd;border-radius:8px;font-size:15px;margin-bottom:12px;box-sizing:border-box;"/>
    <input type="tel" id="wPh" placeholder="Phone Number" style="width:100%;padding:13px;border:1.5px solid #ddd;border-radius:8px;font-size:15px;margin-bottom:12px;box-sizing:border-box;"/>
    <input type="number" id="wAmt" placeholder="Amount (min ₹400)" min="400" style="width:100%;padding:13px;border:1.5px solid #ddd;border-radius:8px;font-size:15px;margin-bottom:6px;box-sizing:border-box;"/>
    <p style="color:#888;font-size:13px;margin:0 0 16px;">Min ₹400 | Available: ₹<%= availableBalance %></p>
    <button type="button" onclick="doWithdraw()" style="width:100%;padding:15px;background:#27AE60;color:#fff;border:none;border-radius:10px;font-size:16px;font-weight:700;cursor:pointer;">Confirm Request</button>
  </div>
</div>

<script>
function selP(p){
  document.getElementById('wP').value=p;
  var e=document.getElementById('eBtn');
  var k=document.getElementById('kBtn');
  e.style.background=p==='esewa'?'#D4A017':'#fff';
  e.style.color=p==='esewa'?'#fff':'#333';
  e.style.borderColor=p==='esewa'?'#D4A017':'#ddd';
  k.style.background=p==='khalti'?'#D4A017':'#fff';
  k.style.color=p==='khalti'?'#fff':'#333';
  k.style.borderColor=p==='khalti'?'#D4A017':'#ddd';
}
async function doWithdraw(){
  var p=document.getElementById('wP').value;
  var n=document.getElementById('wN').value.trim();
  var ph=document.getElementById('wPh').value.trim();
  var a=parseInt(document.getElementById('wAmt').value);
  if(!p){alert('Select eSewa or Khalti');return;}
  if(!n){alert('Enter account name');return;}
  if(!ph){alert('Enter phone number');return;}
  if(!a||a<400){alert('Minimum ₹400');return;}
  try{
    var hdrs={'Content-Type':'application/json'};
    if(typeof csrfHeaders==='function') hdrs=csrfHeaders(hdrs);
    var r=await fetch('/api/withdrawals',{
      method:'POST',
      headers:hdrs,
      credentials:'include',
      body:JSON.stringify({platform:p,accountName:n,phoneNumber:ph,amount:a})
    });
    var d=await r.json();
    if(d.success){
      alert('Requested! Admin processes in 24hrs.');
      location.reload();
    }else{
      alert(d.message||'Error. Try again.');
    }
  }catch(e){alert('Network error.');}
}
</script>

<%- include('partials/footer') %>
