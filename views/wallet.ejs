<%- include('partials/header') %>

<div class="container" style="max-width: 640px; padding-top: 32px; padding-bottom: 48px;">
  <!-- Back to Dashboard -->
  <a href="/dashboard" style="display: inline-flex; align-items: center; gap: 6px; color: var(--gray-500); font-size: 14px; text-decoration: none; margin-bottom: 20px;">
    <i class='bx bx-arrow-back'></i> Back to Dashboard
  </a>

  <h2 style="color: var(--navy); margin-bottom: 24px; display: flex; align-items: center; gap: 10px;">
    <i class='bx bx-wallet' style="color: var(--gold);"></i> Scroll My Wallet
  </h2>
<br>
<br>
<center><h3>
    Scroll Down For Withdrawing Your Earnings
  </h3></center>
  <!-- Referral Links -->
  <div class="card" style="padding: 20px; margin-bottom: 24px;">
    <h3 style="color: var(--navy); margin-bottom: 12px; display: flex; align-items: center; gap: 8px;">
      <i class='bx bx-link' style="color: var(--gold);"></i> Referral Links
    </h3>

    <div style="display: flex; flex-direction: column; gap: 12px;">
      <div>
        <label style="display:block;font-weight:600;color:var(--gray-600);margin-bottom:6px;">General</label>
        <div style="display:flex;gap:10px;align-items:center;">
          <input type="text" id="mainLink" value="<%= referralLink %>" readonly style="flex:1;padding:10px;border:1.5px solid #ddd;border-radius:8px;" />
        </div>
      </div>

      <div>
        <label style="display:block;font-weight:600;color:var(--gray-600);margin-bottom:6px;">Starter</label>
        <div style="display:flex;gap:10px;align-items:center;">
          <input type="text" id="starterLink" value="<%= starterLink %>" readonly style="flex:1;padding:10px;border:1.5px solid #ddd;border-radius:8px;" />
        </div>
      </div>

      <div>
        <label style="display:block;font-weight:600;color:var(--gray-600);margin-bottom:6px;">Prime</label>
        <div style="display:flex;gap:10px;align-items:center;">
          <input type="text" id="primeLink" value="<%= primeLink %>" readonly style="flex:1;padding:10px;border:1.5px solid #ddd;border-radius:8px;" />
        </div>
      </div>

      <div>
        <label style="display:block;font-weight:600;color:var(--gray-600);margin-bottom:6px;">Master</label>
        <div style="display:flex;gap:10px;align-items:center;">
          <input type="text" id="masterLink" value="<%= masterLink %>" readonly style="flex:1;padding:10px;border:1.5px solid #ddd;border-radius:8px;" />
        </div>
      </div>

      <div>
        <label style="display:block;font-weight:600;color:var(--gray-600);margin-bottom:6px;">Bundle</label>
        <div style="display:flex;gap:10px;align-items:center;">
          <input type="text" id="bundleLink" value="<%= bundleLink %>" readonly style="flex:1;padding:10px;border:1.5px solid #ddd;border-radius:8px;" />
        </div>
      </div>
    </div>
  </div>

  <!-- Wallet Balance Card -->
  <div class="card" style="text-align: center; padding: 40px 24px; margin-bottom: 24px; background: linear-gradient(135deg, #0A1F44, #163265); color: var(--white); border: none;">
    <i class='bx bx-wallet' style="font-size: 48px; color: var(--gold); margin-bottom: 12px;"></i>
    <div style="font-size: 42px; font-weight: 800; color: var(--white); margin-bottom: 4px;">₹<%= availableBalance %></div>
    <div style="font-size: 14px; color: rgba(255,255,255,0.7);">Available Balance</div>
  </div>

  <!-- Withdraw Button -->
  <% if (availableBalance >= 400) { %>
    <button type="button"
      id="openWBtn"
      style="width:100%;padding:16px;
      background:#27AE60;color:#fff;
      border:none;border-radius:10px;
      font-size:16px;font-weight:700;
      cursor:pointer;margin:16px 0;
      display:block;">
      Request Withdrawal
    </button>
    <script>
    document.getElementById('openWBtn')
      .addEventListener('click', function() {
        document.getElementById('wModal')
          .style.display = 'flex';
      });
    </script>
  <% } else { %>
    <button disabled style="width:100%;padding:16px;background:#ccc;color:#888;border:none;border-radius:10px;font-size:16px;font-weight:700;cursor:not-allowed;margin:16px 0;">
      Minimum ₹400 required to withdraw
    </button>
  <% } %>

  <!-- Withdrawal History -->
  <div class="card" style="padding: 24px;">
    <h3 style="color: var(--navy); margin-bottom: 16px; display: flex; align-items: center; gap: 8px;">
      <i class='bx bx-history' style="color: var(--gold);"></i> Withdrawal History
    </h3>

    <% if (withdrawals.length > 0) { %>
      <!-- Mobile-friendly table -->
      <div class="table-container">
        <table>
          <thead>
            <tr>
              <th>Amount</th>
              <th>Platform</th>
              <th>Phone/Account</th>
              <th>Status</th>
              <th>Date</th>
            </tr>
          </thead>
          <tbody>
            <% withdrawals.forEach(w => { %>
              <tr>
                <td style="font-weight: 700;">₹<%= w.amount %><% if (w.fee > 0) { %><br><span style="font-size:11px;color:var(--gray-500);">Fee: ₹<%= w.fee %></span><% } %></td>
                <td><%= w.method === 'esewa' ? 'eSewa' : w.method === 'khalti' ? 'Khalti' : 'Bank' %></td>
                <td style="font-size: 13px;">
                  <% if (w.method === 'bank') { %>
                    <%= w.accountName %><br>
                    <span style="color:var(--gray-500);"><%= w.bankName %> · <%= w.accountNumber %></span>
                  <% } else { %>
                    <%= w.walletId %>
                  <% } %>
                </td>
                <td>
                  <span class="badge badge-<%= w.status %>"><%= w.status.charAt(0).toUpperCase() + w.status.slice(1) %></span>
                  <% if (w.status === 'rejected' && w.rejectionReason) { %>
                    <br><span style="font-size:11px;color:var(--danger);"><%= w.rejectionReason %></span>
                  <% } %>
                </td>
                <td style="font-size: 13px; color: var(--gray-500);"><%= new Date(w.createdAt).toLocaleDateString() %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div style="text-align: center; padding: 32px 16px; color: var(--gray-400);">
        <i class='bx bx-receipt' style="font-size: 40px; margin-bottom: 8px;"></i>
        <p>No withdrawal history yet.</p>
      </div>
    <% } %>
  </div>
</div>

<!-- Withdrawal Modal -->
<div id="wModal"
  style="display:none;position:fixed;
  top:0;left:0;width:100%;height:100%;
  background:rgba(0,0,0,0.7);
  z-index:99999;align-items:center;
  justify-content:center;">
  <div style="background:#fff;
    padding:28px;border-radius:16px;
    width:90%;max-width:400px;
    position:relative;">
    
    <button type="button"
      id="closeWBtn"
      style="position:absolute;top:12px;
      right:16px;background:none;
      border:none;font-size:26px;
      cursor:pointer;">✕</button>
    
    <h3 style="margin:0 0 20px;
      color:#0A1F44;">Withdraw</h3>
    
    <div style="display:flex;gap:8px;
      margin-bottom:14px;">
      <button type="button" id="eb"
        style="flex:1;padding:12px;
        border:2px solid #ddd;
        border-radius:8px;font-weight:700;
        cursor:pointer;background:#fff;">
        eSewa
      </button>
      <button type="button" id="kb"
        style="flex:1;padding:12px;
        border:2px solid #ddd;
        border-radius:8px;font-weight:700;
        cursor:pointer;background:#fff;">
        Khalti
      </button>
    </div>
    <input type="hidden" id="wp"/>
    <input type="text" id="wn"
      placeholder="Account Holder Name"
      style="width:100%;padding:12px;
      border:1.5px solid #ddd;
      border-radius:8px;font-size:15px;
      margin-bottom:10px;
      box-sizing:border-box;"/>
    <input type="tel" id="wph"
      placeholder="Phone Number"
      style="width:100%;padding:12px;
      border:1.5px solid #ddd;
      border-radius:8px;font-size:15px;
      margin-bottom:10px;
      box-sizing:border-box;"/>
    <input type="number" id="wa"
      placeholder="Amount (min ₹400)"
      style="width:100%;padding:12px;
      border:1.5px solid #ddd;
      border-radius:8px;font-size:15px;
      margin-bottom:6px;
      box-sizing:border-box;"/>
    <p style="font-size:13px;color:#888;
      margin:0 0 14px;">
      Available: ₹<%= availableBalance||0 %>
    </p>
    <button type="button" id="submitW"
      style="width:100%;padding:14px;
      background:#27AE60;color:#fff;
      border:none;border-radius:10px;
      font-size:16px;font-weight:700;
      cursor:pointer;">
      Confirm
    </button>
  </div>
</div>

<script>
document.getElementById('closeWBtn')
  .addEventListener('click',function(){
    document.getElementById('wModal')
      .style.display='none';
  });

document.getElementById('eb')
  .addEventListener('click',function(){
    document.getElementById('wp').value='esewa';
    this.style.background='#D4A017';
    this.style.color='#fff';
    this.style.borderColor='#D4A017';
    document.getElementById('kb').style.background='#fff';
    document.getElementById('kb').style.color='#333';
    document.getElementById('kb').style.borderColor='#ddd';
  });

document.getElementById('kb')
  .addEventListener('click',function(){
    document.getElementById('wp').value='khalti';
    this.style.background='#D4A017';
    this.style.color='#fff';
    this.style.borderColor='#D4A017';
    document.getElementById('eb').style.background='#fff';
    document.getElementById('eb').style.color='#333';
    document.getElementById('eb').style.borderColor='#ddd';
  });

document.getElementById('submitW')
  .addEventListener('click', async function(){
    var p=document.getElementById('wp').value;
    var n=document.getElementById('wn').value.trim();
    var ph=document.getElementById('wph').value.trim();
    var a=parseInt(document.getElementById('wa').value);
    if(!p){alert('Select eSewa or Khalti');return;}
    if(!n){alert('Enter account name');return;}
    if(!ph){alert('Enter phone number');return;}
    if(!a||a<400){alert('Minimum ₹400');return;}
    try{
      var r=await fetch('/api/withdrawals',{
        method:'POST',
        headers:{'Content-Type':'application/json'},
        credentials:'include',
        body:JSON.stringify({
          platform:p,accountName:n,
          phoneNumber:ph,amount:a
        })
      });
      var d=await r.json();
      if(d.success){
        alert('Done! Admin will process in 24hrs.');
        location.reload();
      }else{
        alert(d.message||'Error');
      }
    }catch(e){alert('Network error');}
  });
</script>

<%- include('partials/footer') %>
