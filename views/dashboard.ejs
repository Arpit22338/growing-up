<%- include('partials/header') %>

<!-- Dashboard Header -->
<div class="dash-header">
  <div class="container">
    <h1>Welcome, <%= user.firstName %> 👋</h1>
    <p>Your referral code: <strong style="color: var(--gold);"><%= user.referralCode %></strong></p>
  </div>
</div>

<div class="container">
  <!-- Stats -->
  <div class="stats-grid">
    <div class="stat-card">
      <i class='bx bx-money'></i>
      <div class="stat-value">₹<%= user.totalEarnings %></div>
      <div class="stat-label">Total Earnings</div>
    </div>
    <div class="stat-card">
      <i class='bx bx-group'></i>
      <div class="stat-value"><%= user.referredUsers ? user.referredUsers.length : 0 %></div>
      <div class="stat-label">Total Referred Users</div>
    </div>
    <div class="stat-card">
      <i class='bx bx-book-open'></i>
      <div class="stat-value"><%= user.purchasedCourses ? user.purchasedCourses.filter(c => c.status === 'approved').length : 0 %></div>
      <div class="stat-label">Active Courses</div>
    </div>
    <div class="stat-card">
      <i class='bx bx-wallet'></i>
      <div class="stat-value">₹<%= user.referredUsers ? user.referredUsers.filter(r => r.isActive).length * Math.round((user.purchasedCourses && user.purchasedCourses[0] ? user.purchasedCourses[0].price : 0) * 0.65) : 0 %></div>
      <div class="stat-label">Earned from Referrals</div>
    </div>
  </div>

  <!-- Referral Section -->
  <div class="referral-box">
    <h3><i class='bx bx-link' style="color: var(--gold);"></i> My Referral Links</h3>
    <p style="color: var(--gray-500); font-size: 13px; margin-bottom: 16px;">
      Share these links to earn 65% commission on every sale!
    </p>

    <!-- General referral link -->
    <div style="margin-bottom: 16px; padding: 16px; background: var(--gray-50); border-radius: var(--radius-sm);">
      <label style="font-size: 13px; color: var(--navy); margin-bottom: 6px; display: block; font-weight: 600;">
        <i class='bx bx-globe' style="color: var(--gold);"></i> General Link (user picks course)
      </label>
      <div class="referral-link-group">
        <input type="text" readonly value="<%= baseUrl %>/register?ref=<%= user.referralCode %>" id="genLink">
        <button class="btn btn-primary btn-sm" onclick="copyLink('genLink')">
          <i class='bx bx-copy'></i> Copy
        </button>
      </div>
      <a href="https://wa.me/?text=Join%20Growing%20Up%20and%20start%20earning!%20<%= encodeURIComponent(baseUrl + '/register?ref=' + user.referralCode) %>" 
         target="_blank" class="btn-whatsapp" style="margin-top: 8px;">
        <i class='bx bxl-whatsapp'></i> Share on WhatsApp
      </a>
    </div>

    <!-- Course-specific referral links -->
    <h4 style="color: var(--navy); margin-bottom: 12px; font-size: 15px;">
      <i class='bx bx-book-open' style="color: var(--gold);"></i> Course-Specific Refer Links
    </h4>
    <div class="referral-dashboard">
      <% Object.keys(courses).forEach(key => { %>
        <div class="card" style="border-top: 3px solid <%= courses[key].borderColor && !courses[key].borderColor.includes('gradient') ? courses[key].borderColor : 'var(--gold)' %>;">
          <h4 style="font-size: 14px; color: var(--navy); margin-bottom: 4px;"><%= courses[key].title %></h4>
          <p style="font-size: 12px; color: var(--gray-500); margin-bottom: 8px;"><%= courses[key].name %> — <%= courses[key].currency %><%= courses[key].price %></p>
          <div class="referral-link-group" style="margin-bottom: 8px;">
            <input type="text" readonly
              value="<%= baseUrl %>/course/<%= key %>?ref=<%= user.referralCode %>"
              id="link_<%= key %>">
            <button class="btn btn-primary btn-sm" onclick="copyLink('link_<%= key %>')">
              <i class='bx bx-copy'></i>
            </button>
          </div>
          <a href="https://wa.me/?text=Check%20out%20<%= encodeURIComponent(courses[key].title) %>%20on%20Growing%20Up!%20<%= encodeURIComponent(baseUrl + '/course/' + key + '?ref=' + user.referralCode) %>" 
             target="_blank" class="btn-whatsapp" style="width: 100%; justify-content: center;">
            <i class='bx bxl-whatsapp'></i> Share
          </a>
        </div>
      <% }); %>
    </div>
  </div>

  <!-- Referred Users -->
  <div class="card" style="margin-bottom: 24px;">
    <h3 style="margin-bottom: 16px;"><i class='bx bx-group' style="color: var(--gold);"></i> My Referrals</h3>
    <% if (user.referredUsers && user.referredUsers.length > 0) { %>
      <div class="table-container">
        <table>
          <thead>
            <tr>
              <th>Name</th>
              <th>Email</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% user.referredUsers.forEach(ref => { %>
              <tr>
                <td><%= ref.firstName %> <%= ref.lastName %></td>
                <td><%= ref.email %></td>
                <td>
                  <span class="badge <%= ref.isActive ? 'badge-active' : 'badge-inactive' %>">
                    <%= ref.isActive ? 'Active' : 'Pending' %>
                  </span>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <p style="color: var(--gray-500); text-align: center; padding: 20px;">
        No referrals yet. Share your link to start earning!
      </p>
    <% } %>
  </div>

  <!-- Purchased Courses -->
  <div class="card" style="margin-bottom: 40px;">
    <h3 style="margin-bottom: 16px;"><i class='bx bx-book-open' style="color: var(--gold);"></i> My Courses</h3>
    <% if (user.purchasedCourses && user.purchasedCourses.length > 0) { %>
      <div class="table-container">
        <table>
          <thead>
            <tr>
              <th>Course</th>
              <th>Price</th>
              <th>Status</th>
              <th>Date</th>
            </tr>
          </thead>
          <tbody>
            <% user.purchasedCourses.forEach(course => { %>
              <tr>
                <td><%= course.courseName %></td>
                <td>₹<%= course.price %></td>
                <td>
                  <span class="badge badge-<%= course.status %>"><%= course.status %></span>
                </td>
                <td><%= new Date(course.purchasedAt).toLocaleDateString() %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <p style="color: var(--gray-500); text-align: center; padding: 20px;">No courses purchased yet.</p>
    <% } %>
  </div>
</div>

<script>
  function copyLink(id) {
    const input = document.getElementById(id);
    navigator.clipboard.writeText(input.value).then(() => {
      showToast('Link copied to clipboard!');
    });
  }
</script>

<%- include('partials/footer') %>
