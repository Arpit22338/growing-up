<%- include('partials/header') %>

<!-- Dashboard Hero -->
<div class="dash-header">
  <div class="container">
    <div class="dash-profile-row">
      <div class="dash-avatar">
        <% if (user.profilePicture) { %>
          <img src="<%= user.profilePicture %>" alt="<%= user.firstName %>">
        <% } else { %>
          <span><%= user.firstName.charAt(0).toUpperCase() %></span>
        <% } %>
      </div>
      <div style="flex:1;">
        <h1>Welcome back, <%= user.firstName %> <i class='bx bx-hand' style="color: var(--gold);"></i></h1>
        <p style="opacity: 0.9; margin: 6px 0 10px;">
          <span style="font-size:13px;opacity:0.85;">Your referral code:</span>
          <strong id="dashRefCode" style="color: var(--gold); background: rgba(212,168,67,0.15); padding: 4px 12px; border-radius: 20px; font-size: 15px; letter-spacing: 0.5px; margin-left: 4px;"><%= user.referralCode %></strong>
          <button type="button" onclick="copyDashRefCode()" title="Copy referral code" style="background:rgba(255,255,255,0.15);border:none;color:#fff;width:30px;height:30px;border-radius:6px;cursor:pointer;margin-left:6px;font-size:14px;vertical-align:middle;">
            <i class='bx bx-copy'></i>
          </button>
        </p>
        <a href="/profile" style="display:inline-block;color:#D4A017;text-decoration:none;font-size:13px;font-weight:600;">View full profile <i class='bx bx-right-arrow-alt'></i></a>
        <a href="/settings" style="display:inline-block;margin-left:12px;color:#fff;text-decoration:none;font-size:13px;font-weight:600;background:rgba(255,255,255,0.15);padding:6px 12px;border-radius:6px;"><i class='bx bx-cog'></i> Settings</a>
      </div>
    </div>
  </div>
</div>

<div class="container" style="max-width: 960px;">
  <!-- Quick Stats -->
  <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:16px;padding:16px;">
    <div style="background:#fff!important;border-radius:12px!important;padding:20px!important;box-shadow:0 2px 8px rgba(0,0,0,0.08)!important;display:flex!important;flex-direction:column!important;align-items:center!important;text-align:center!important;width:auto!important;height:auto!important;">
      <i class='bx bx-money' style="font-size:28px;color:#D4A017;margin-bottom:8px;"></i>
      <div style="font-size:24px;font-weight:700;color:#0A1F44;">₹<%= user.totalEarnings %></div>
      <div style="font-size:13px;color:#888;margin-top:4px;">Total Earnings</div>
    </div>
    <div style="background:#fff!important;border-radius:12px!important;padding:20px!important;box-shadow:0 2px 8px rgba(0,0,0,0.08)!important;display:flex!important;flex-direction:column!important;align-items:center!important;text-align:center!important;width:auto!important;height:auto!important;">
      <i class='bx bx-group' style="font-size:28px;color:#3B82F6;margin-bottom:8px;"></i>
      <div style="font-size:24px;font-weight:700;color:#0A1F44;"><%= user.referredUsers ? user.referredUsers.length : 0 %></div>
      <div style="font-size:13px;color:#888;margin-top:4px;">Referrals</div>
    </div>
    <div style="background:#fff!important;border-radius:12px!important;padding:20px!important;box-shadow:0 2px 8px rgba(0,0,0,0.08)!important;display:flex!important;flex-direction:column!important;align-items:center!important;text-align:center!important;width:auto!important;height:auto!important;">
      <i class='bx bx-book-open' style="font-size:28px;color:#10B981;margin-bottom:8px;"></i>
      <div style="font-size:24px;font-weight:700;color:#0A1F44;">4</div>
      <div style="font-size:13px;color:#888;margin-top:4px;">Active Courses</div>
    </div>
    <div style="background:#fff!important;border-radius:12px!important;padding:20px!important;box-shadow:0 2px 8px rgba(0,0,0,0.08)!important;display:flex!important;flex-direction:column!important;align-items:center!important;text-align:center!important;width:auto!important;height:auto!important;">
      <i class='bx bx-wallet' style="font-size:28px;color:#D4A017;margin-bottom:8px;"></i>
      <div style="font-size:24px;font-weight:700;color:#0A1F44;">₹<%= availableBalance %></div>
      <div style="font-size:13px;color:#888;margin-top:4px;">Available Balance</div>
    </div>
  </div>

  <!-- Wallet & Withdraw Section -->
  <div class="dash-section">
    <div class="dash-section-header">
      <h2><i class='bx bx-wallet'></i> Wallet</h2>
      <a href="/dashboard/wallet" style="font-size:13px;color:var(--gold);font-weight:600;text-decoration:none;">View Full Wallet <i class='bx bx-right-arrow-alt'></i></a>
    </div>
    <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:16px;margin-bottom:20px;">
      <div style="background:#fff!important;border-radius:12px!important;padding:20px!important;box-shadow:0 2px 8px rgba(0,0,0,0.08)!important;display:flex!important;flex-direction:column!important;align-items:center!important;text-align:center!important;width:auto!important;height:auto!important;">
        <i class='bx bx-money' style="font-size:28px;color:#D4A017;margin-bottom:8px;"></i>
        <div style="font-size:24px;font-weight:700;color:#0A1F44;">₹<%= user.totalEarnings %></div>
        <div style="font-size:13px;color:#888;margin-top:4px;">Total Earnings</div>
      </div>
      <div style="background:#fff!important;border-radius:12px!important;padding:20px!important;box-shadow:0 2px 8px rgba(0,0,0,0.08)!important;display:flex!important;flex-direction:column!important;align-items:center!important;text-align:center!important;width:auto!important;height:auto!important;">
        <i class='bx bx-wallet' style="font-size:28px;color:#10B981;margin-bottom:8px;"></i>
        <div style="font-size:24px;font-weight:700;color:#0A1F44;">₹<%= availableBalance %></div>
        <div style="font-size:13px;color:#888;margin-top:4px;">Available Balance</div>
      </div>
    </div>

    <% if (availableBalance > 0) { %>
     <a href="/dashboard/wallet"> <button type="button"
     
      style="width:100%;padding:16px;
      background:#27AE60;color:#fff;
      border:none;border-radius:10px;
      font-size:16px;font-weight:700;
      cursor:pointer;margin:16px 0;
      display:block;">
      Request Withdrawal
    </button></a>
    <% } else { %>
      <div style="background: var(--gray-100); border-radius: var(--radius-sm); padding: 12px 16px; text-align: center; color: var(--gray-500); font-size: 14px; margin-bottom: 16px;">
        <i class='bx bx-info-circle'></i> No withdrawable balance yet. Available: ₹<%= availableBalance %>
      </div>
    <% } %>

    <!-- Withdrawal History -->
    <% if (typeof withdrawals !== 'undefined' && withdrawals.length > 0) { %>
      <h4 style="color: var(--navy); margin-bottom: 12px;"><i class='bx bx-history' style="color: var(--gold);"></i> Withdrawal History</h4>
      <div class="dash-referral-list">
        <% withdrawals.forEach(w => { %>
          <div class="dash-referral-item" style="flex-wrap: wrap;">
            <div class="dash-referral-info" style="flex: 1;">
              <strong>₹<%= w.amount %> via <%= w.method.charAt(0).toUpperCase() + w.method.slice(1) %></strong>
              <span><%= new Date(w.createdAt).toLocaleDateString() %><%= w.fee > 0 ? ' · Fee: ₹' + w.fee + ' · Net: ₹' + w.netAmount : '' %></span>
              <% if (w.status === 'rejected' && w.rejectionReason) { %>
                <span style="color: var(--danger); font-size: 12px;">Reason: <%= w.rejectionReason %></span>
              <% } %>
            </div>
            <span class="badge badge-<%= w.status %>"><%= w.status %></span>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>

  <!-- Withdrawal Modal -->
  <div id="wModal" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.7);z-index:99999;align-items:center;justify-content:center;">
    <div style="background:#fff;border-radius:16px;padding:28px;width:90%;max-width:400px;position:relative;">

      <button type="button" onclick="document.getElementById('wModal').style.display='none'" style="position:absolute;top:12px;right:16px;background:none;border:none;font-size:24px;cursor:pointer;">✕</button>

      <h3 style="margin:0 0 20px;color:#0A1F44;font-size:20px;">Withdraw Money</h3>

      <div style="display:flex;gap:10px;margin-bottom:16px;">
        <button type="button" id="eb" onclick="selPlat('esewa')" style="flex:1;padding:12px;border:2px solid #ddd;border-radius:8px;font-weight:700;cursor:pointer;background:#fff;font-size:15px;">eSewa</button>
        <button type="button" id="kb" onclick="selPlat('khalti')" style="flex:1;padding:12px;border:2px solid #ddd;border-radius:8px;font-weight:700;cursor:pointer;background:#fff;font-size:15px;">Khalti</button>
      </div>
      <input type="hidden" id="wplat"/>

      <input type="text" id="wname" placeholder="Account Holder Name" style="width:100%;padding:13px;border:1.5px solid #ddd;border-radius:8px;font-size:15px;margin-bottom:12px;box-sizing:border-box;"/>

      <input type="tel" id="wphone" placeholder="Phone Number" style="width:100%;padding:13px;border:1.5px solid #ddd;border-radius:8px;font-size:15px;margin-bottom:12px;box-sizing:border-box;"/>

      <input type="number" id="wamt" placeholder="Amount" min="1" style="width:100%;padding:13px;border:1.5px solid #ddd;border-radius:8px;font-size:15px;margin-bottom:6px;box-sizing:border-box;"/>

      <p style="color:#888;font-size:13px;margin:0 0 16px;">Available: ₹<%= availableBalance || 0 %></p>

      <button type="button" onclick="submitWithdraw()" style="width:100%;padding:15px;background:#27AE60;color:#fff;border:none;border-radius:10px;font-size:16px;font-weight:700;cursor:pointer;">Confirm Request</button>
    </div>
  </div>

  <!-- Share & Earn Section -->
  <div class="dash-section">
    <div class="dash-section-header">
      <h2><i class='bx bx-share-alt'></i> Share & Earn</h2>
      <span class="dash-section-badge">65% commission</span>
    </div>

    <!-- General Link -->
    <div class="dash-share-card">
      <div class="dash-share-label"><i class='bx bx-link'></i> Your Referral Link</div>
      <div class="referral-link-group">
        <input type="text" readonly value="<%= baseUrl %>/register?ref=<%= user.referralCode %>" id="genLink">
      </div>
      <a href="https://wa.me/?text=Join%20Growing%20Up%20and%20start%20earning!%20<%= encodeURIComponent(baseUrl + '/register?ref=' + user.referralCode) %>"
         target="_blank" class="btn-whatsapp" style="margin-top: 10px;">
        <i class='bx bxl-whatsapp'></i> Share on WhatsApp
      </a>
    </div>

    <!-- Course Links -->
    <div class="dash-course-links">
      <% Object.keys(courses).forEach(key => { %>
        <div class="dash-course-link-card course-border-<%= key %>">
          <div class="dash-course-link-top">
            <span class="dash-course-name"><%= courses[key].title %></span>
            <span class="dash-course-price"><%= courses[key].currency %><%= courses[key].price %></span>
          </div>
          <div class="referral-link-group">
            <input type="text" readonly
              value="<%= baseUrl %>/course/<%= key %>?ref=<%= user.referralCode %>"
              id="link_<%= key %>">

          </div>
          <a href="https://wa.me/?text=Check%20out%20<%= encodeURIComponent(courses[key].title) %>%20on%20Growing%20Up!%20<%= encodeURIComponent(baseUrl + '/course/' + key + '?ref=' + user.referralCode) %>"
             target="_blank" class="btn-whatsapp btn-sm" style="width: 100%; justify-content: center; margin-top: 8px;">
            <i class='bx bxl-whatsapp'></i> Share
          </a>
        </div>
      <% }); %>
    </div>
  </div>

  <!-- My Referrals -->
  <div class="dash-section">
    <div class="dash-section-header">
      <h2><i class='bx bx-group'></i> My Referrals</h2>
      <span class="dash-section-count"><%= user.referredUsers ? user.referredUsers.length : 0 %> total</span>
    </div>
    <% if (user.referredUsers && user.referredUsers.length > 0) { %>
      <div class="dash-referral-list">
        <% user.referredUsers.forEach(ref => { %>
          <div class="dash-referral-item">
            <div class="dash-referral-avatar"><%= ref.firstName.charAt(0).toUpperCase() %></div>
            <div class="dash-referral-info">
              <strong><%= ref.firstName %> <%= ref.lastName %></strong>
              <span><%= ref.email %></span>
            </div>
            <span class="badge <%= ref.isActive ? 'badge-active' : 'badge-inactive' %>">
              <%= ref.isActive ? 'Active' : 'Pending' %>
            </span>
          </div>
        <% }); %>
      </div>
    <% } else { %>
      <div class="dash-empty">
        <i class='bx bx-user-plus'></i>
        <p>No referrals yet. Share your link to start earning!</p>
      </div>
    <% } %>
  </div>

  <!-- My Courses -->
  <div class="dash-section" style="margin-bottom: 48px;">
    <div class="dash-section-header">
      <h2><i class='bx bx-book-open'></i> My Courses</h2>
    </div>
    <% if (user.purchasedCourses && user.purchasedCourses.length > 0) { %>
      <div class="dash-course-list">
        <% user.purchasedCourses.forEach(course => { %>
          <div class="dash-course-item">
            <div class="dash-course-item-left">
              <div class="dash-course-icon"><i class='bx bx-book'></i></div>
              <div>
                <strong><%= course.courseName %></strong>
                <span>₹<%= course.price %> &bull; <%= new Date(course.purchasedAt).toLocaleDateString() %></span>
              </div>
            </div>
            <span class="badge badge-<%= course.status %>"><%= course.status %></span>
          </div>
        <% }); %>
      </div>
    <% } else { %>
      <div class="dash-empty">
        <i class='bx bx-cart'></i>
        <p>No courses purchased yet.</p>
      </div>
    <% } %>
  </div>
</div>

<script>
function copyDashRefCode() {
  var code = document.getElementById('dashRefCode').textContent.trim();
  var link = '<%= baseUrl %>/register?ref=' + code;
  if (navigator.clipboard && navigator.clipboard.writeText) {
    navigator.clipboard.writeText(link).then(function() { showToast('Referral link copied!', 'success'); }, function() { fallbackCopy(link); });
  } else { fallbackCopy(link); }
}
function fallbackCopy(t) {
  var ta = document.createElement('textarea');
  ta.value = t; ta.style.position = 'fixed'; ta.style.opacity = '0';
  document.body.appendChild(ta); ta.select();
  try { document.execCommand('copy'); showToast('Referral link copied!', 'success'); }
  catch(e) { showToast('Copy failed', 'error'); }
  document.body.removeChild(ta);
}
function showToast(msg, type) {
  var t = document.getElementById('dashToast');
  if (!t) {
    t = document.createElement('div');
    t.id = 'dashToast';
    t.style.cssText = 'position:fixed;top:80px;left:50%;transform:translateX(-50%) translateY(-20px);color:#fff;padding:12px 24px;border-radius:10px;font-size:14px;font-weight:600;z-index:99999;opacity:0;transition:opacity 0.2s,transform 0.2s;pointer-events:none;box-shadow:0 4px 16px rgba(0,0,0,0.2);';
    document.body.appendChild(t);
  }
  t.textContent = msg;
  t.style.background = type === 'error' ? '#DC2626' : '#0E7C66';
  t.style.opacity = '1';
  t.style.transform = 'translateX(-50%) translateY(0)';
  clearTimeout(showToast._t);
  showToast._t = setTimeout(function() {
    t.style.opacity = '0';
    t.style.transform = 'translateX(-50%) translateY(-20px)';
  }, 2500);
}

function selPlat(p) {
  document.getElementById('wplat').value = p;
  document.getElementById('eb').style.background = p==='esewa' ? '#D4A017' : '#fff';
  document.getElementById('eb').style.color = p==='esewa' ? '#fff' : '#333';
  document.getElementById('eb').style.borderColor = p==='esewa' ? '#D4A017' : '#ddd';
  document.getElementById('kb').style.background = p==='khalti' ? '#D4A017' : '#fff';
  document.getElementById('kb').style.color = p==='khalti' ? '#fff' : '#333';
  document.getElementById('kb').style.borderColor = p==='khalti' ? '#D4A017' : '#ddd';
}

var csrfMeta = document.querySelector('meta[name="csrf-token"]');
var CSRF = csrfMeta ? csrfMeta.content : '';

async function submitWithdraw() {
  var p = document.getElementById('wplat').value;
  var n = document.getElementById('wname').value.trim();
  var ph = document.getElementById('wphone').value.trim();
  var a = parseInt(document.getElementById('wamt').value);
  if (!p) { alert('Select eSewa or Khalti'); return; }
  if (!n) { alert('Enter account name'); return; }
  if (!ph) { alert('Enter phone number'); return; }
  if (!a || a < 1) { alert('Enter a valid amount'); return; }
  try {
    var r = await fetch('/api/withdrawals', {
      method: 'POST',
      headers: {'Content-Type':'application/json','X-CSRF-Token':CSRF},
      credentials: 'include',
      body: JSON.stringify({
        platform:p, accountName:n,
        phoneNumber:ph, amount:a
      })
    });
    var d = await r.json();
    if (d.success) {
      alert('Done! Admin processes in 24hrs.');
      document.getElementById('wModal').style.display = 'none';
      location.reload();
    } else {
      alert(d.message || d.error || 'Error. Try again.');
    }
  } catch(e) {
    alert('Network error. Try again.');
  }
}
</script>

<%- include('partials/footer') %>
