<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' — ' : '' %>Growing Up — Online Courses & Referral Earnings in Nepal</title>

  <!-- SEO Meta Tags -->
  <meta name="description" content="<%= typeof metaDesc !== 'undefined' ? metaDesc : 'Growing Up is Nepal\'s leading referral-based course platform. Learn skills, earn 65% referral commission. Starter ₹499, Prime ₹699, Master ₹1599, Everything Bundle ₹1999.' %>">
  <meta name="keywords" content="Growing Up Nepal, online courses Nepal, referral earnings Nepal, skill development, eSewa Khalti courses, learn and earn Nepal, Nepali education platform, digital skills Nepal">
  <meta name="author" content="Growing Up">
  <meta name="robots" content="index, follow">
  <meta name="theme-color" content="#0B1D3A">
  <link rel="canonical" href="<%= typeof canonicalUrl !== 'undefined' ? canonicalUrl : 'https://growingup.vercel.app' %>">

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website">
  <meta property="og:url" content="<%= typeof canonicalUrl !== 'undefined' ? canonicalUrl : 'https://growingup.vercel.app' %>">
  <meta property="og:title" content="<%= typeof title !== 'undefined' ? title + ' — ' : '' %>Growing Up — Learn & Earn in Nepal">
  <meta property="og:description" content="<%= typeof metaDesc !== 'undefined' ? metaDesc : 'Join thousands of Nepali learners building skills and earning through referrals. Courses from ₹499.' %>">
  <meta property="og:image" content="https://growingup.vercel.app/images/logo-512.png">
  <meta property="og:site_name" content="Growing Up">
  <meta property="og:locale" content="en_US">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="<%= typeof title !== 'undefined' ? title + ' — ' : '' %>Growing Up — Learn & Earn in Nepal">
  <meta name="twitter:description" content="<%= typeof metaDesc !== 'undefined' ? metaDesc : 'Nepal\'s leading referral-based course platform. Learn skills, earn commissions.' %>">
  <meta name="twitter:image" content="https://growingup.vercel.app/images/logo-512.png">

  <!-- Favicons (optimized sizes) -->
  <link rel="icon" type="image/x-icon" href="/images/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/images/favicon-16.png">
  <link rel="apple-touch-icon" sizes="192x192" href="/images/logo-192.png">

  <!-- Web App Manifest -->
  <link rel="manifest" href="/manifest.json">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">

  <!-- Structured Data (JSON-LD) -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "EducationalOrganization",
    "name": "Growing Up",
    "url": "https://growingup.vercel.app",
    "logo": "https://growingup.vercel.app/images/logo-512.png",
    "description": "Nepal's leading referral-based online course platform. Learn digital skills and earn through referrals.",
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+977-9808467028",
      "contactType": "customer support",
      "email": "arpitkafle468@gmail.com",
      "availableLanguage": ["English"]
    },
    "sameAs": [],
    "areaServed": {
      "@type": "Country",
      "name": "Nepal"
    },
    "offers": {
      "@type": "AggregateOffer",
      "lowPrice": "499",
      "highPrice": "1999",
      "priceCurrency": "INR",
      "offerCount": "4"
    }
  }
  </script>
  <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
</head>
<body>
  <!-- Navbar -->
  <nav style="background:#0A1F44;color:#fff;height:60px;padding:0 24px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:1000;width:100%;box-sizing:border-box;font-family:'Poppins',sans-serif;">
    <a href="/" style="display:flex;align-items:center;gap:8px;text-decoration:none;color:#fff;font-weight:700;font-size:18px;">
      <img src="/images/logo-web.png" alt="Growing Up" width="38" height="38" style="border-radius:50%;">
      Growing <span style="color:#D4A017;">Up</span>
    </a>
    <div id="navLinksDesktop" style="display:flex;align-items:center;gap:20px;">
      <a href="/" style="color:#fff;text-decoration:none;font-size:14px;font-weight:500;">Home</a>
      <a href="/#courses" style="color:#fff;text-decoration:none;font-size:14px;font-weight:500;">Courses</a>
      <% if (typeof session !== 'undefined' && session.userId) { %>
        <% if (session.role === 'superadmin' || session.role === 'financial_secretary') { %>
          <a href="/admin" style="color:#D4A017;text-decoration:none;font-size:14px;font-weight:600;">Admin</a>
        <% } else { %>
          <a href="/dashboard" style="color:#fff;text-decoration:none;font-size:14px;font-weight:500;">Dashboard</a>
        <% } %>
        <a href="/dashboard" style="color:#fff;text-decoration:none;font-size:14px;font-weight:500;"><i class='bx bx-user'></i> Profile</a>
        <a href="/logout" style="color:#0A1F44;background:#D4A017;padding:8px 18px;border-radius:8px;text-decoration:none;font-size:14px;font-weight:600;">Logout</a>
      <% } else { %>
        <a href="/login" style="color:#fff;text-decoration:none;font-size:14px;font-weight:500;">Login</a>
        <a href="/register" style="color:#0A1F44;background:#D4A017;padding:8px 18px;border-radius:8px;text-decoration:none;font-size:14px;font-weight:600;">Register</a>
      <% } %>
    </div>
    <button type="button" id="hamburgerBtn" style="display:none;background:none;border:none;color:#fff;font-size:28px;cursor:pointer;padding:4px;">
      <i class='bx bx-menu' id="hamburgerIcon"></i>
    </button>
  </nav>
  <!-- Mobile Drawer Overlay -->
  <div id="drawerOverlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:1100;" onclick="closeDrawer()"></div>
  <!-- Mobile Drawer -->
  <div id="mobileDrawer" style="position:fixed;top:0;left:-280px;width:280px;height:100%;background:#0A1F44;z-index:1200;transition:left 0.3s ease;padding:20px 0;overflow-y:auto;">
    <div style="display:flex;align-items:center;gap:8px;padding:0 20px 20px;border-bottom:1px solid rgba(255,255,255,0.1);">
      <img src="/images/logo-web.png" alt="Growing Up" width="36" height="36" style="border-radius:50%;">
      <span style="color:#fff;font-weight:700;font-size:16px;">Growing <span style="color:#D4A017;">Up</span></span>
      <button type="button" onclick="closeDrawer()" style="margin-left:auto;background:none;border:none;color:#fff;font-size:24px;cursor:pointer;"><i class='bx bx-x'></i></button>
    </div>
    <div style="padding:16px 0;">
      <a href="/" onclick="closeDrawer()" style="display:block;padding:12px 24px;color:#fff;text-decoration:none;font-size:15px;font-weight:500;">Home</a>
      <a href="/#courses" onclick="closeDrawer()" style="display:block;padding:12px 24px;color:#fff;text-decoration:none;font-size:15px;font-weight:500;">Courses</a>
      <% if (typeof session !== 'undefined' && session.userId) { %>
        <% if (session.role === 'superadmin' || session.role === 'financial_secretary') { %>
          <a href="/admin" onclick="closeDrawer()" style="display:block;padding:12px 24px;color:#D4A017;text-decoration:none;font-size:15px;font-weight:600;">Admin</a>
        <% } else { %>
          <a href="/dashboard" onclick="closeDrawer()" style="display:block;padding:12px 24px;color:#fff;text-decoration:none;font-size:15px;font-weight:500;">Dashboard</a>
        <% } %>
        <a href="/dashboard" onclick="closeDrawer()" style="display:block;padding:12px 24px;color:#fff;text-decoration:none;font-size:15px;font-weight:500;"><i class='bx bx-user'></i> Profile</a>
        <div style="border-top:1px solid rgba(255,255,255,0.1);margin:8px 0;"></div>
        <a href="/logout" onclick="closeDrawer()" style="display:block;padding:12px 24px;color:#ff6b6b;text-decoration:none;font-size:15px;font-weight:600;"><i class='bx bx-log-out'></i> Logout</a>
      <% } else { %>
        <a href="/login" onclick="closeDrawer()" style="display:block;padding:12px 24px;color:#fff;text-decoration:none;font-size:15px;font-weight:500;">Login</a>
        <a href="/register" onclick="closeDrawer()" style="display:block;padding:12px 24px;color:#D4A017;text-decoration:none;font-size:15px;font-weight:600;">Register</a>
      <% } %>
    </div>
  </div>
  <style>
    @media(max-width:768px){
      #navLinksDesktop{display:none!important;}
      #hamburgerBtn{display:block!important;}
      /* Ensure main navbar is sticky and visible */
      nav{position:sticky!important;top:0!important;z-index:9999!important;}
      /* Container full width on mobile */
      .container{width:100%!important;padding-left:16px!important;padding-right:16px!important;box-sizing:border-box!important;}
    }
  </style>
