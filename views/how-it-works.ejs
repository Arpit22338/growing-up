  .cta-box h2 { margin: 0 0 8px; font-size: 1.6rem; }
  .cta-box p { margin: 0 0 18px; opacity: 0.85; }
  .cta-box .btn {
    background: #0A1F44;
    color: #D4A017;
    padding: 14px 32px;
    border-radius: 10px;
    text-decoration: none;
    font-weight: 700;
    display: inline-block;
  }
  .cta-box .btn:hover { background: #051633; }
</style>

