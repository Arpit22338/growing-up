<script>
  // FAQ accordion — event delegation, keyboard accessible, single-open by default
  (function() {
    var list = document.querySelector('.how-section .faq-item').parentElement;
    if (!list) return;

    list.addEventListener('click', function(e) {
      var btn = e.target.closest('.faq-q');
      if (!btn) return;
      var item = btn.parentElement;
      var wasOpen = item.classList.contains('open');

      // Close all others in this list
      list.querySelectorAll('.faq-item.open').forEach(function(openItem) {
        if (openItem !== item) {
          openItem.classList.remove('open');
          var b = openItem.querySelector('.faq-q');
          if (b) b.setAttribute('aria-expanded', 'false');
        }
      });

      // Toggle this one
      item.classList.toggle('open', !wasOpen);
      btn.setAttribute('aria-expanded', String(!wasOpen));
    });

    // Keyboard: Enter / Space already handled by <button>, but ensure focus ring
  })();

  // Auto-open FAQ item if URL has #faq-N (e.g. /how-it-works#faq-3)
  if (window.location.hash && /^#faq-\d+$/.test(window.location.hash)) {
    var items = document.querySelectorAll('.faq-item');
    var idx = parseInt(window.location.hash.replace('#faq-', ''), 10) - 1;
    if (items[idx]) {
      items[idx].classList.add('open');
      var b = items[idx].querySelector('.faq-q');
      if (b) b.setAttribute('aria-expanded', 'true');
      items[idx].scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  }
</script>

