<%- include('partials/header') %>

<style>
  .how-hero {
    background: linear-gradient(135deg, #0A1F44 0%, #1E3A8A 100%);
    color: #fff;
    padding: 64px 24px;
    text-align: center;
  }
  .how-hero h1 { font-size: 2.4rem; font-weight: 800; margin: 0 0 12px; }
  .how-hero p { font-size: 1.1rem; opacity: 0.9; max-width: 640px; margin: 0 auto; }
  .how-container { max-width: 960px; margin: 0 auto; padding: 48px 24px; }
  .how-section { margin-bottom: 48px; }
  .how-section h2 {
    color: #0A1F44;
    font-size: 1.8rem;
    font-weight: 700;
    margin: 0 0 8px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .how-section h2 i { color: #D4A017; }
  .how-section .lede { color: #475569; font-size: 1.05rem; margin: 0 0 24px; }
  .steps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 20px;
  }
  .step {
    background: #fff;
    border-radius: 14px;
    padding: 24px 20px;
    box-shadow: 0 2px 10px rgba(10,31,68,0.06);
    border-top: 4px solid #D4A017;
    position: relative;
  }
  .step .num {
    position: absolute;
    top: -16px;
    left: 20px;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #D4A017;
    color: #0A1F44;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 16px;
    box-shadow: 0 2px 6px rgba(0,0,0,0.15);
  }
  .step h3 { color: #0A1F44; margin: 8px 0 8px; font-size: 1.05rem; }
  .step p { color: #64748B; font-size: 14px; margin: 0; line-height: 1.5; }

  @media (max-width: 600px) {
    .how-hero { padding: 40px 16px; }
    .how-hero h1 { font-size: 1.8rem; }
    .how-hero p { font-size: 1rem; }
    .how-container { padding: 32px 16px; }
    .how-section { margin-bottom: 32px; }
    .how-section h2 { font-size: 1.45rem; }
    .how-faq-item summary { padding: 14px 16px; font-size: 0.95rem; }
  }
  .earn-card {
    background: linear-gradient(135deg, #fff7e6, #fff);
    border: 2px solid #D4A017;
    border-radius: 14px;
    padding: 28px 24px;
    margin-bottom: 24px;
  }
  .earn-card h3 { color: #0A1F44; margin: 0 0 8px; font-size: 1.3rem; }
  .earn-card .big {
    font-size: 2.2rem;
    font-weight: 800;
    color: #D4A017;
    margin: 4px 0 12px;
  }
  .earn-card .note { color: #64748B; font-size: 14px; }
  .course-earn {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
    margin-top: 16px;
  }
  .course-earn-item {
    background: #fff;
    border-radius: 10px;
    padding: 16px;
    border: 1px solid #E2E8F0;
  }
  .course-earn-item .name { font-weight: 700; color: #0A1F44; margin-bottom: 4px; }
  .course-earn-item .com { color: #10B981; font-weight: 700; font-size: 1.1rem; }
  .course-earn-item .price { color: #64748B; font-size: 13px; }
  .faq-item {
    background: #fff;
    border-radius: 12px;
    margin-bottom: 10px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.04);
    border: 1px solid #E2E8F0;
    overflow: hidden;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .faq-item.open {
    border-color: #D4A017;
    box-shadow: 0 2px 12px rgba(212,168,67,0.12);
  }
  .faq-q {
    padding: 18px 20px;
    cursor: pointer;
    font-weight: 600;
    color: #0A1F44;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    user-select: none;
    background: none;
    border: none;
    width: 100%;
    text-align: left;
    font-family: 'Poppins', sans-serif;
    font-size: 16px;
    transition: background 0.15s;
  }
  .faq-q:hover { background: #F8FAFC; }
  .faq-q:focus-visible {
    outline: 2px solid #D4A017;
    outline-offset: -2px;
  }
  .faq-q .chev {
    color: #D4A017;
    font-size: 22px;
    transition: transform 0.25s ease;
    flex-shrink: 0;
  }
  .faq-item.open .faq-q .chev { transform: rotate(180deg); }
  .faq-a {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
    color: #475569;
    font-size: 15px;
    line-height: 1.6;
    padding: 0 20px;
  }
  .faq-item.open .faq-a {
    max-height: 600px;
    padding: 0 20px 18px;
  }
  .faq-a a { color: #0A1F44; font-weight: 600; text-decoration: underline; }
  .faq-a a:hover { color: #D4A017; }
  .tip-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 16px;
  }
  .tip {
    background: #fff;
    padding: 18px;
    border-radius: 10px;
    border-left: 4px solid #3B82F6;
  }
  .tip h4 { color: #0A1F44; margin: 0 0 6px; font-size: 1rem; }
  .tip p { color: #64748B; font-size: 14px; margin: 0; }
  .cta-box {
    background: linear-gradient(135deg, #D4A017, #B8860B);
    color: #0A1F44;
    border-radius: 16px;
    padding: 36px 28px;
    text-align: center;
    margin-top: 32px;
