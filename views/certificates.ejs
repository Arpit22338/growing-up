<%- include('partials/header', { title: 'My Certificates' }) %>

<style>
  .certs-wrap { max-width: 880px; margin: 0 auto; padding: 24px 16px 64px; font-family: 'Poppins', sans-serif; }
  .certs-hero {
    background: linear-gradient(135deg, #0A1F44, #1E3A8A);
    color: #fff; border-radius: 16px; padding: 28px 24px;
    margin-bottom: 24px; box-shadow: 0 4px 18px rgba(10,31,68,0.18);
  }
  .certs-hero h1 { font-size: 1.7rem; font-weight: 700; margin: 0 0 6px; }
  .certs-hero p { color: rgba(255,255,255,0.85); margin: 0; font-size: 0.98rem; }
  .cert-card {
    background: #fff; border: 1px solid #EEF2F7; border-radius: 14px;
    padding: 20px 22px; margin-bottom: 14px;
    display: flex; align-items: center; gap: 18px; flex-wrap: wrap;
    box-shadow: 0 2px 8px rgba(10,31,68,0.05);
  }
  .cert-card .seal {
    flex-shrink: 0; width: 64px; height: 64px; border-radius: 50%;
    background: linear-gradient(135deg, #D4A017, #B8860B);
    color: #0A1F44; display: flex; align-items: center; justify-content: center;
    font-size: 32px; box-shadow: 0 4px 12px rgba(212,168,67,0.35);
  }
  .cert-card .body { flex: 1; min-width: 200px; }
  .cert-card h3 { margin: 0 0 4px; color: #0A1F44; font-size: 1.15rem; font-weight: 700; }
  .cert-card .meta { color: #64748B; font-size: 13px; }
  .cert-card .meta code { background: #F1F5F9; padding: 2px 8px; border-radius: 4px; font-size: 12px; color: #0A1F44; }
  .cert-card .granted-badge {
    display: inline-block; background: #FEF3C7; color: #92400E;
    padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 700;
    margin-left: 6px;
  }
  .cert-card .actions { display: flex; gap: 8px; flex-wrap: wrap; }
  .cert-card .btn { padding: 10px 16px; border-radius: 8px; font-size: 13px; font-weight: 700; text-decoration: none; display: inline-flex; align-items: center; gap: 5px; cursor: pointer; border: none; }
  .cert-card .btn-gold { background: #D4A017; color: #0A1F44; }
  .cert-card .btn-gold:hover { background: #E5B22A; }
  .cert-card .btn-outline { background: #fff; color: #0A1F44; border: 1.5px solid #CBD5E1; }
  .cert-card .btn-outline:hover { background: #F1F5F9; }
  .empty {
    background: #fff; border: 1px dashed #CBD5E1; border-radius: 14px;
    padding: 40px 20px; text-align: center; color: #64748B;
  }
  .empty i { font-size: 56px; color: #CBD5E1; display: block; margin-bottom: 10px; }
  @media (max-width: 600px) {
    .certs-hero h1 { font-size: 1.35rem; }
    .cert-card { padding: 16px; }
    .cert-card .seal { width: 52px; height: 52px; font-size: 24px; }
  }
</style>

<div class="certs-wrap">
  <a href="/dashboard" style="display:inline-flex;align-items:center;gap:6px;color:#64748B;font-size:14px;text-decoration:none;margin-bottom:14px;font-weight:500;">
    <i class='bx bx-arrow-back'></i> Back to Dashboard
  </a>

  <div class="certs-hero">
    <h1><i class='bx bx-certification'></i> My Certificates</h1>
    <p>View, download, and share every certificate you've earned. Share the Certificate ID with anyone and they can verify it on the public Verify page.</p>
  </div>

  <% if (completed.length === 0) { %>
    <div class="empty">
      <i class='bx bx-award'></i>
      <h3 style="color:#0A1F44;margin:0 0 6px;">No certificates yet</h3>
      <p style="margin:0 0 18px;">Complete all modules in a course to earn your Certificate of Completion.</p>
      <a href="/dashboard" class="btn btn-gold" style="background:#D4A017;color:#0A1F44;padding:10px 18px;border-radius:8px;font-weight:700;text-decoration:none;display:inline-block;">Go to Dashboard</a>
    </div>
  <% } else { %>
    <% completed.forEach(function(c) { %>
      <div class="cert-card">
        <div class="seal"><i class='bx bx-medal'></i></div>
        <div class="body">
          <h3><%= c.courseName %><% if (c.granted) { %><span class="granted-badge">Granted</span><% } %></h3>
          <div class="meta">
            Completed <%= new Date(c.completedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
            &middot; Cert ID: <code>GU-<%= c.certId %></code>
          </div>
        </div>
        <div class="actions">
          <a href="/certificate/<%= c.courseKey %>" class="btn btn-gold" target="_blank"><i class='bx bx-show'></i> View</a>
          <a href="/certificate/<%= c.courseKey %>/download" class="btn btn-outline" target="_blank"><i class='bx bx-download'></i> Download</a>
          <button type="button" class="btn btn-outline" data-copy-text="GU-<%= c.certId %>"><i class='bx bx-copy'></i> Copy ID</button>
          <a href="/verify/GU-<%= c.certId %>" class="btn btn-outline" target="_blank"><i class='bx bx-shield-check'></i> Verify Link</a>
        </div>
      </div>
    <% }); %>
  <% } %>
</div>

<%- include('partials/footer') %>
