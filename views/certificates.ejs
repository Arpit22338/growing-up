<%- include('partials/header') %>

<style>
  body { background: #F1F5F9; }
  .certs-hero {
    background: linear-gradient(135deg, #0A1F44, #1E3A8A);
    color: #fff; text-align: center;
    padding: 52px 20px 36px; margin-bottom: 32px;
  }
  .certs-hero h1 { font-size: 2rem; font-weight: 800; margin: 0 0 10px; }
  .certs-hero p { color: rgba(255,255,255,0.85); font-size: 1rem; margin: 0; max-width: 540px; margin-left: auto; margin-right: auto; }

  .cert-card {
    background: #fff; border-radius: 14px; overflow: hidden;
    box-shadow: 0 2px 14px rgba(10,31,68,0.08);
    margin-bottom: 18px; border-left: 5px solid #10B981;
    animation: fadeIn 0.35s ease;
  }
  .cert-card.pending-sync { border-left-color: #F59E0B; }

  @keyframes fadeIn { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }

  .cert-card .inner { display: flex; align-items: stretch; gap: 0; }
  .cert-card .icon-col {
    flex-shrink: 0; width: 72px; display: flex; align-items: center; justify-content: center;
    background: linear-gradient(135deg, #0A1F44, #1E3A8A); color: #D4A017; font-size: 30px;
  }
  .cert-card.pending-sync .icon-col { background: linear-gradient(135deg, #92400E, #D97706); color: #fff; }
  .cert-card .body { flex: 1; padding: 16px 18px; display: flex; flex-direction: column; gap: 6px; }
  .cert-card .body h3 { margin: 0; font-size: 1.05rem; color: #0A1F44; font-weight: 700; }
  .cert-card .body .meta { color: #64748B; font-size: 13px; display: flex; flex-wrap: wrap; gap: 10px; align-items: center; }
  .cert-card .body .meta i { vertical-align: middle; margin-right: 2px; }
  .cert-card .body .cert-id { font-family: monospace; font-size: 13px; color: #0A1F44; background: #F1F5F9; padding: 2px 8px; border-radius: 4px; display: inline-block; }
  .cert-card .actions { display: flex; gap: 6px; margin-top: 6px; flex-wrap: wrap; }
  .cert-card .actions a, .cert-card .actions button {
    display: inline-flex; align-items: center; gap: 4px;
    padding: 6px 12px; border-radius: 6px; font-size: 13px; font-weight: 600;
    text-decoration: none; border: none; cursor: pointer; font-family: inherit;
  }
  .btn-dl { background: #D4A017; color: #0A1F44; }
  .btn-dl:hover { background: #E5B22A; }
  .btn-verify { background: #EEF2FF; color: #3730A3; }
  .btn-verify:hover { background: #C7D2FE; }
  .btn-del { background: #FEE2E2; color: #991B1B; }
  .btn-del:hover { background: #FECACA; }
  .btn-share { background: #F0F9FF; color: #0369A1; }
  .btn-share:hover { background: #E0F2FE; }
  .btn-copy { background: #F1F5F9; color: #475569; }
  .btn-copy:hover { background: #E2E8F0; }
  .btn-sync { background: #FEF3C7; color: #92400E; }
  .btn-sync:hover { background: #FDE68A; }

  .empty-state { text-align: center; padding: 60px 20px; }
  .empty-state i { font-size: 72px; color: #CBD5E1; }
  .empty-state h2 { color: #475569; margin: 16px 0 6px; }
  .empty-state p { color: #94A3B8; font-size: 15px; margin: 0 0 18px; }

  .sync-banner {
    background: #FEF3C7; border: 1px solid #F59E0B; border-radius: 10px;
    padding: 14px 18px; margin-bottom: 20px; display: flex; align-items: center;
    gap: 10px; color: #92400E; font-size: 14px;
  }
  .sync-banner i { font-size: 22px; flex-shrink: 0; }

  .toast {
    position: fixed; bottom: 20px; right: 20px; background: #0A1F44; color: #fff;
    padding: 12px 18px; border-radius: 8px; font-size: 14px; font-weight: 600;
    box-shadow: 0 4px 14px rgba(0,0,0,0.25); z-index: 9999; opacity: 0;
    transform: translateY(16px); transition: all 0.25s ease;
    display: flex; align-items: center; gap: 8px;
  }
  .toast.show { opacity: 1; transform: translateY(0); }
</style>

<div class="certs-hero">
  <h1><i class='bx bx-shield-quarter'></i> My Certificates</h1>
  <p>View, download, and verify your Growing Up course completion certificates.</p>
</div>

<div class="container" style="max-width:720px; padding-bottom:40px;">

  <div id="syncBanner" class="sync-banner" style="display:none;">
    <i class='bx bx-sync'></i>
    <span id="syncMsg">Syncing your completions to the server...</span>
  </div>

  <div id="certList"></div>

  <div id="pendingList" style="display:none;">
    <h2 style="font-size:1.15rem; color:#92400E; margin:24px 0 12px;"><i class='bx bx-medal'></i> Courses Ready to Claim</h2>
    <div id="pendingCards"></div>
  </div>

  <div id="emptyState" class="empty-state" style="display:none;">
    <i class='bx bx-medal'></i>
    <h2>No certificates yet</h2>
    <p>Complete all modules in a course to earn your certificate.</p>
    <a href="/how-it-works" style="color:#D4A017; font-weight:700;">How certificates work &rarr;</a>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
(function() {
  var baseUrl = '<%= baseUrl %>';
  var completedFromServer = <%- JSON.stringify(completed) %>;
  var approvedFromServer = <%- JSON.stringify(approved) %>;
  var moduleCountsFromServer = <%- JSON.stringify(moduleCounts) %>;
  var ALL_COURSE_KEYS = Object.keys(moduleCountsFromServer);

  var toastTimer = null;
  function showToast(msg, icon) {
    var el = document.getElementById('toast');
    el.innerHTML = '<i class="bx ' + (icon || 'bx-check-circle') + '"></i> ' + msg;
    el.className = 'toast show';
    clearTimeout(toastTimer);
    toastTimer = setTimeout(function() { el.className = 'toast'; }, 3000);
  }

  function fmtDate(d) {
    if (!d) return '';
    return new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
  }

  function copyText(text) {
    if (navigator.clipboard) { navigator.clipboard.writeText(text); return; }
    var ta = document.createElement('textarea');
    ta.value = text; document.body.appendChild(ta);
    ta.select(); document.execCommand('copy');
    document.body.removeChild(ta);
  }

  function getCsrf() {
    var m = document.querySelector('meta[name="csrf-token"]');
    return m ? m.content : '';
  }

  // ---- RENDER CERTIFICATE CARDS ----
  function renderCerts(certs) {
    var list = document.getElementById('certList');
    list.innerHTML = '';
    certs.forEach(function(c) {
      var card = document.createElement('div');
      card.className = 'cert-card';
      var verifyUrl = baseUrl + '/verify/GU-' + encodeURIComponent(c.certId);
      var downloadUrl = baseUrl + '/certificate/' + encodeURIComponent(c.courseKey) + '/download';
      card.innerHTML =
        '<div class="inner">' +
          '<div class="icon-col"><i class="bx bx-check-circle"></i></div>' +
          '<div class="body">' +
            '<h3>' + c.courseName + '</h3>' +
            '<div class="meta">' +
              '<span><i class="bx bx-calendar"></i> ' + fmtDate(c.completedAt) + '</span>' +
              '<span class="cert-id">GU-' + c.certId + '</span>' +
              (c.granted ? '<span><i class="bx bx-gift"></i> Granted</span>' : '') +
            '</div>' +
            '<div class="actions">' +
              '<a class="btn-dl" href="' + baseUrl + '/certificate/' + encodeURIComponent(c.courseKey) + '" target="_blank"><i class="bx bx-show"></i> View</a>' +
              '<a class="btn-verify" href="' + verifyUrl + '" target="_blank"><i class="bx bx-shield-check"></i> Verify</a>' +
              '<button class="btn-copy" onclick="window._certCopy(this,\'' + c.certId + '\')"><i class="bx bx-copy"></i> Copy ID</button>' +
              '<button class="btn-share" onclick="window._certShare(this,\'' + c.certId + '\',\'' + c.courseName.replace(/'/g, "\\'") + '\')"><i class="bx bx-share-alt"></i> Share</button>' +
              '<button class="btn-del" onclick="window._certDelete(this,\'' + c.courseKey + '\')"><i class="bx bx-trash"></i></button>' +
            '</div>' +
          '</div>' +
        '</div>';
      list.appendChild(card);
    });
  }

  // ---- RENDER PENDING (courses with localStorage progress but not yet synced) ----
  function renderPending(courses) {
    if (!courses.length) return;
    var sec = document.getElementById('pendingList');
    var wrap = document.getElementById('pendingCards');
    sec.style.display = '';
    wrap.innerHTML = '';
    courses.forEach(function(c) {
      var card = document.createElement('div');
      card.className = 'cert-card pending-sync';
      card.innerHTML =
        '<div class="inner">' +
          '<div class="icon-col"><i class="bx bx-medal"></i></div>' +
          '<div class="body">' +
            '<h3>' + c.courseName + '</h3>' +
            '<div class="meta"><span><i class="bx bx-check-circle"></i> ' + c.doneCount + ' / ' + c.moduleCount + ' modules complete</span></div>' +
            '<div class="actions">' +
              '<a class="btn-sync" href="/course/' + encodeURIComponent(c.courseKey) + '"><i class="bx bx-book-open"></i> View Course & Finish</a>' +
            '</div>' +
          '</div>' +
        '</div>';
      wrap.appendChild(card);
    });
  }

  // ---- ACTIONS ----
  window._certCopy = function(btn, certId) {
    copyText('GU-' + certId);
    showToast('Copied!', 'bx-check');
  };

  window._certShare = function(btn, certId, name) {
    var url = baseUrl + '/verify/GU-' + certId;
    var text = 'I earned the ' + name + ' certificate from Growing Up!\nVerify: ' + url;
    if (navigator.share) {
      navigator.share({ title: name + ' Certificate', text: text, url: url }).catch(function(){});
    } else {
      copyText(text);
      showToast('Copied share text!', 'bx-check');
    }
  };

  window._certDelete = function(btn, courseKey) {
    if (!confirm('Delete this certificate? You can re-earn it by completing the course again.')) return;
    fetch('/api/course/' + courseKey + '/delete-cert', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': getCsrf() },
      credentials: 'same-origin'
    }).then(function(r) { return r.json(); }).then(function(d) {
      if (d.success) {
        showToast('Certificate deleted', 'bx-check');
        setTimeout(function() { location.reload(); }, 600);
      } else {
        showToast(d.error || 'Failed', 'bx-error');
      }
    }).catch(function() { showToast('Network error', 'bx-error'); });
  };

  // ---- SYNC: check localStorage for each course and sync to DB ----
  function syncAndRender() {
    var pending = [];
    var syncPromises = [];
    var syncAttempted = {};

    ALL_COURSE_KEYS.forEach(function(key) {
      var storageKey = 'gu_completed_' + key;
      var stored = [];
      try { stored = JSON.parse(localStorage.getItem(storageKey)) || []; } catch(e) {}
      if (!stored.length) {
        try { stored = JSON.parse(localStorage.getItem('modules_' + key)) || []; } catch(e) {}
      }
      if (stored.length === 0) return;

      var completedCourse = completedFromServer.find(function(c) { return c.courseKey === key; });
      var modCount = moduleCountsFromServer[key] || 0;
      if (completedCourse) return;

      var allDone = modCount > 0 && stored.length >= modCount;

      if (allDone && !syncAttempted[key]) {
        syncAttempted[key] = true;
        var p = fetch('/api/course/' + key + '/complete', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': getCsrf() },
          credentials: 'same-origin',
          body: JSON.stringify({ courseKey: key })
        }).then(function(r) {
          if (r.status === 401 || r.status === 403) {
            return r.text().then(function(t) {
              showToast('Auth error (' + r.status + '): ' + t.substring(0, 100), 'bx-error');
              return { success: false, error: 'Auth error ' + r.status };
            });
          }
          return r.json();
        }).then(function(d) {
          if (d.success && d.completedAt) {
            showToast('Synced! Reloading...', 'bx-check-circle');
            return true;
          } else {
            showToast('Sync error: ' + (d.error || JSON.stringify(d)), 'bx-error');
            return false;
          }
        }).catch(function(e) {
          showToast('Network error: ' + e.message, 'bx-error');
          return false;
        });
        syncPromises.push(p);
      } else if (!allDone) {
        pending.push({
          courseKey: key,
          courseName: key.charAt(0).toUpperCase() + key.slice(1),
          moduleCount: modCount,
          doneCount: stored.length
        });
      }
    });

    if (syncPromises.length) {
      var banner = document.getElementById('syncBanner');
      var msg = document.getElementById('syncMsg');
      banner.style.display = '';
      msg.textContent = 'Syncing completions to server...';

      Promise.all(syncPromises).then(function(results) {
        var anySuccess = results.some(function(r) { return r === true; });
        if (anySuccess) {
          msg.textContent = 'Synced! Reloading...';
          setTimeout(function() { location.reload(); }, 1000);
        } else {
          msg.textContent = 'Sync failed. See toast for details.';
          banner.style.background = '#FEE2E2';
          banner.style.borderColor = '#DC2626';
          banner.style.color = '#991B1B';
          renderFallback(pending);
        }
      });
      return;
    }

    renderFallback(pending);
  }

  function renderFallback(pending) {
    if (completedFromServer.length) {
      renderCerts(completedFromServer);
    }
    if (pending.length) {
      renderPending(pending);
    }
    if (!completedFromServer.length && !pending.length) {
      document.getElementById('emptyState').style.display = '';
    }
  }

  // ---- INIT ----
  syncAndRender();
})();
</script>

<%- include('partials/footer') %>
