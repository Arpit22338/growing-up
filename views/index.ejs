<%- include('partials/header') %>

<!-- Hero Section -->
<section class="hero">
  <img src="/images/logo-web.png" alt="Growing Up" class="hero-logo" width="100" height="100">
  <h1>Invest in Your <span>Future</span></h1>
  <p>Join thousands of Nepali learners building skills and earning through referrals. Start your journey with Growing Up today.</p>
  <a href="#courses" class="btn-hero">
    <i class='bx bx-book-open'></i> Explore Courses
  </a>
</section>

<!-- How It Works -->
<section class="section">
  <div class="container">
    <h2 class="section-title">How It Works</h2>
    <p class="section-subtitle">Simple steps to start learning and earning</p>
    <div class="courses-grid" style="max-width: 800px; margin: 0 auto;">
      <div class="card" style="text-align: center;">
        <i class='bx bx-link' style="font-size: 40px; color: var(--gold); margin-bottom: 12px;"></i>
        <h3>1. Get a Referral</h3>
        <p style="color: var(--gray-500); font-size: 14px;">Get a referral link or code from an existing member to join the platform.</p>
      </div>
      <div class="card" style="text-align: center;">
        <i class='bx bx-cart' style="font-size: 40px; color: var(--gold); margin-bottom: 12px;"></i>
        <h3>2. Pick a Course</h3>
        <p style="color: var(--gray-500); font-size: 14px;">Choose a package that fits your goals and pay via eSewa or Khalti.</p>
      </div>
      <div class="card" style="text-align: center;">
        <i class='bx bx-money' style="font-size: 40px; color: var(--gold); margin-bottom: 12px;"></i>
        <h3>3. Earn & Grow</h3>
        <p style="color: var(--gray-500); font-size: 14px;">Refer others and earn 65% commission on every sale they make.</p>
      </div>
    </div>
  </div>
</section>

<!-- Courses Section -->
<section class="section" id="courses" style="background: var(--white);">
  <div class="container">
    <h2 class="section-title">Choose Your Package</h2>
    <p class="section-subtitle">All packages include lifetime access & community support</p>
    <div class="courses-grid">
      <% const courseKeys = Object.keys(courses); %>
      <% courseKeys.forEach((key, i) => { %>
        <% const c = courses[key]; %>
        <div class="course-card<%= key === 'everything' ? ' featured' : '' %>">
          <h3><%= c.name %></h3>
          <div class="price"><%= c.currency %><%= c.price %></div>
          <p><%= c.description %></p>
          <ul class="features">
            <% c.features.forEach(f => { %>
              <li><i class='bx bx-check'></i> <%= f %></li>
            <% }); %>
          </ul>
          <a href="/register?course=<%= key %>" class="btn-course">Get Started</a>
        </div>
      <% }); %>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
