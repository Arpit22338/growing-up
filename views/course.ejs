<%- include('partials/header') %>

<section class="section" style="background: var(--white); padding-top: 40px;">
  <div class="container" style="max-width: 800px;">
    
    <!-- Course Card -->
    <% var borderVal = (course.borderColor && !course.borderColor.includes('gradient')) ? course.borderColor : 'var(--gold)'; %>
    <div class="course-detail-card" data-border="<%= borderVal %>">
      <% if (course.badge) { %>
        <div class="course-badge" style="position: absolute; top: 16px; right: 16px;"><%= course.badge %></div>
      <% } %>

      <!-- Thumbnail -->
      <div class="course-detail-thumb">
        <img src="<%= course.thumbnail %>" alt="<%= course.title %>">
        <div class="course-detail-icon">
          <i class='bx <%= course.icon %>'></i>
        </div>
      </div>

      <!-- Info -->
      <div class="course-detail-body">
        <p class="course-detail-label"><%= course.name %></p>
        <h1 class="course-detail-title"><%= course.title %></h1>
        <div class="course-detail-price"><%= course.currency %><%= course.price %></div>
        <p class="course-detail-desc"><%= course.description %></p>

        <!-- Content List -->
        <h3 style="color: var(--navy); margin-bottom: 12px; font-size: 18px;">
          <i class='bx bx-list-check' style="color: var(--gold);"></i> What You'll Learn
        </h3>
        <ul class="course-detail-content">
          <% course.content.forEach(item => { %>
            <li>
              <i class='bx <%= item.icon %>' style="color: var(--gold); font-size: 18px; flex-shrink: 0;"></i>
              <span><%= item.text %></span>
            </li>
          <% }); %>
        </ul>

        <!-- Honest Certificate Note -->
        <div class="no-cert-notice" style="margin: 24px 0;">
          <i class='bx bx-info-circle'></i>
          <div>
            <strong style="display:block;margin-bottom:4px;color:#0A1F44;">About certification — being honest with you</strong>
            <span>Our courses are knowledge and skill-building programs. The real value is what you learn and apply, not a piece of paper. If you need a certificate for a job or school, this isn't the right product for that.</span>
            <br>
            <span style="display:block;margin-top:8px;">
              <strong style="color:#0A1F44;">Good news:</strong> if you <em>do</em> complete the full course, we <strong>do</strong> offer a free printable <em>Certificate of Completion</em> — just to mark the milestone. It's printable A4 landscape with your name, course, and a unique ID. See the FAQ for details.
            </span>
          </div>
        </div>

        <!-- Buttons -->
        <div class="course-detail-actions">
          <%
            // Decide what "Get Started" does for the current viewer.
            // Admins / owners → go straight to the reader.
            // Pending user    → back to /pending.
            // Inactive but eligible → friendly "approve your account first".
            // Not logged in   → register flow (original behavior).
            var isAdmin = !!(loggedInUser && (loggedInUser.role === 'superadmin' || loggedInUser.role === 'financial_secretary'));
            var ownsCourse = !!(loggedInUser && loggedInUser.purchasedCourses && loggedInUser.purchasedCourses.some(function(c) {
              return c.courseKey === course.key && c.status === 'approved';
            }));
            var canRead = isAdmin || ownsCourse;
          %>
          <% if (canRead) { %>
            <a href="/course/<%= course.key %>/read" class="btn btn-gold btn-lg" style="width: 100%;">
              <i class='bx bx-book-open'></i> <%= isAdmin ? 'Open Course (Admin)' : 'Open Course' %>
            </a>
          <% } else if (typeof loggedInUser !== 'undefined' && loggedInUser && !loggedInUser.isActive) { %>
            <a href="/pending" class="btn btn-gold btn-lg" style="width: 100%;">
              <i class='bx bx-time-five'></i> Awaiting Account Approval
            </a>
            <p style="font-size:12px;color:var(--gray-500);margin-top:8px;text-align:center;">
              Your account is pending — once approved you'll be able to access the course.
            </p>
          <% } else { %>
            <a href="/register?course=<%= course.key %><%= ref ? '&ref=' + ref : '' %>" class="btn btn-gold btn-lg" style="width: 100%;">
              <i class='bx bx-rocket'></i> Get Started
            </a>
            <% if (course.key === 'everything') { %>
              <p style="font-size:12px;color:var(--gray-500);margin-top:10px;text-align:center;line-height:1.5;">
                Everything Bundle (₹<%= course.price %>) includes everything from Starter, Prime, and Master — our recommended option if you want full access.
              </p>
            <% } else { %>
              <p style="font-size:12px;color:var(--gray-500);margin-top:10px;text-align:center;line-height:1.5;">
                Want full access to all 3 tiers? See the
                <a href="/course/bundle" style="color:var(--gold);font-weight:700;text-decoration:underline;">Everything Bundle (₹1,999)</a>
                — or
                <a href="https://wa.me/9779808467028?text=Hi%2C%20I%20want%20to%20switch%20tiers%20on%20Growing%20Up" target="_blank" rel="noopener noreferrer" style="color:#10B981;font-weight:700;text-decoration:none;">contact admin on WhatsApp</a>
                to switch tiers.
              </p>
            <% } %>
          <% } %>

          <% if (typeof loggedInUser !== 'undefined' && loggedInUser && loggedInUser.isActive) { %>
            <!-- Logged in & approved user: show refer button -->
            <div class="refer-earn-box">
              <h4><i class='bx bx-link' style="color: var(--gold);"></i> Refer & Earn 65%</h4>
              <p style="font-size: 13px; color: var(--gray-500); margin-bottom: 12px;">
                Share this course and earn ₹<%= Math.round(course.price * 0.65) %> per referral!
              </p>
              <div class="referral-link-group">
                <input type="text" readonly 
                  value="<%= baseUrl %>/course/<%= course.key %>?ref=<%= loggedInUser.referralCode %>" 
                  id="courseRefLink">

              </div>
              <a href="https://wa.me/?text=Check%20out%20this%20course%20on%20Growing%20Up!%20<%= encodeURIComponent(baseUrl + '/course/' + course.key + '?ref=' + loggedInUser.referralCode) %>" 
                 target="_blank" class="btn btn-sm" style="background: #25D366; color: white; margin-top: 10px; width: 100%;">
                <i class='bx bxl-whatsapp'></i> Share on WhatsApp
              </a>
            </div>
          <% } else if (typeof loggedInUser !== 'undefined' && loggedInUser && !loggedInUser.isActive) { %>
            <!-- Logged in but pending -->
            <div class="refer-earn-box" style="opacity: 0.7;">
              <p style="color: var(--warning); font-size: 13px; font-weight: 600;">
                <i class='bx bx-time-five'></i> Your account must be approved before you can refer others.
              </p>
            </div>
          <% } else { %>
            <!-- Not logged in -->
            <a href="/login" class="btn btn-outline btn-sm" style="width: 100%; margin-top: 8px;">
              <i class='bx bx-link'></i> Login to Refer & Earn
            </a>
          <% } %>
        </div>
      </div>
    </div>

  </div>
</section>

<script>
(function(){
  var card = document.querySelector('.course-detail-card[data-border]');
  if (card) card.style.borderTop = '5px solid ' + card.dataset.border;
})();
</script>

<%- include('partials/footer') %>
