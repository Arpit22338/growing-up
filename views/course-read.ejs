<%- include('partials/header', { loggedInUser }) %>

<style>
  .cr-wrap { max-width: 1180px; margin: 0 auto; padding: 20px 16px 64px; font-family: 'Poppins', sans-serif; }
  .cr-back { display: inline-flex; align-items: center; gap: 6px; color: #64748B; font-size: 14px; text-decoration: none; margin-bottom: 14px; font-weight: 500; }
  .cr-back:hover { color: #0A1F44; }

  /* Hero */
  .cr-hero {
    background: linear-gradient(135deg, #0A1F44 0%, #1E3A8A 60%, #3B82F6 100%);
    color: #fff;
    border-radius: 18px;
    padding: 26px 24px;
    box-shadow: 0 4px 20px rgba(10,31,68,0.18);
    margin-bottom: 20px;
  }
  .cr-hero h1 { font-size: 1.9rem; font-weight: 700; margin: 0 0 4px; line-height: 1.15; }
  .cr-hero p { color: rgba(255,255,255,0.85); margin: 0 0 16px; font-size: 0.98rem; }
  .cr-hero-meta { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 18px; }
  .cr-hero-meta .chip { background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.2); padding: 5px 12px; border-radius: 999px; font-size: 12px; font-weight: 600; }
  .cr-hero-meta .chip.gold { background: #D4A017; color: #0A1F44; border-color: #D4A017; }
  .cr-progress-row { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  .cr-progress-bar { flex: 1; min-width: 200px; height: 10px; background: rgba(255,255,255,0.15); border-radius: 999px; overflow: hidden; }
  .cr-progress-fill { height: 100%; background: linear-gradient(90deg, #D4A017, #E5B22A); border-radius: 999px; transition: width 0.4s ease; }
  .cr-progress-label { font-size: 13px; font-weight: 700; color: #fff; min-width: 80px; }

  /* Layout: sidebar + main */
  .cr-layout { display: grid; grid-template-columns: 280px 1fr; gap: 20px; }
  @media (max-width: 880px) { .cr-layout { grid-template-columns: 1fr; } }

  /* Sidebar (renamed from .cr-sidebar to .cr-modnav so the global
     [class*="sidebar"] mobile-hide rule in style.css doesn't clobber it) */
  .cr-modnav { background: #fff; border: 1px solid #EEF2F7; border-radius: 14px; padding: 14px; box-shadow: 0 2px 8px rgba(10,31,68,0.05); position: sticky; top: 80px; align-self: start; max-height: calc(100vh - 100px); overflow-y: auto; }
  .cr-modnav h3 { font-size: 13px; text-transform: uppercase; color: #64748B; letter-spacing: 0.5px; margin: 0 0 10px; padding: 0 4px; }
  .cr-mod-item {
    display: flex; align-items: flex-start; gap: 10px;
    padding: 10px 12px; border-radius: 10px;
    cursor: pointer; transition: background 0.15s, transform 0.05s;
    border: 1.5px solid transparent;
    margin-bottom: 4px;
  }
  .cr-mod-item:hover { background: #F1F5F9; }
  .cr-mod-item.active { background: #EEF2FF; border-color: #6366f1; }
  .cr-mod-item:active { transform: scale(0.99); }
  .cr-mod-check { flex-shrink: 0; width: 22px; height: 22px; border-radius: 50%; background: #E2E8F0; color: #94A3B8; display: flex; align-items: center; justify-content: center; font-size: 14px; margin-top: 1px; }
  .cr-mod-item.done .cr-mod-check { background: #10B981; color: #fff; }
  .cr-mod-title { font-size: 14px; color: #0A1F44; line-height: 1.35; font-weight: 500; }
  .cr-mod-item.active .cr-mod-title { font-weight: 700; }

  /* Main */
  .cr-main { background: #fff; border: 1px solid #EEF2F7; border-radius: 14px; padding: 28px 28px 24px; box-shadow: 0 2px 8px rgba(10,31,68,0.05); min-height: 460px; }
  .cr-mod-content h2 { font-size: 1.55rem; color: #0A1F44; margin: 0 0 14px; font-weight: 700; line-height: 1.2; }
  .cr-mod-content h3 { font-size: 1.05rem; color: #3730a3; margin: 22px 0 8px; font-weight: 700; display: flex; align-items: center; gap: 6px; }
  .cr-mod-content p { color: #334155; line-height: 1.65; margin: 0 0 12px; font-size: 15px; }
  .cr-mod-content ul, .cr-mod-content ol { color: #334155; line-height: 1.7; padding-left: 22px; margin: 0 0 14px; font-size: 15px; }
  .cr-mod-content ul li, .cr-mod-content ol li { margin-bottom: 4px; }
  .cr-mod-content b, .cr-mod-content strong { color: #0A1F44; }

  .cr-callout { border-left: 4px solid #D4A017; padding: 12px 14px; background: #FFFBEB; border-radius: 0 8px 8px 0; margin: 14px 0; color: #92400E; font-size: 14.5px; line-height: 1.55; }
  .cr-callout.tip { border-color: #6366f1; background: #EEF2FF; color: #3730a3; }
  .cr-callout.story { border-color: #10B981; background: #ECFDF5; color: #065F46; }

  /* Mark-complete */
  .cr-complete-row { margin-top: 28px; padding-top: 20px; border-top: 1px solid #EEF2F7; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; }
  .cr-complete-status { font-size: 14px; color: #64748B; }
  .cr-complete-status.done { color: #065F46; font-weight: 600; }
  .cr-complete-btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 12px 22px; border-radius: 10px;
    font-family: 'Poppins', sans-serif; font-size: 14px; font-weight: 700;
    cursor: pointer; border: 2px solid transparent;
    transition: transform 0.05s, background 0.2s;
  }
  .cr-complete-btn:active { transform: scale(0.97); }
  .cr-complete-btn.mark { background: #10B981; color: #fff; }
  .cr-complete-btn.mark:hover { background: #059669; }
  .cr-complete-btn.unmark { background: #fff; color: #64748B; border-color: #CBD5E1; }
  .cr-complete-btn.unmark:hover { background: #F1F5F9; }
  .cr-complete-btn:disabled { opacity: 0.6; cursor: wait; }

  /* CTA */
  .cr-cta { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 28px; padding: 20px; background: linear-gradient(135deg, #F0FDF4, #ECFDF5); border: 2px dashed #10B981; border-radius: 14px; align-items: center; }
  .cr-cta .text { flex: 1; min-width: 200px; }
  .cr-cta h3 { margin: 0 0 4px; color: #065F46; font-size: 1.1rem; }
  .cr-cta p { margin: 0; color: #047857; font-size: 14px; }
  .cr-cta .btn-gold { background: #D4A017; color: #0A1F44; padding: 12px 22px; border-radius: 10px; text-decoration: none; font-weight: 700; display: inline-flex; align-items: center; gap: 6px; }
  .cr-cta .btn-gold:hover { background: #E5B22A; }
  .cr-cta.locked { background: linear-gradient(135deg, #FEF3C7, #FEF9E7); border-color: #D4A017; }
  .cr-cta.locked h3 { color: #92400E; }
  .cr-cta.locked p { color: #B45309; }
  .cr-cta.locked .btn-gold { background: #CBD5E1; color: #64748B; pointer-events: none; }

  /* Toast */
  .cr-toast { position: fixed; top: 80px; left: 50%; transform: translateX(-50%) translateY(-20px); background: #0A1F44; color: #fff; padding: 12px 24px; border-radius: 10px; font-size: 14px; font-weight: 600; z-index: 9999; opacity: 0; pointer-events: none; transition: opacity 0.2s, transform 0.2s; box-shadow: 0 4px 16px rgba(0,0,0,0.2); max-width: 90%; text-align: center; }
  .cr-toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
  .cr-toast.success { background: #10B981; }
  .cr-toast.error { background: #DC2626; }

  /* Module pills (mobile) */
  .cr-pills { display: none; overflow-x: auto; gap: 6px; padding: 10px 0; margin-bottom: 16px; -webkit-overflow-scrolling: touch; scrollbar-width: none; }
  .cr-pills::-webkit-scrollbar { display: none; }
  .cr-pills .pill { flex-shrink: 0; padding: 6px 14px; border-radius: 999px; font-size: 12px; font-weight: 600; border: 1.5px solid #E2E8F0; background: #fff; color: #64748B; cursor: pointer; transition: all 0.15s; white-space: nowrap; }
  .cr-pills .pill.active { background: #EEF2FF; border-color: #6366f1; color: #4338CA; }
  .cr-pills .pill.done { background: #ECFDF5; border-color: #10B981; color: #065F46; }
  @media (max-width: 880px) { .cr-pills { display: flex; } }

  /* Prev / Next buttons */
  .cr-nav-btns { display: flex; justify-content: space-between; gap: 12px; margin-top: 20px; padding-top: 16px; border-top: 1px solid #EEF2F7; }
  .cr-nav-btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 10px 18px; border-radius: 10px;
    font-family: 'Poppins', sans-serif; font-size: 13px; font-weight: 600;
    cursor: pointer; border: 1.5px solid #E2E8F0; background: #fff; color: #0A1F44;
    transition: background 0.15s, border-color 0.15s;
    text-decoration: none;
  }
  .cr-nav-btn:hover { background: #F1F5F9; border-color: #6366f1; }
  .cr-nav-btn:disabled, .cr-nav-btn.disabled { opacity: 0.4; pointer-events: none; }

  /* Responsive */
  @media (max-width: 880px) {
    .cr-modnav { position: static; max-height: none; }
    .cr-main { padding: 22px 18px 20px; }
  }
  @media (max-width: 600px) {
    .cr-wrap { padding: 14px 10px 48px; }
    .cr-hero { padding: 20px 16px; }
    .cr-hero h1 { font-size: 1.5rem; }
    .cr-main { padding: 18px 14px 16px; }
    .cr-mod-content h2 { font-size: 1.3rem; }
    .cr-mod-content h3 { font-size: 1rem; }
  }
</style>

<div class="cr-wrap">
  <a href="/dashboard" class="cr-back"><i class='bx bx-arrow-back'></i> Back to Dashboard</a>

  <!-- Hero -->
  <div class="cr-hero">
    <h1><%= course.name %></h1>
    <p><%= course.description %></p>
    <div class="cr-hero-meta">
      <span class="chip"><i class='bx bx-book-open'></i> <%= moduleCount %> module<%= moduleCount === 1 ? '' : 's' %></span>
      <span class="chip"><i class='bx bx-layer'></i> <%= course.title %></span>
      <span class="chip gold"><i class='bx bx-medal'></i> Free Certificate on Completion</span>
    </div>
    <div class="cr-progress-row">
      <div class="cr-progress-bar">
        <div class="cr-progress-fill" id="crProgressFill" style="width: <%= moduleCount > 0 ? (completedCount / moduleCount * 100) : 0 %>%"></div>
      </div>
      <div class="cr-progress-label" id="crProgressLabel"><%= completedCount %> / <%= moduleCount %></div>
    </div>
  </div>

  <% if (typeof certLocked !== 'undefined' && certLocked) { %>
    <div class="cr-cta locked" style="margin-bottom: 20px;">
      <div class="text">
        <h3><i class='bx bx-lock-alt'></i> Certificate Locked</h3>
        <p>Complete all <%= moduleCount %> modules to unlock your Certificate of Completion.</p>
      </div>
    </div>
  <% } %>

  <!-- Layout -->
  <div class="cr-layout">
    <!-- Module nav (renamed from cr-sidebar to avoid global mobile-hide) -->
    <aside class="cr-modnav" id="crSidebar">
      <h3><i class='bx bx-list-ul'></i> Modules</h3>
      <% modules.forEach(function(mod, idx) { %>
        <div class="cr-mod-item <%= idx === 0 ? 'active' : '' %> <%= completedModules.indexOf(mod.id) !== -1 ? 'done' : '' %>" data-idx="<%= idx %>" data-id="<%= mod.id %>">
          <div class="cr-mod-check"><% if (completedModules.indexOf(mod.id) !== -1) { %><i class='bx bx-check'></i><% } else { %><%= idx + 1 %><% } %></div>
          <div class="cr-mod-title"><%= mod.title %></div>
        </div>
      <% }); %>
    </aside>

    <!-- Main -->
    <main class="cr-main">
      <!-- Module pills (mobile) -->
      <div class="cr-pills" id="crPills">
        <% modules.forEach(function(mod, idx) { %>
          <span class="pill <%= idx === 0 ? 'active' : '' %> <%= completedModules.indexOf(mod.id) !== -1 ? 'done' : '' %>" data-idx="<%= idx %>"><%= idx + 1 %>. <%= mod.title %></span>
        <% }); %>
      </div>

      <div class="cr-mod-content" id="crModContent">
        <!-- populated by JS -->
      </div>

      <div class="cr-complete-row">
        <div class="cr-complete-status" id="crStatus"></div>
        <button type="button" class="cr-complete-btn" id="crCompleteBtn" data-idx="0">
          <i class='bx bx-check-circle'></i> <span>Loading...</span>
        </button>
      </div>

      <!-- Prev / Next buttons -->
      <div class="cr-nav-btns" id="crNavBtns">
        <button type="button" class="cr-nav-btn disabled" id="crPrevBtn"><i class='bx bx-chevron-left'></i> Prev</button>
        <button type="button" class="cr-nav-btn" id="crNextBtn">Next <i class='bx bx-chevron-right'></i></button>
      </div>

      <% if (allComplete) { %>
        <div class="cr-cta" id="crCertCta">
          <div class="text">
            <h3><i class='bx bx-party'></i> All Modules Complete!</h3>
            <p>You've finished every module. Your Certificate of Completion is ready.</p>
          </div>
          <a href="/certificate/<%= courseKey %>" class="btn-gold" target="_blank"><i class='bx bx-certification'></i> Get Certificate</a>
        </div>
      <% } else { %>
        <div class="cr-cta locked" id="crCertCta">
          <div class="text">
            <h3><i class='bx bx-lock-alt'></i> Certificate Unlocks at 100%</h3>
            <p>Finish all <%= moduleCount %> modules to download your Certificate of Completion.</p>
          </div>
          <span class="btn-gold"><i class='bx bx-certification'></i> Locked</span>
        </div>
      <% } %>

      <div style="margin-top:24px;">
        <a href="/dashboard" class="cr-back"><i class='bx bx-grid-alt'></i> Back to Dashboard</a>
      </div>
    </main>
  </div>
</div>

<div class="cr-toast" id="crToast"></div>

<script>
  // Server-injected data (module content is HTML from us, safe to set)
  const courseKey = '<%= courseKey %>';
  const modules = <%- JSON.stringify(modules).replace(/<\x2Fscript/gi, '<\\x2Fscript') %>;
  const moduleCount = <%= moduleCount %>;

  // Completion is stored in localStorage — no server round-trip needed.
  // Key: gu_completed_{courseKey} → JSON array of module IDs.
  const STORAGE_KEY = 'gu_completed_' + courseKey;

  function loadCompleted() {
    try {
      var raw = localStorage.getItem(STORAGE_KEY);
      return raw ? JSON.parse(raw) : [];
    } catch (e) { return []; }
  }
  function saveCompleted(arr) {
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(arr)); } catch (e) {}
  }

  let completedModules = loadCompleted();

  const moduleList = document.getElementById('crSidebar');
  const moduleContent = document.getElementById('crModContent');
  const completeBtn = document.getElementById('crCompleteBtn');
  const statusEl = document.getElementById('crStatus');
  const progressFill = document.getElementById('crProgressFill');
  const progressLabel = document.getElementById('crProgressLabel');
  const certCta = document.getElementById('crCertCta');
  const toastEl = document.getElementById('crToast');

  let currentIdx = 0;

  function showToast(msg, type) {
    toastEl.textContent = msg;
    toastEl.className = 'cr-toast show ' + (type || '');
    clearTimeout(showToast._t);
    showToast._t = setTimeout(function() { toastEl.className = 'cr-toast'; }, 2500);
  }

  function isCompleted(id) { return completedModules.indexOf(id) !== -1; }
  function completedCount() { return completedModules.length; }
  function allComplete() { return moduleCount > 0 && completedModules.length >= moduleCount; }

  function renderSidebar() {
    if (!moduleList) return;
    Array.from(moduleList.querySelectorAll('.cr-mod-item')).forEach(function(el) {
      const idx = parseInt(el.getAttribute('data-idx'), 10);
      const id = parseInt(el.getAttribute('data-id'), 10);
      el.classList.toggle('active', idx === currentIdx);
      el.classList.toggle('done', isCompleted(id));
      const check = el.querySelector('.cr-mod-check');
      if (isCompleted(id)) {
        check.innerHTML = "<i class='bx bx-check'></i>";
      } else {
        check.textContent = String(idx + 1);
      }
    });
  }

  function renderProgress() {
    const pct = moduleCount > 0 ? (completedCount() / moduleCount * 100) : 0;
    progressFill.style.width = pct + '%';
    progressLabel.textContent = completedCount() + ' / ' + moduleCount;
  }

  function renderPills() {
    if (!pillsEl) return;
    Array.from(pillsEl.querySelectorAll('.pill')).forEach(function(el) {
      const idx = parseInt(el.getAttribute('data-idx'), 10);
      const id = modules[idx] ? modules[idx].id : -1;
      el.classList.toggle('active', idx === currentIdx);
      el.classList.toggle('done', isCompleted(id));
    });
  }

  function renderNavBtns() {
    prevBtn.classList.toggle('disabled', currentIdx === 0);
    nextBtn.classList.toggle('disabled', currentIdx >= modules.length - 1);
  }

  function renderCertCta() {
    if (allComplete()) {
      certCta.className = 'cr-cta';
      certCta.innerHTML = "<div class='text'><h3><i class='bx bx-party'></i> All Modules Complete!</h3><p>You've finished every module. Your Certificate of Completion is ready.</p></div><a href='/certificate/" + courseKey + "' class='btn-gold' target='_blank'><i class='bx bx-certification'></i> Get Certificate</a>";
    } else {
      certCta.className = 'cr-cta locked';
      certCta.innerHTML = "<div class='text'><h3><i class='bx bx-lock-alt'></i> Certificate Unlocks at 100%</h3><p>Finish all " + moduleCount + " modules to download your Certificate of Completion.</p></div><span class='btn-gold'><i class='bx bx-certification'></i> Locked</span>";
    }
  }

  function renderCompleteBtn() {
    if (!modules[currentIdx]) return;
    const modId = modules[currentIdx].id;
    completeBtn.setAttribute('data-idx', currentIdx);
    if (isCompleted(modId)) {
      completeBtn.className = 'cr-complete-btn unmark';
      completeBtn.innerHTML = "<i class='bx bx-undo'></i> <span>Mark as Incomplete</span>";
      statusEl.className = 'cr-complete-status done';
      statusEl.innerHTML = "<i class='bx bx-check-circle'></i> You've completed this module";
    } else {
      completeBtn.className = 'cr-complete-btn mark';
      completeBtn.innerHTML = "<i class='bx bx-check-circle'></i> <span>Mark as Complete</span>";
      statusEl.className = 'cr-complete-status';
      statusEl.innerHTML = "<i class='bx bx-info-circle'></i> Mark this module as complete to track your progress";
    }
  }

  function renderModule() {
    if (!modules[currentIdx]) return;
    const mod = modules[currentIdx];
    moduleContent.innerHTML = mod.content;
    window.scrollTo({ top: moduleContent.offsetTop - 80, behavior: 'smooth' });
    renderSidebar();
    renderCompleteBtn();
    renderPills();
    renderNavBtns();
  }

  // Toggle completion — localStorage only, no server call for individual modules
  function toggleComplete() {
    if (!modules[currentIdx]) return;
    const modId = modules[currentIdx].id;
    const idx = completedModules.indexOf(modId);
    if (idx !== -1) {
      completedModules.splice(idx, 1);
      showToast('Marked as incomplete', 'success');
    } else {
      completedModules.push(modId);
      showToast('✓ Module marked complete!', 'success');
    }
    saveCompleted(completedModules);

    // Always render cert CTA — even if sidebar/pills fail
    try { renderSidebar(); } catch(e) {}
    try { renderProgress(); } catch(e) {}
    try { renderPills(); } catch(e) {}
    try { renderNavBtns(); } catch(e) {}
    try { renderCompleteBtn(); } catch(e) {}
    renderCertCta();

    // If all modules are now complete, sync certificate ownership to DB
    if (allComplete()) {
      syncCertToDB();
    }
  }

  // Save certificate ownership to DB (idempotent, called once when all modules done)
  function syncCertToDB() {
    var _csrfMeta = document.querySelector('meta[name="csrf-token"]');
    var _csrf = _csrfMeta ? _csrfMeta.content : '';
    fetch('/api/course/' + courseKey + '/complete', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': _csrf },
      credentials: 'same-origin',
      body: JSON.stringify({ courseKey: courseKey })
    }).then(function(r) { return r.json(); }).then(function(d) {
      if (d.success) console.log('Certificate synced to DB');
    }).catch(function(e) { console.error('Cert sync failed:', e); });
  }

  // Wire sidebar clicks
  Array.from(moduleList.querySelectorAll('.cr-mod-item')).forEach(function(el) {
    el.addEventListener('click', function() {
      currentIdx = parseInt(this.getAttribute('data-idx'), 10);
      renderModule();
    });
  });

  // Wire pill clicks
  var pillsEl = document.getElementById('crPills');
  if (pillsEl) {
    Array.from(pillsEl.querySelectorAll('.pill')).forEach(function(el) {
      el.addEventListener('click', function() {
        currentIdx = parseInt(this.getAttribute('data-idx'), 10);
        renderModule();
      });
    });
  }

  // Prev / Next buttons
  var prevBtn = document.getElementById('crPrevBtn');
  var nextBtn = document.getElementById('crNextBtn');
  prevBtn.addEventListener('click', function() { if (currentIdx > 0) { currentIdx--; renderModule(); } });
  nextBtn.addEventListener('click', function() { if (currentIdx < modules.length - 1) { currentIdx++; renderModule(); } });

  completeBtn.addEventListener('click', toggleComplete);

  // Initial render
  if (modules.length) {
    try { renderModule(); } catch(e) { console.error('renderModule error:', e); }
    try { renderProgress(); } catch(e) {}
    renderCertCta();
    try { renderPills(); } catch(e) {}
    try { renderNavBtns(); } catch(e) {}
  } else {
    moduleContent.innerHTML = '<div class="alert alert-danger">Course content not found.</div>';
  }
</script>

<%- include('partials/footer') %>
