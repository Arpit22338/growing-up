// Get current course key from server variable
const courseKey = '<%= course.key %>';
const modules = courseModules[courseKey] || [];

const moduleList = document.getElementById('moduleList');
const moduleContent = document.getElementById('moduleContent');

function renderModuleList() {
  moduleList.innerHTML = '';
  modules.forEach((mod, idx) => {
    const li = document.createElement('li');
    li.textContent = mod.title;
    li.onclick = () => selectModule(idx);
    if (idx === 0) li.classList.add('active');
    moduleList.appendChild(li);
  });
}

function selectModule(idx) {
  Array.from(moduleList.children).forEach((li, i) => {
    li.classList.toggle('active', i === idx);
  });
  moduleContent.innerHTML = `<h3 style='color:#3730a3;font-weight:600;margin-bottom:10px;'>${modules[idx].title}</h3><div style='font-size:1.08rem;color:#334155;'>${modules[idx].content}</div>`;
}

if (modules.length) {
  renderModuleList();
  selectModule(0);
} else {
  moduleContent.innerHTML = '<div class="alert alert-danger">Course content not found.</div>';
}
