<%- include('partials/header', { loggedInUser }) %>
<style>
  .course-read-hero {
    background: linear-gradient(90deg, #f8fafc 60%, #e0e7ff 100%);
    border-radius: 18px;
    padding: 32px 24px 24px 24px;
    margin-bottom: 32px;
    box-shadow: 0 2px 16px 0 rgba(60,72,100,0.07);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
  }
  .course-read-hero h1 {
    font-size: 2.2rem;
    font-weight: 700;
    color: #1e293b;
    margin-bottom: 0;
  }
  .course-read-hero p {
    color: #475569;
    font-size: 1.1rem;
    margin-bottom: 0;
  }
  .module-list {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin: 0 0 24px 0;
    padding: 0;
    list-style: none;
  }
  .module-list li {
    background: #fff;
    border: 1.5px solid #c7d2fe;
    border-radius: 8px;
    padding: 10px 18px;
    font-weight: 500;
    color: #3730a3;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
    box-shadow: 0 1px 4px 0 rgba(60,72,100,0.04);
  }
  .module-list li.active, .module-list li:hover {
    background: #6366f1;
    color: #fff;
    border-color: #6366f1;
  }
  .module-content {
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 2px 12px 0 rgba(60,72,100,0.06);
    padding: 28px 20px;
    margin-bottom: 32px;
    min-height: 220px;
    animation: fadeIn 0.4s;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @media (max-width: 600px) {
    .course-read-hero { padding: 18px 8px 16px 8px; }
    .module-content { padding: 16px 6px; }
    .module-list li { padding: 8px 10px; font-size: 0.98rem; }
  }
</style>

<div class="container course-read">
  <div class="course-read-hero">
    <h1><%= course.name %> <span style="font-size:1.1rem;font-weight:400;color:#6366f1;">Course</span></h1>
    <p><%= course.description %></p>
    <div style="display:flex;align-items:center;gap:10px;">
      <span style="background:#6366f1;color:#fff;padding:4px 12px;border-radius:6px;font-size:0.98rem;">Level: <%= course.title %></span>
      <span style="background:#fbbf24;color:#fff;padding:4px 12px;border-radius:6px;font-size:0.98rem;">Price: <%= course.currency %><%= course.price %></span>
    </div>
  </div>

  <!-- Module Navigation -->
  <ul class="module-list" id="moduleList">
    <!-- JS will populate modules -->
  </ul>

  <!-- Module Content -->
  <div class="module-content" id="moduleContent">
    <!-- JS will populate content -->
  </div>

  <a href="/dashboard" class="btn btn-primary mt-4" style="margin-bottom:32px;">Go to Dashboard</a>
</div>

