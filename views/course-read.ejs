<%- include('partials/header', { loggedInUser }) %>
<style>
  .course-read-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 32px 16px;
  }
  .course-read-hero {
    background: linear-gradient(90deg, #f8fafc 60%, #e0e7ff 100%);
    border-radius: 18px;
    padding: 32px 24px;
    margin-bottom: 32px;
    box-shadow: 0 2px 16px 0 rgba(60,72,100,0.07);
  }
  .course-read-hero h1 {
    font-size: 2.2rem;
    font-weight: 700;
    color: #1e293b;
    margin-bottom: 8px;
  }
  .course-read-hero p {
    color: #475569;
    font-size: 1.1rem;
    margin-bottom: 12px;
  }
  .course-content {
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 2px 12px 0 rgba(60,72,100,0.06);
    padding: 28px 24px;
    margin-bottom: 32px;
    min-height: 300px;
  }
  .course-content h1, .course-content h2 {
    color: #3730a3;
    margin-bottom: 16px;
  }
  .course-content h3 {
    color: #6366f1;
    margin-bottom: 12px;
  }
  .course-content p {
    color: #334155;
    line-height: 1.7;
    margin-bottom: 14px;
  }
  .course-content ul, .course-content ol {
    color: #334155;
    line-height: 1.7;
    margin-bottom: 16px;
    padding-left: 24px;
  }
  .course-content li {
    margin-bottom: 6px;
  }
  .course-content iframe {
    max-width: 100%;
    border-radius: 8px;
    margin: 16px 0;
  }
  @media (max-width: 600px) {
    .course-read-hero { padding: 18px 12px; }
    .course-read-hero h1 { font-size: 1.6rem; }
    .course-content { padding: 16px 12px; }
  }
</style>

<div class="course-read-container">
  <div class="course-read-hero">
    <h1><%= course.name %></h1>
    <p><%= course.description %></p>
    <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
      <span style="background:#6366f1;color:#fff;padding:4px 12px;border-radius:6px;font-size:0.98rem;">Level: <%= course.title %></span>
      <span style="background:#fbbf24;color:#fff;padding:4px 12px;border-radius:6px;font-size:0.98rem;">Price: <%= course.currency %><%= course.price %></span>
    </div>
  </div>

  <div class="course-content">
    <%- include(contentPartial) %>
  </div>

  <a href="/dashboard" class="btn btn-primary" style="margin-bottom:32px;">Go to Dashboard</a>
</div>

<%- include('partials/footer') %>
